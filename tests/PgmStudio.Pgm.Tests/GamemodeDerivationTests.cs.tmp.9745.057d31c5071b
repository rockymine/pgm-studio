using PgmStudio.Pgm;

namespace PgmStudio.Pgm.Tests;

/// <summary>
/// The gamemode is derived from which objective modules a map carries — PGM never reads
/// <c>&lt;gamemode&gt;</c> to decide it. That element is the author's label: most maps omit it, some
/// disagree with their own modules, and it must never be defaulted into a fact.
/// </summary>
public sealed class GamemodeDerivationTests
{
    private static string Map(string body, string? gamemode = null) =>
        $"""<?xml version="1.0"?><map proto="1.5.0"><name>m</name><version>1</version>
        {(gamemode is null ? "" : $"<gamemode>{gamemode}</gamemode>")}<objective>o</objective>{body}</map>""";

    private static PgmStudio.Domain.MapXml Parse(string body, string? gamemode = null) =>
        MapParser.ParseXmlString(Map(body, gamemode));

    private const string Wool = """<wools team="red"><wool color="red" location="1,2,3"><monument><block>1,2,3</block></monument></wool></wools>""";
    private const string Destroyable = """<destroyables><destroyable owner="red" name="Hill" materials="obsidian"/></destroyables>""";

    [Test]
    public async Task Wools_make_a_map_ctw()
        => await Assert.That(Parse(Wool).Gamemodes).IsEquivalentTo(new[] { "ctw" });

    [Test]
    public async Task A_real_destroyable_makes_a_map_dtm()
        => await Assert.That(Parse(Destroyable).Gamemodes).IsEquivalentTo(new[] { "dtm" });

    // CTW, DTM and DTC coexist — a scalar cannot hold this, and both corpora keep a mixed/ directory
    // for the maps that prove it.
    [Test]
    public async Task A_map_can_be_more_than_one_gamemode()
        => await Assert.That(Parse(Wool + Destroyable).Gamemodes).IsEquivalentTo(new[] { "ctw", "dtm" });

    [Test]
    public async Task A_map_with_no_objective_module_has_no_gamemode()
        => await Assert.That(Parse("").Gamemodes).IsEmpty();

    // The deviation from PGM: it tags a map DTM the moment DestroyableModule parses anything. A map whose
    // every destroyable is a phantom is pure CTW that happens to script its build floor with the element.
    [Test]
    public async Task A_phantom_only_module_contributes_no_gamemode()
    {
        var m = Parse(Wool + """
            <modes><mode id="mode-air" after="0s" material="air"/></modes>
            <destroyables materials="stained glass" completion="0%" show="false" mode-changes="true">
                <destroyable owner="red" name="monu"/>
                <destroyable owner="blue" name="monu"/>
            </destroyables>
            """);
        await Assert.That(m.Destroyables.Count).IsEqualTo(2);   // kept — a phantom is load-bearing
        await Assert.That(m.Gamemodes).IsEquivalentTo(new[] { "ctw" });
    }

    [Test]
    public async Task One_real_destroyable_among_phantoms_is_enough()
    {
        var m = Parse("""
            <destroyables materials="obsidian">
                <destroyable owner="red" name="marker" show="false"/>
                <destroyable owner="red" name="Hill"/>
            </destroyables>
            """);
        await Assert.That(m.Gamemodes).IsEquivalentTo(new[] { "dtm" });
    }

    // ── the declared label ──────────────────────────────────────────────────────────
    [Test]
    public async Task An_absent_gamemode_element_stays_absent()
    {
        var m = Parse(Wool);
        await Assert.That(m.DeclaredGamemode).IsEmpty();
        await Assert.That(XmlWriter.ToXml(m)).DoesNotContain("<gamemode>");
    }

    // lindorm and rushers_vs_defenders label themselves `ad` while carrying wools: the label says how the
    // map is played, which no module expresses. It round-trips verbatim and does not affect the derivation.
    [Test]
    public async Task The_declared_label_round_trips_and_never_overrides_the_derivation()
    {
        var m = Parse(Wool, "ad");
        await Assert.That(m.DeclaredGamemode).IsEqualTo("ad");
        await Assert.That(m.Gamemodes).IsEquivalentTo(new[] { "ctw" });
        await Assert.That(XmlWriter.ToXml(m)).Contains("<gamemode>ad</gamemode>");
        await Assert.That(MapParser.ParseXmlString(XmlWriter.ToXml(m)).DeclaredGamemode).IsEqualTo("ad");
    }

    // A destroyables map declaring `ctw` is one of PGM's own inconsistencies; the modules win.
    [Test]
    public async Task A_label_contradicting_the_modules_does_not_win()
    {
        var m = Parse(Destroyable, "ctw");
        await Assert.That(m.DeclaredGamemode).IsEqualTo("ctw");
        await Assert.That(m.Gamemodes).IsEquivalentTo(new[] { "dtm" });
    }
}
