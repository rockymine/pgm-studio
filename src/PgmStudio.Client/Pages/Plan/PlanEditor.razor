@page "/plan-editor"
@layout EditorLayout
@inject IJSRuntime JS
@implements IAsyncDisposable

@* Plan editor (the seed studio) — a coarse cell-grid layout tool. Blazor renders the topbar, a thin
   rail that folds the collapsible left settings panel (plan name · globals · reference · overlays), the
   canvas shell whose toolbar holds the draw tools (pieces · build · markers · technical), and the right
   inspector; the PlanCanvas JS (via bridge/plan-bridge.js) owns the plan document, the pointer tools and
   the live symmetry mirror ghost. Plans import/export as *.plan.json; edits autosave to localStorage. *@

<div class="editor-page">
  <div id="topbar" class="topbar">
    <a href="/" class="topbar-breadcrumb-home" title="Studio home">
      <i data-lucide="house"></i><span>Studio</span>
    </a>
    <span class="topbar-sep">›</span>
    <span class="topbar-crumb topbar-crumb--dim">Plan editor</span>
    <div class="topbar-right">
      @if (importError is not null) { <span class="topbar-crumb topbar-crumb--dim">@importError</span> }
      <button class="action-btn" @onclick="NewPlan" title="Start a blank plan">New</button>
      <label class="action-btn" title="Import a *.plan.json file">
        Import
        <InputFile OnChange="OnImport" accept=".json" style="display:none" />
      </label>
      <button class="action-btn" @onclick="ExportPlan" title="Download this plan as *.plan.json">Export</button>
      <button class="action-btn action-btn--primary" @onclick="OpenCompile" title="Compile the plan into a layout + intent, then create a draft">
        <i data-lucide="play"></i> Compile
      </button>
      <ThemeToggle />
    </div>
  </div>

  <div id="main" class="app-body">
    <nav class="activity-rail">
      <a class="activity-logo" href="/" title="Studio home">
        <div class="activity-logo-box">
          <span class="activity-logo-pgm">pgm</span>
          <span class="activity-logo-sub">STUDIO</span>
        </div>
      </a>
      <button class="activity-btn @(leftPanel == "settings" && leftOpen ? "active" : null)" title="Settings" @onclick='() => SelectActivity("settings")'>
        <i data-lucide="sliders-horizontal"></i>
      </button>
      <button class="activity-btn @(leftPanel == "validation" && leftOpen ? "active" : null)" title="Validation — evaluator score &amp; fired rules" @onclick='() => SelectActivity("validation")'>
        <i data-lucide="shield-check"></i>
      </button>
    </nav>

    <div class="activity-viewport">
      <div class="workspace">
        @if (leftOpen)
        {
        <div class="workspace-sidebar">
          <div class="workspace-scroll">
            @if (leftPanel == "settings")
            {
            <div class="panel-section">
              <div class="field">
                <label class="field-label">Plan name</label>
                <input class="field-input" value="@planName" @onchange="OnName" placeholder="Untitled plan" />
              </div>
            </div>

            <div class="panel-section">
              <div class="section-header section-header--ruled"><h2 class="section-title">Symmetry &amp; globals</h2></div>
              <div class="field">
                <label class="field-label">Symmetry</label>
                <select class="field-input" value="@symmetry" @onchange="OnSymmetry">
                  <option value="rot_180">Rotate 180°</option>
                  <option value="rot_90">Rotate 90°</option>
                  <option value="mirror_x">Mirror X</option>
                  <option value="mirror_z">Mirror Z</option>
                  <option value="none">None — single unit</option>
                </select>
              </div>
              <div class="field">
                <label class="field-label">Cell size (blocks)</label>
                <NumberField Value="cell" ValueChanged="OnCell" Min="1" />
              </div>
              <div class="field">
                <label class="field-label">Base surface (y)</label>
                <NumberField Value="surface" ValueChanged="OnSurface" Min="0" />
              </div>
              <div class="field">
                <label class="field-label">Surface step (y)</label>
                <NumberField Value="surfaceStep" ValueChanged="OnSurfaceStep" Min="1" />
              </div>
              <div class="field">
                <label class="field-label">Headroom</label>
                <NumberField Value="headroom" ValueChanged="OnHeadroom" Min="1" />
              </div>
              <div class="field">
                <label class="field-label">Max players</label>
                <NumberField Value="maxPlayers" ValueChanged="OnMaxPlayers" Min="2" Step="2" />
              </div>
            </div>

            <div class="panel-section">
              <div class="section-header section-header--ruled"><h2 class="section-title">Reference</h2></div>
              <div class="field">
                <label class="field-label">Trace over map</label>
                <select class="field-input" value="@refMap" @onchange="OnPickReferenceMap">
                  <option value="">— none —</option>
                  @foreach (var m in traceMaps) { <option value="@m.Slug">@m.Name</option> }
                </select>
              </div>
              @if (refError is not null) { <p class="section-desc plan-compile-draft-error">@refError</p> }
              @if (refMap is not null)
              {
                <div class="field">
                  <label class="field-label">Opacity</label>
                  <input type="range" class="field-input" min="0" max="1" step="0.05" value="@refOpacity" @oninput="OnRefOpacity" />
                </div>
                <div class="field">
                  <label class="field-label">Offset X (cells)</label>
                  <NumberField Value="refOffsetX" ValueChanged="OnRefOffsetX" Step="1" />
                </div>
                <div class="field">
                  <label class="field-label">Offset Z (cells)</label>
                  <NumberField Value="refOffsetZ" ValueChanged="OnRefOffsetZ" Step="1" />
                </div>
                <div class="field">
                  <label class="field-label">Scale</label>
                  <NumberField Value="refScale" ValueChanged="OnRefScale" Min="0.1" Step="0.1" />
                </div>
                <div class="ctrl-row">
                  <button class="action-btn action-btn--full" @onclick="RecenterReference" title="Reset offset and scale">Recenter</button>
                  <button class="action-btn action-btn--full" @onclick="ClearReference" title="Remove the backdrop (keeps the plan)">Clear</button>
                </div>
              }
              <p class="section-desc">Trace a real map's top-down render to build a plan from it. The backdrop is saved with the plan as provenance and never affects the compiled output.</p>
            </div>

            <div class="panel-section">
              <div class="section-header section-header--ruled"><h2 class="section-title">Overlays</h2></div>
              <div class="plan-overlay-toggles">
                <button class="filter-chip @(overlayInterfaces ? "filter-chip--active" : null)" title="Land interfaces (green, slimmer core if narrow) · corner contacts (red)"
                        @onclick='() => ToggleOverlay("interfaces")'>Interfaces</button>
                <button class="filter-chip @(overlayFrontline ? "filter-chip--active" : null)" title="Piece edges facing a build area"
                        @onclick='() => ToggleOverlay("frontline")'>Frontline</button>
                <button class="filter-chip @(overlayLabels ? "filter-chip--active" : null)" title="Piece / build-area id labels and build-area gap links with hop distance"
                        @onclick='() => ToggleOverlay("labels")'>Labels</button>
                <button class="filter-chip @(heightMap ? "filter-chip--active" : null)" title="Colour pieces by island height (surface y)"
                        @onclick="ToggleHeightMap">Heights</button>
              </div>
              <p class="section-desc">Toggle the derived-structure overlays and the height ramp drawn on the canvas.</p>
            </div>
            }
            else
            {
            <div class="panel-section">
              <div class="section-header section-header--ruled">
                <h2 class="section-title">Validation</h2>
                @if (evaluation is not null)
                {
                  <span class="badge @(evaluation.Valid ? "badge--success" : "badge--error")" title="Evaluator cost — lower is better, 0 is perfect">@evaluation.Score.ToString("0.##")</span>
                }
              </div>
              @if (evaluation is null)
              {
                <p class="section-desc">The evaluator scores the plan against the layout rules — hard well-formedness first, then soft feel. Click a fired rule to isolate its evidence on the canvas.</p>
              }
              else if (evaluation.Violations.Count == 0)
              {
                <div class="plan-lint-ok"><i data-lucide="check-circle-2"></i> No rules fired</div>
              }
              else
              {
                <div class="plan-lint-list">
                  @for (var i = 0; i < evaluation.Violations.Count; i++)
                  {
                    var idx = i;
                    var v = evaluation.Violations[i];
                    <button class="plan-lint-row @(selectedViolation == idx ? "plan-lint-row--active" : null)" @onclick="() => SelectViolation(idx)" title="Show only this rule's evidence on the canvas">
                      <span class="plan-lint-dot @(v.Kind == "hard" ? "plan-lint-dot--error" : "plan-lint-dot--lint")"></span>
                      <span class="plan-lint-chip">@v.RuleId</span>
                      <span class="plan-lint-msg">@v.Message</span>
                      @if (v.Kind == "soft") { <span class="list-tag">@v.Distance.ToString("0.#")</span> }
                    </button>
                  }
                </div>
              }
            </div>
            }
          </div>
        </div>
        <div class="sidebar-handle"></div>
        }

        <div class="workspace-canvas">
          <div class="canvas-subbar">
            <div class="plan-toolbar">
              <button class="draw-tool-btn @(tool == "select" ? "draw-tool-btn--active" : null)" title="Select / edit"
                      @onclick='() => PickTool("select")'><i data-lucide="mouse-pointer-2"></i></button>
              <button class="draw-tool-btn @(tool == "pan" ? "draw-tool-btn--active" : null)" title="Move / pan"
                      @onclick='() => PickTool("pan")'><i data-lucide="hand"></i></button>
              <span class="plan-tool-sep"></span>
              @foreach (var r in GeneratingRoles)
              {
                <button class="draw-tool-btn @(tool == "piece" && role == r.Id ? "draw-tool-btn--active" : null)"
                        style="--role-color:@r.Color" title="Draw a @r.Label piece" @onclick="() => PickRole(r.Id)">
                  <span class="plan-role-swatch"></span>
                </button>
              }
              <button class="draw-tool-btn @(tool == "zone" ? "draw-tool-btn--active" : null)" title="Draw a build area" @onclick='() => PickTool("zone")'>
                <span class="plan-role-swatch plan-role-swatch--build"></span>
              </button>
              <span class="plan-tool-sep"></span>
              <button class="draw-tool-btn @(tool == "spawn" ? "draw-tool-btn--active" : null)" title="Place a spawn marker · click a placed spawn to cycle its facing" @onclick='() => PickTool("spawn")'>
                <i data-lucide="flag"></i>
              </button>
              <button class="draw-tool-btn @(tool == "wool" ? "draw-tool-btn--active" : null)" title="Place a wool goal marker" @onclick='() => PickTool("wool")'>
                <i data-lucide="square"></i>
              </button>
              <button class="draw-tool-btn @(tool == "iron" ? "draw-tool-btn--active" : null)" title="Place an iron marker" @onclick='() => PickTool("iron")'>
                <i data-lucide="pickaxe"></i>
              </button>
              @* A destroyable is defended by one team and broken by the others, which only means something
                 when there are two: at four teams PGM treats every goal as shared, and what that should play
                 like is undecided. So the tool is offered for the 2-team symmetries only (OB14). *@
              @if (ObjectivesOfferable)
              {
                <button class="draw-tool-btn @(tool == "destroyable" ? "draw-tool-btn--active" : null)" title="Place a destroyable (DTM) marker" @onclick='() => PickTool("destroyable")'>
                  <i data-lucide="gem"></i>
                </button>
              }
              <button class="draw-tool-btn @(tool == "wall" ? "draw-tool-btn--active" : null)" title="Toggle a pre-built wall on the land interface you click" @onclick='() => PickTool("wall")'>
                <i data-lucide="brick-wall"></i>
              </button>
              <span class="plan-tool-sep"></span>
              @foreach (var r in TechnicalRoles)
              {
                <button class="draw-tool-btn @(tool == "piece" && role == r.Id ? "draw-tool-btn--active" : null)"
                        style="--role-color:@r.Color" title="Draw a @r.Label annotation" @onclick="() => PickRole(r.Id)">
                  <span class="plan-role-swatch plan-role-swatch--@r.Id"></span>
                </button>
              }
            </div>
            <div @ref="cursorRef" class="canvas-cursor"></div>
            <div class="canvas-subbar-right">
              <button class="filter-chip" title="Fit the plan to view" @onclick="Fit"><i data-lucide="scan"></i></button>
              <button class="filter-chip @(threeD ? "filter-chip--active" : null)" disabled="@isoUnavailable"
                      title="@(isoUnavailable ? "3-D preview needs WebGL, which isn't available in this browser" : "Isometric height preview (read-only)")"
                      @onclick="Toggle3D">3D</button>
              @if (isoUnavailable)
              {
                <span class="canvas-zoom" title="The 3-D height preview needs WebGL, which this browser can't provide.">no WebGL</span>
              }
              @if (threeD)
              {
                <button class="filter-chip" title="Rotate the preview 90°" @onclick="RotateIso"><i data-lucide="rotate-cw"></i></button>
              }
              <span class="canvas-zoom">@zoomLabel</span>
            </div>
          </div>
          <div @ref="wrapRef" class="svg-area">
            <svg @ref="svgRef" class="map-canvas-svg" xmlns="http://www.w3.org/2000/svg"></svg>
          </div>
        </div>
        <div class="sidebar-handle"></div>

        <div class="workspace-inspector">
          <div class="workspace-scroll">
            <div class="panel-section">
              @if (sel is null)
              {
                <p class="section-desc">Select a piece, build area or marker to inspect. Draw a piece from the palette, then drop spawns / wools onto it.</p>
              }
              else if (sel.Kind == "piece")
              {
                <div class="detail-header">
                  <span class="geo-type-icon"><i data-lucide="box"></i></span>
                  <span class="detail-label">Piece</span>
                  <span class="detail-header-badges"><span class="badge badge--neutral">@sel.Role</span></span>
                </div>
                <div class="field">
                  <label class="field-label">Id</label>
                  <input class="field-input" value="@sel.Id" @onchange="OnPieceId" />
                </div>
                <div class="field">
                  <label class="field-label">Role</label>
                  <select class="field-input" value="@sel.Role" @onchange="OnPieceRole">
                    @foreach (var r in Roles) { <option value="@r.Id">@r.Label</option> }
                  </select>
                </div>
                <div class="field">
                  <label class="field-label">Surface (y)</label>
                  <div class="ctrl-row">
                    <button class="action-btn action-btn--icon" title="Lower surface by @((int)surfaceStep)" @onclick="() => StepSurface(-(int)surfaceStep)">−</button>
                    <span class="plan-stepper-value">@sel.Surface@(sel.SurfaceSet ? "" : " (base)")</span>
                    <button class="action-btn action-btn--icon" title="Raise surface by @((int)surfaceStep)" @onclick="() => StepSurface((int)surfaceStep)">+</button>
                  </div>
                </div>
                <div class="field">
                  <label class="field-label">Step</label>
                  <div class="ctrl-row">
                    @foreach (var s in StepPresets)
                    {
                      <button class="filter-chip @((int)surfaceStep == s ? "filter-chip--active" : null)" title="Step surface by @s" @onclick="() => SetSurfaceStep(s)">@s</button>
                    }
                  </div>
                </div>
                <button class="action-btn action-btn--full" @onclick="ToggleMirrors">
                  @(sel.Mirrors ? "Exclude from mirror" : "Include in mirror")
                </button>
                <button class="action-btn action-btn--full action-btn--danger" @onclick="DeleteSelected">
                  <i data-lucide="trash-2"></i> Delete piece
                </button>
              }
              else if (sel.Kind == "zone")
              {
                <div class="detail-header">
                  <span class="geo-type-icon"><i data-lucide="square-dashed"></i></span>
                  <span class="detail-label">Build area</span>
                </div>
                <div class="field">
                  <label class="field-label">Id</label>
                  <input class="field-input" value="@sel.Id" @onchange="OnZoneId" />
                </div>
                <button class="action-btn action-btn--full action-btn--danger" @onclick="DeleteSelected">
                  <i data-lucide="trash-2"></i> Delete build area
                </button>
              }
              else
              {
                <div class="detail-header">
                  <span class="geo-type-icon"><i data-lucide="flag"></i></span>
                  <span class="detail-label">@sel.MarkerKind</span>
                </div>
                <div class="field">
                  <label class="field-label">On piece</label>
                  <div class="plan-readout">@sel.Piece &nbsp; <span class="list-tag">at @OffsetLabel</span></div>
                </div>
                @if (sel.MarkerKind == "spawn")
                {
                  <div class="field">
                    <label class="field-label">Facing</label>
                    <div class="ctrl-row">
                      <span class="plan-stepper-value">@sel.Facing</span>
                      <button class="action-btn action-btn--icon" @onclick="CycleFacing" title="Cycle facing"><i data-lucide="rotate-cw"></i></button>
                    </div>
                  </div>
                }
                <button class="action-btn action-btn--full action-btn--danger" @onclick="DeleteSelected">
                  <i data-lucide="trash-2"></i> Delete marker
                </button>
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  @if (showCompile)
  {
    <div class="plan-compile-backdrop" @onclick="CloseCompile"></div>
    <div class="plan-compile-drawer" @onclick:stopPropagation="true">
      <div class="plan-compile-head">
        <div class="detail-header">
          <span class="geo-type-icon"><i data-lucide="play"></i></span>
          <span class="detail-label">Compile &amp; test</span>
        </div>
        <button class="action-btn action-btn--icon" title="Close" @onclick="CloseCompile"><i data-lucide="x"></i></button>
      </div>

      <div class="plan-compile-body">
        @if (compiling)
        {
          <p class="section-desc">Compiling…</p>
        }
        else if (compileErrors.Count > 0)
        {
          <div class="plan-compile-errors">
            <p class="section-desc">Fix these structural errors before compiling (lint alone never blocks):</p>
            @foreach (var f in compileErrors)
            {
              <div class="plan-lint-row plan-lint-row--static">
                <span class="plan-lint-dot plan-lint-dot--error"></span>
                @if (!string.IsNullOrEmpty(f.Rule)) { <span class="plan-lint-chip">@f.Rule</span> }
                <span class="plan-lint-msg">@f.Message</span>
              </div>
            }
          </div>
        }
        else if (compileError is not null)
        {
          <div class="plan-compile-errors"><p class="section-desc">@compileError</p></div>
        }
        else if (compiledLayout is not null)
        {
          <div class="plan-compile-tabs">
            <button class="draw-tool-btn @(compileTab == "layout" ? "draw-tool-btn--active" : null)" @onclick='() => compileTab = "layout"'>Layout</button>
            <button class="draw-tool-btn @(compileTab == "intent" ? "draw-tool-btn--active" : null)" @onclick='() => compileTab = "intent"'>Intent</button>
            <div class="plan-compile-tab-actions">
              <button class="action-btn" title="Copy to clipboard" @onclick="CopyTab"><i data-lucide="clipboard"></i> @(copied ? "Copied" : "Copy")</button>
              <button class="action-btn" title="Download this file" @onclick="DownloadTab"><i data-lucide="download"></i> Download</button>
            </div>
          </div>
          <pre class="plan-compile-json">@(compileTab == "layout" ? compiledLayout : compiledIntent)</pre>
        }
      </div>

      <div class="plan-compile-foot">
        <div class="plan-compile-draft">
          @if (draftSlug is null)
          {
            <button class="action-btn action-btn--primary action-btn--full" disabled="@(compiledLayout is null || draftBusy)" @onclick="CreateDraft">
              @if (draftBusy) { <span>@draftStep…</span> } else { <span><i data-lucide="hammer"></i> Create draft</span> }
            </button>
          }
          else
          {
            <div class="plan-lint-ok"><i data-lucide="check-circle-2"></i> Draft <strong>@draftSlug</strong> created</div>
            <a class="action-btn action-btn--full" href="@($"/maps/{draftSlug}/sketch")" target="_blank" rel="noopener">
              <i data-lucide="external-link"></i> Open in sketch editor
            </a>
            <button class="action-btn action-btn--primary action-btn--full" @onclick="DownloadWorld">
              <i data-lucide="download"></i> Download world ZIP
            </button>
          }
          @if (draftError is not null) { <p class="section-desc plan-compile-draft-error">@draftError</p> }
        </div>
      </div>
    </div>
  }
</div>
