@page "/maps/{Slug}/edit"
@layout EditorLayout
@inject HttpClient Http
@inject IJSRuntime JS
@using PgmStudio.Client.Pages.EditorActivities

@* Editor shell — topbar + activity rail + activity viewport. Port of studio/templates/editor.html
   + the activity state machine in static/main.js. *@

<StudioShell>
  <Bar>
    <Topbar HomeHref="/maps" HomeLabel="Maps" HomeTitle="Back to dashboard">
      <Crumbs>
        <Crumb>@(mapName ?? Slug.Replace('_', ' '))</Crumb>
        <Crumb Dim>@(string.IsNullOrEmpty(mapVersion) ? "" : $"v{mapVersion}")</Crumb>
      </Crumbs>
      <Right>
        <div id="topbar-error" role="alert" class="@(error is null ? null : "is-visible")">
          <span class="topbar-error-text">@error</span>
          <button class="topbar-error-dismiss" @onclick="() => error = null"><i data-lucide="x"></i></button>
        </div>
        <Button Disabled>Export XML</Button>
      </Right>
    </Topbar>
  </Bar>
  <Rail>
    <ActivityRail>
      @foreach (var a in Activities)
      {
        <ActivityButton Icon="@a.Icon" Title="@a.Title" Active="active == a.Id"
                        Disabled="!loaded" Status="@StatusOf(a.Id)" OnClick="() => Switch(a.Id)" />
      }
      <ActivityButton Icon="gavel" Title="Filters" Disabled="true" />
      <ActivityButton Icon="archive" Title="Export" Disabled="true" />
    </ActivityRail>
  </Rail>
  <ChildContent>
      @if (!loaded)
      {
        <div class="workspace workspace--placeholder">
          <p class="panel-empty-msg">@(error ?? "Loading map…")</p>
        </div>
      }
      else
      {
        @switch (active)
        {
          case "setup":
            <ConfigureActivity Slug="@Slug" OnComplete="GoOverview" />
            break;
          case "overview":
            <OverviewActivity Slug="@Slug" OnStatus="OnOverviewStatus" />
            break;
          case "teams":
            <TeamsActivity Slug="@Slug" />
            break;
          case "build-regions":
            <BuildRegionsActivity Slug="@Slug" />
            break;
          case "objective":
            <ObjectiveActivity Slug="@Slug" />
            break;
          case "regions":
            <RegionsActivity Slug="@Slug" />
            break;
          default:
            <div class="workspace workspace--placeholder">
              <p class="panel-empty-msg">@(TitleOf(active)) — not yet ported.</p>
            </div>
            break;
        }
      }
  </ChildContent>
</StudioShell>
