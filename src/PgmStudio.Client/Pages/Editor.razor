@page "/editor/{Slug}"
@layout EditorLayout
@inject HttpClient Http
@inject IJSRuntime JS
@using PgmStudio.Client.Pages.EditorActivities

@* Editor shell — topbar + activity rail + activity viewport. Port of studio/templates/editor.html
   + the activity state machine in static/main.js. *@

<div class="editor-page">

  <div id="topbar" class="topbar">
    <a href="/" class="topbar-breadcrumb-home" title="Back to dashboard">
      <i data-lucide="house"></i>
      <span>Maps</span>
    </a>
    <span class="topbar-sep">›</span>
    <span class="topbar-crumb">@(mapName ?? Slug.Replace('_', ' '))</span>
    <span class="topbar-sep">›</span>
    <span class="topbar-crumb topbar-crumb--dim">@(string.IsNullOrEmpty(mapVersion) ? "" : $"v{mapVersion}")</span>

    <div class="topbar-right">
      <div id="topbar-error" role="alert" class="@(error is null ? null : "is-visible")">
        <span class="topbar-error-text">@error</span>
        <button class="topbar-error-dismiss" @onclick="() => error = null"><i data-lucide="x"></i></button>
      </div>
      <button class="action-btn" disabled>Export XML</button>
    </div>
  </div>

  <div id="main" class="app-body">
    <nav class="activity-rail">
      <div class="activity-logo">
        <div class="activity-logo-box">
          <span class="activity-logo-pgm">pgm</span>
          <span class="activity-logo-sub">STUDIO</span>
        </div>
      </div>
      @foreach (var a in Activities)
      {
        <button class="activity-btn @(active == a.Id ? "active" : null)"
                title="@a.Title" disabled="@(!loaded)" data-status="@StatusOf(a.Id)"
                @onclick="() => Switch(a.Id)">
          <i data-lucide="@a.Icon"></i>
        </button>
      }
      <button class="activity-btn" disabled title="Filters"><i data-lucide="gavel"></i></button>
      <button class="activity-btn" disabled title="Export"><i data-lucide="archive"></i></button>
    </nav>

    <div class="activity-viewport">
      @if (!loaded)
      {
        <div class="workspace workspace--placeholder">
          <p class="panel-empty-msg">@(error ?? "Loading map…")</p>
        </div>
      }
      else
      {
        @switch (active)
        {
          case "configure":
            <ConfigureActivity Slug="@Slug" OnComplete="GoOverview" />
            break;
          case "overview":
            <OverviewActivity Slug="@Slug" OnStatus="OnOverviewStatus" />
            break;
          case "teams":
            <TeamsActivity Slug="@Slug" />
            break;
          case "build-regions":
            <BuildRegionsActivity Slug="@Slug" />
            break;
          case "objective":
            <ObjectiveActivity Slug="@Slug" />
            break;
          case "regions":
            <RegionsActivity Slug="@Slug" />
            break;
          default:
            <div class="workspace workspace--placeholder">
              <p class="panel-empty-msg">@(TitleOf(active)) — not yet ported.</p>
            </div>
            break;
        }
      }
    </div>
  </div>
</div>
