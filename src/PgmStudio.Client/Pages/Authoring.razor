@page "/authoring"
@layout PgmStudio.Client.Layout.EditorLayout
@using PgmStudio.Client.Pages.EditorActivities
@inject IJSRuntime JS

@* Concept showcase for the intent-driven NEW-map authoring experience (docs/contracts/new-map-authoring.md).
   UI-only, no backend: each authoring phase and its panels are laid out with real thunder map data,
   built on the existing tokens/components/editor primitives (canvases render real region geometry,
   fully static). Modelled on /design. *@

