@page "/authoring"
@layout PgmStudio.Client.Layout.EditorLayout
@using PgmStudio.Client.Pages.EditorActivities
@inject IJSRuntime JS

@* Concept showcase for the intent-driven NEW-map authoring experience (docs/contracts/new-map-authoring.md).
   UI-only, no backend. Each authoring phase + its panels are laid out with thunder's REAL region/terrain
   geometry (shared IslandMap component), one mock per sub-step. Built on the existing design system.
   Split into per-heading components under Pages/Authoring/. Modelled on /design. *@

<div class="editor-page">

<div id="topbar" class="topbar">
  <a href="/" class="topbar-breadcrumb-home" title="Back to dashboard">
    <i data-lucide="house"></i>
    <span>Studio</span>
  </a>
  <span class="topbar-sep">›</span>
  <span class="topbar-crumb">New-Map Authoring</span>
  <span class="topbar-crumb topbar-crumb--dim">concept</span>
  <div class="topbar-right">
    <span class="ds-file-list">intent model · thunder_blank</span>
    <ThemeToggle />
  </div>
</div>

<div id="ds-layout">
  <nav id="ds-nav" aria-label="Authoring concept sections">
    <div class="ds-nav-group">Concept</div>
    <a href="#overview" @onclick:preventDefault="true" @onclick='() => Scroll("overview")'>Overview</a>
    <a href="#flow" @onclick:preventDefault="true" @onclick='() => Scroll("flow")'>The flow</a>
    <a href="#nav" @onclick:preventDefault="true" @onclick='() => Scroll("nav")'>Navigation model</a>
    <div class="ds-nav-group">Authoring steps</div>
    <a href="#info" @onclick:preventDefault="true" @onclick='() => Scroll("info")'>0 · Map Info</a>
    <a href="#world" @onclick:preventDefault="true" @onclick='() => Scroll("world")'>1 · World</a>
    <a href="#teams" @onclick:preventDefault="true" @onclick='() => Scroll("teams")'>2 · Teams &amp; Spawns</a>
    <a href="#build" @onclick:preventDefault="true" @onclick='() => Scroll("build")'>3 · Build</a>
    <a href="#validate" @onclick:preventDefault="true" @onclick='() => Scroll("validate")'>Buildability &amp; Traversability</a>
    <a href="#wools" @onclick:preventDefault="true" @onclick='() => Scroll("wools")'>4 · Wools</a>
    <a href="#review" @onclick:preventDefault="true" @onclick='() => Scroll("review")'>5 · Review &amp; Export</a>
    <div class="ds-nav-group">Surfaces</div>
    <a href="#xml" @onclick:preventDefault="true" @onclick='() => Scroll("xml")'>XML preview</a>
    <a href="#tree" @onclick:preventDefault="true" @onclick='() => Scroll("tree")'>Region tree</a>
    <a href="#focus" @onclick:preventDefault="true" @onclick='() => Scroll("focus")'>Side-view &amp; focus</a>
    <div class="ds-nav-group">Reference</div>
    <a href="#principles" @onclick:preventDefault="true" @onclick='() => Scroll("principles")'>Principles</a>
  </nav>

  <main id="ds-main">
    <header class="ds-intro" id="overview">
      <p class="ds-kicker">Intent-driven · UI concept</p>
      <h1>New-Map Authoring</h1>
      <p>
        Today the studio runs <strong>structure → meaning</strong>: it parses a map's XML, then
        <em>derives</em> what each region means. New-map authoring runs the other way —
        <strong>meaning → structure</strong>. The author states intent (identity, teams, spawns, build
        space, wools) and the system <em>generates</em> the region / filter / apply-rule graph that
        serializes to PGM-loadable XML. This page lays out every step of that experience and the panels
        it uses, with canvases drawn from the <em>real</em> terrain and regions of <code>thunder</code> —
        a four-team 90°-rotational map — so a blank copy (<code>thunder_blank</code>) could, in theory, be
        authored end-to-end to a valid export. Each activity shows <em>every</em> sub-step; the step bar
        sits above its own row, the canvas keeps its draw toolbar.
      </p>
    </header>

    <FlowSection />
    <NavModelSection />
    <InfoSection />
    <WorldSection />
    <TeamsSection />
    <BuildSection />
    <ValidateSection />
    <WoolsSection />
    <ReviewSection />
    <XmlSection />
    <TreeSection />
    <FocusSection />
    <PrinciplesSection />

  </main>
</div>

</div>
