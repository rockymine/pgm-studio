                    <div class="list-row list-row--compact"><span class="geo-type-icon"><i data-lucide="layers"></i></span><span class="list-label">Island · W tip</span><span class="list-tag">1,653</span></div>
                    <div class="list-row list-row--compact"><span class="geo-type-icon"><i data-lucide="layers"></i></span><span class="list-label">Island · E arm</span><span class="list-tag">3,024</span></div>
                    <div class="list-row list-row--compact"><span class="geo-type-icon"><i data-lucide="layers"></i></span><span class="list-label">Island · E tip</span><span class="list-tag">1,653</span></div>
                    <div class="list-row list-row--compact"><span class="geo-type-icon"><i data-lucide="layers"></i></span><span class="list-label">Island · S arm</span><span class="list-tag">3,024</span></div>
                    <div class="list-row list-row--compact"><span class="geo-type-icon"><i data-lucide="layers"></i></span><span class="list-label">Island · S tip</span><span class="list-tag">1,653</span></div>
                    <div class="list-row list-row--compact"><span class="geo-type-icon"><i data-lucide="layers"></i></span><span class="list-label">Island · N arm</span><span class="list-tag">3,024</span></div>
                    <div class="list-row list-row--compact"><span class="geo-type-icon"><i data-lucide="layers"></i></span><span class="list-label">Island · N tip</span><span class="list-tag">1,653</span></div>
                  </div>
                </section>

