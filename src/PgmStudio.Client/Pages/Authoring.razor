                    <rect x="15.0"  y="144.0" width="57.0" height="29.0" rx="2"/><!-- blue-two-islands -->
                    <rect x="145.0" y="108.0" width="72.0" height="42.0" rx="2"/><!-- green-main-and-spawn -->
