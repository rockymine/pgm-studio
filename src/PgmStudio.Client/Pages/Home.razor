@page "/"
@layout EditorLayout
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>PGM Studio — Maps</PageTitle>

@* Dashboard — studio-styled map list (no Bootstrap). Each row opens the editor at /editor/{slug}. *@

<div class="editor-page">
  <div class="topbar">
    <span class="topbar-crumb">Map Studio</span>
    <div class="topbar-right">
      <ThemeToggle />
    </div>
  </div>

  <div class="app-body">
    <nav class="activity-rail">
      <div class="activity-logo">
        <div class="activity-logo-box">
          <span class="activity-logo-pgm">pgm</span>
          <span class="activity-logo-sub">STUDIO</span>
        </div>
      </div>
      <button class="activity-btn active" title="Maps"><i data-lucide="map"></i></button>
    </nav>

    <div class="activity-viewport">
      <div class="workspace">
        <div class="workspace-scroll" style="max-width: 960px;">
          <section class="panel-section">
            <div class="section-header section-header--ruled">
              <h2 class="section-title">Maps</h2>
              <span class="badge badge--dim">@(maps?.Count ?? 0)</span>
            </div>
            <input class="field-input" placeholder="Search maps…" @bind="filter" @bind:event="oninput" />
            <div class="panel-list" style="margin-top: var(--space-3);">
              @if (maps is null) { <div class="list-empty">Loading…</div> }
              else if (!Filtered.Any()) { <div class="list-empty">No maps match.</div> }
              else
              {
                @foreach (var m in Filtered)
                {
                  <a class="list-row" href="@($"editor/{m.Slug}")">
                    <span class="list-label list-label--mono">@m.Slug</span>
                    <span class="list-label">@m.Name</span>
                    <span class="list-tag">@m.Gamemode</span>
                    @if (!string.IsNullOrEmpty(m.Version)) { <span class="list-tag">@($"v{m.Version}")</span> }
                  </a>
                }
              }
            </div>
          </section>
        </div>
      </div>
    </div>
  </div>

  <footer class="app-footer">
    <span class="app-footer-brand">PGM Map Studio</span>
    <nav class="app-footer-links">
      <a class="app-footer-link" href="design">
        <i data-lucide="palette"></i><span>Design</span>
      </a>
      <a class="app-footer-link" href="https://github.com/rockymine/pgm-studio" target="_blank" rel="noopener noreferrer">
        @* lucide dropped its brand icons, so inline the GitHub mark (currentColor = themed) *@
        <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 012-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"></path>
        </svg><span>GitHub</span>
      </a>
    </nav>
  </footer>
</div>
