@namespace PgmStudio.Client.Pages.EditorActivities
@inject HttpClient Http
@inject IJSRuntime JS

@* Overview activity — map identity + authors/contributors. Port of studio ov-workspace
   (templates/editor.html) + panels/overview-panel.js. *@

<Workspace>
  <Sidebar>
      <section class="panel-section">
        <div class="section-header section-header--ruled">
          <h2 class="section-title">Map Identity</h2>
        </div>
        <div class="field">
          <label class="field-label" for="ov-name">Map Name <span class="field-required">*</span></label>
          <input id="ov-name" class="field-input" type="text" placeholder="My CTW Map"
                 value="@name" @oninput="e => { name = e.Value?.ToString() ?? string.Empty; Dirty(); }" />
        </div>
        <div class="field-row">
          <div class="field">
            <label class="field-label" for="ov-version">Version <span class="field-required">*</span></label>
            <input id="ov-version" class="field-input" type="text" placeholder="1.0.0"
                   value="@version" @oninput="e => { version = e.Value?.ToString() ?? string.Empty; Dirty(); }" />
          </div>
          <div class="field">
            @* Derived from the map's objective modules, so it is shown rather than asked for: typing a
               gamemode could not change what the map is. Empty when the map carries no objective yet. *@
            <label class="field-label" for="ov-gamemode">Gamemode</label>
            <input id="ov-gamemode" class="field-input" type="text" disabled
                   title="Derived from the map's objectives" placeholder="—" value="@GamemodeLabel" />
          </div>
        </div>
        <div class="field">
          <label class="field-label" for="ov-objective">Objective</label>
          <textarea id="ov-objective" class="field-input field-input--textarea" rows="2"
                    placeholder="Capture all enemy wools!"
                    value="@objective" @oninput="e => { objective = e.Value?.ToString() ?? string.Empty; Dirty(); }"></textarea>
        </div>
      </section>

      <section class="panel-section">
        <div class="section-header section-header--ruled">
          <h2 class="section-title">Authors</h2>
          <button class="action-btn" @onclick="() => AddPerson(authors)">+ Add</button>
        </div>
        <div class="author-list">
          @foreach (var p in authors) { @PersonRow(p, authors) }
        </div>
      </section>

      <section class="panel-section">
        <div class="section-header section-header--ruled">
          <h2 class="section-title">Contributors</h2>
          <button class="action-btn" @onclick="() => AddPerson(contributors)">+ Add</button>
        </div>
        <div class="author-list">
          @foreach (var p in contributors) { @PersonRow(p, contributors) }
        </div>
      </section>

      <section class="panel-section">
        <div class="panel-actions">
          <button class="action-btn action-btn--primary" disabled="@(!dirty)" @onclick="Save">Save changes</button>
          <span class="panel-save-status">@saveStatus</span>
        </div>
      </section>
  </Sidebar>

  <div class="sidebar-handle"></div>

  <div class="workspace-canvas">
    <div @ref="wrapRef" class="svg-area">
      <svg @ref="svgRef" class="map-canvas-svg" xmlns="http://www.w3.org/2000/svg"></svg>
    </div>
  </div>
</Workspace>

@code {
    // PersonRow stays here because it is a Razor markup template; the activity's state and logic
    // live in OverviewActivity.razor.cs.
    private RenderFragment PersonRow(Person p, List<Person> list) => __builder =>
    {
        <div class="author-row">
            <img class="author-avatar" width="16" height="16" alt=""
                 src="@(string.IsNullOrEmpty(p.Uuid) ? AvatarEmpty : $"https://mc-heads.net/avatar/{p.Uuid}/16")" />
            <input class="field-input author-name @(p.Error ? "field-input--error" : null)" type="text"
                   placeholder="Minecraft username" title="@(p.Error ? "Player not found" : p.Uuid)"
                   value="@p.Name"
                   @oninput="e => { p.Name = e.Value?.ToString() ?? string.Empty; Dirty(); }"
                   @onblur="() => ResolveName(p)" />
            <input class="field-input author-contribution" type="text" placeholder="Contribution (optional)"
                   value="@p.Contribution" @oninput="e => { p.Contribution = e.Value?.ToString() ?? string.Empty; Dirty(); }" />
            <button class="btn-remove" title="Remove" @onclick="() => RemovePerson(list, p)">✕</button>
        </div>
    };
}
