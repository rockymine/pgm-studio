@namespace PgmStudio.Client.Pages.EditorActivities
@inject IJSRuntime JS
@inject HttpClient Http
@implements IAsyncDisposable

@* Hybrid editor canvas: Blazor renders the toolbar/labels/svg shell, the reused EditorCanvas JS
   (via bridge/editor-bridge.js interop) owns pan/zoom/render/selection. Cursor + zoom labels are written
   by JS directly (hot path); only selection round-trips to C# (OnSelect). *@

<div class="workspace-canvas">
  <div class="canvas-subbar">
    <div class="canvas-toolbar">
      <button class="draw-tool-btn @(tool == "move" ? "draw-tool-btn--active" : null)" title="Move (M)"
              @onclick='() => SetTool("move")'><i data-lucide="hand"></i></button>
      <button class="draw-tool-btn @(tool == "select" ? "draw-tool-btn--active" : null)" title="Select (S)"
              @onclick='() => SetTool("select")'><i data-lucide="mouse-pointer-2"></i></button>
      @if (DrawCategory is not null)
      {
        <button class="draw-tool-btn @(tool == "rectangle" ? "draw-tool-btn--active" : null)" title="Rectangle"
                @onclick='() => SetTool("rectangle")'><i data-lucide="rectangle-horizontal"></i></button>
        <button class="draw-tool-btn @(tool == "cuboid" ? "draw-tool-btn--active" : null)" title="Cuboid"
                @onclick='() => SetTool("cuboid")'><i data-lucide="box"></i></button>
        <button class="draw-tool-btn @(tool == "cylinder" ? "draw-tool-btn--active" : null)" title="Cylinder"
                @onclick='() => SetTool("cylinder")'><i data-lucide="cylinder"></i></button>
        <button class="draw-tool-btn @(tool == "circle" ? "draw-tool-btn--active" : null)" title="Circle"
                @onclick='() => SetTool("circle")'><i data-lucide="circle"></i></button>
        <button class="draw-tool-btn @(tool == "block" ? "draw-tool-btn--active" : null)" title="Block (single block)"
                @onclick='() => SetTool("block")'><i data-lucide="square"></i></button>
        <button class="draw-tool-btn @(tool == "point" ? "draw-tool-btn--active" : null)" title="Point"
                @onclick='() => SetTool("point")'><i data-lucide="dot"></i></button>
      }
      else if (PointPick)
      {
        <button class="draw-tool-btn @(tool == "point" ? "draw-tool-btn--active" : null)" title="Point — place a spawn"
                @onclick='() => SetTool("point")'><i data-lucide="dot"></i></button>
      }
      else if (RectDraw)
      {
        <button class="draw-tool-btn @(tool == "rectangle" ? "draw-tool-btn--active" : null)" title="Rectangle — draw a protection zone"
                @onclick='() => SetTool("rectangle")'><i data-lucide="rectangle-horizontal"></i></button>
      }
    </div>
    <div @ref="coordsRef" class="canvas-cursor"></div>
    <div class="canvas-subbar-right">
      @if (orbitMode is not null)
      {
        <Chip Active="orbitOn"
                Title="Mirror drawn regions across the map's confirmed symmetry"
                OnClick="ToggleOrbit">@OrbitLabel()</Chip>
      }
      @* Blocks overlay is a mode-independent visual aid (renders below the regions/markers); offered on every
         canvas so placement can be lined up against the real terrain. No-op when the map has no scan data. *@
      <Chip Active="blocksOn" Title="Overlay the top-surface block colours"
              OnClick="ToggleBlocks">Blocks</Chip>
      @if (ShowBuildable)
      {
        <Chip Active="buildableOn"
                Title="Overlay the per-column buildability verdict (green buildable · orange void-denied · red never · yellow restricted)"
                OnClick="ToggleBuildability">Buildable</Chip>
      }
      @if (islandIds.Count > 0)
      {
        <select class="field-input canvas-island-select" title="Zoom to fit an island" value="@islandSel" @onchange="OnFitIslandSelect">
          <option value="">Fit island…</option>
          @foreach (var id in islandIds)
          {
            <option value="@id">Island @id</option>
          }
        </select>
      }
      <Chip Title="Reset zoom (fit whole map)" OnClick="OnResetClick"><i data-lucide="scan"></i></Chip>
      <span @ref="zoomRef" class="canvas-zoom">—</span>
    </div>
  </div>
  <div @ref="wrapRef" class="svg-area">
    <svg @ref="svgRef" class="map-canvas-svg" xmlns="http://www.w3.org/2000/svg"></svg>
  </div>
</div>
