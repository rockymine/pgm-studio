@namespace PgmStudio.Client.Pages.EditorActivities
@inject HttpClient Http
@inject IJSRuntime JS

@* Build Regions activity — Step 1: max build height with a side-view canvas (drag the line, or type
   a value) + an X/Z axis toggle; Step 2: build-area region tree + canvas + inspector (delete/rename).
   Port of build-regions-activity.js (C7 side-view via studio.mountSideview / SideviewCanvas). *@

<div class="workspace">
  <div class="workspace-sidebar">
    <div class="workspace-scroll">
      @if (step == 1)
      {
        <section class="panel-section">
          <div class="section-header section-header--ruled">
            <h2 class="section-title">Maximum Build Height</h2>
            <span class="badge badge--dim">Step 1</span>
          </div>
          <p class="section-desc">Maximum Y level above which no block placement is permitted. Leave blank to enforce no vertical ceiling.</p>
          <div class="field">
            <label class="field-label">Blocks</label>
            <input class="field-input" type="number" min="0" max="255" step="1" placeholder="None"
                   value="@maxHeight" @onchange="OnHeightInput" />
          </div>
          <div class="panel-actions">
            <button class="action-btn action-btn--primary" disabled="@(!heightDirty)" @onclick="SaveHeight">Save</button>
            <span class="panel-save-status">@heightStatus</span>
          </div>
        </section>
      }
      else
      {
        <section class="panel-section">
          <div class="section-header section-header--ruled">
            <h2 class="section-title">Build Region</h2>
            <span class="badge badge--dim">Step 2</span>
          </div>
          @if (groups is null) { <div class="list-empty">Loading…</div> }
          else { <RegionTree Groups="groups" SelectedId="selRegion" SelectedSet="selSet" OnSelect="OnTreeSelect" /> }
        </section>
      }
    </div>
    <div class="cfg-sidebar-nav">
      @if (step == 2) { <button class="action-btn" @onclick="() => step = 1"><i data-lucide="arrow-left"></i> Back</button> }
      @if (step == 1) { <button class="action-btn action-btn--primary action-btn--push-end" @onclick="GoStep2">Next <i data-lucide="arrow-right"></i></button> }
    </div>
  </div>

  <div class="sidebar-handle"></div>

  @if (step == 1)
  {
    <div class="workspace-canvas">
      <div class="canvas-subbar">
        <div class="canvas-toolbar">
          <button class="draw-tool-btn @(axis == "z" ? "draw-tool-btn--active" : null)" title="Look along Z"
                  @onclick='() => SetAxis("z")'>Z</button>
          <button class="draw-tool-btn @(axis == "x" ? "draw-tool-btn--active" : null)" title="Look along X"
                  @onclick='() => SetAxis("x")'>X</button>
        </div>
        <div class="canvas-subbar-right"><span class="canvas-hint">Drag the line to set the build height</span></div>
      </div>
      <div class="svg-area"><canvas @ref="sideviewRef" class="sideview-canvas"></canvas></div>
    </div>
  }
  else
  {
    <EditorCanvas @ref="canvas" Slug="@Slug" Category="build" DrawCategory="build" DraftStep="build" OnSelect="OnCanvasSelect" OnRegionCreated="ReloadBuild" />
    <div class="sidebar-handle"></div>
    <div class="workspace-inspector">
      <div class="workspace-scroll">
        <div class="panel-section">
          <RegionInspector Node="RegionNodeSel" OnSelectChild="Select" OnDelete="DeleteRegion" OnRename="RenameRegion" />
        </div>
      </div>
    </div>
  }
</div>

<Toast Message="@error" />
