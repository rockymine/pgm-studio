@namespace PgmStudio.Client.Pages.EditorActivities
@inject IJSRuntime JS

@* Region geo-tree sidebar — recursive category tree with collapse, type icons, and primary/
   descendant selection highlight. Port of panels/regions-panel.js + region/region-tree.js. *@

<div class="region-tree">
  @if (Groups is null || !Groups.Any(g => g.Regions.Count > 0))
  {
    <div class="panel-empty-msg">No named regions found.</div>
  }
  else
  {
    @foreach (var row in BuildRows())
    {
      @switch (row.Kind)
      {
        case "header":
          <div class="cat-header">@row.Text</div>
          break;
        case "divider":
          <div class="cat-divider"></div>
          break;
        default:
          var n = row.Node!;
          <div class="geo-row @SelClass(n.Id)" @onclick="() => OnSelect.InvokeAsync(n)">
            <span class="geo-indent">
              @for (var d = 0; d < row.Depth; d++)
              {
                <span class="indent-pipe"></span>
              }
              @if (n.HasKids)
              {
                <button class="collapse-btn" @onclick="() => Toggle(n.Id)" @onclick:stopPropagation="true">
                  <i data-lucide="@(collapsed.Contains(n.Id) ? "chevron-right" : "chevron-down")"></i>
                </button>
              }
            </span>
            <span class="geo-type-icon"><i data-lucide="@RegionNode.Icon(n.Type)"></i></span>
            <span class="geo-label @(n.Synthetic ? "geo-label--synthetic" : null)" title="@n.Label">
              @(string.IsNullOrEmpty(n.Label) ? $"({n.Type})" : n.Label)
            </span>
            @if (row.ParentType == "complement" && row.Index == 0)
            {
              <span class="complement-base-tag">base</span>
            }
            @* the first filter event wired to this region ("enter", "block-break", …) — surfaces the rule
               in use at a glance (unwired regions like monuments/spawners show nothing). Good R1 prep. *@
            @if (n.FirstEvent is { } ev)
            {
              <span class="list-tag">@ev</span>
            }
          </div>
          break;
      }
    }
  }
</div>
