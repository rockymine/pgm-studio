@namespace PgmStudio.Client.Pages.EditorActivities
@inject HttpClient Http
@inject IJSRuntime JS

@* Teams activity — teams (list/add/inspector CRUD) + spawn regions (list + assignment) on a
   spawn-filtered canvas. Port of teams-activity.js + teams-panel.js. Region drawing is deferred. *@

<Workspace>
  <Sidebar>
      <Section Title="Teams">
        <Actions>
          <Button OnClick="AddTeam">+ Add Team</Button>
        </Actions>
        <ChildContent>
          <div class="panel-list">
            @if (teams.Count == 0)
            {
              @if (symMode is not null && !suggestionDismissed)
              {
                <SmartSuggestion Header="Smart Suggestion" Badge="@SymBadge()" AcceptLabel="@AcceptLabel()"
                                 Busy="suggestionBusy" OnAccept="AcceptSuggestion" OnReject="RejectSuggestion">
                  <p class="smart-suggestion__text">@SuggestionText()</p>
                  <div class="smart-suggestion-teams">
                    @foreach (var s in SuggestedTeams())
                    {
                      <div class="smart-suggestion-team">
                        <span class="list-swatch list-swatch--sm" style="background-color:@GameColors.ChatHex(s.Color)"></span>@s.Name
                      </div>
                    }
                  </div>
                </SmartSuggestion>
              }
              else { <div class="list-empty">No teams.</div> }
            }
            @foreach (var t in teams)
            {
              <ListRow Compact Selected="selTeam == t.Id" OnClick="() => SelectTeam(t.Id)">
                <span class="list-swatch" style="background-color:@GameColors.ChatHex(t.Color)"></span>
                <span class="list-label list-label--mono">@t.Id</span>
                <span class="list-tag">@t.Name</span>
              </ListRow>
            }
          </div>
        </ChildContent>
      </Section>

      <Section Title="Spawn Points">
        <div class="panel-list geo-icons-flush">
          @if (!SpawnPoints.Any()) { <div class="list-empty">No spawn points.</div> }
          @foreach (var r in SpawnPoints)
          {
            var sp = SpawnFor(r.Id);
            var spTeam = sp is null ? null : teams.FirstOrDefault(t => t.Id == sp.Team);
            <ListRow Compact Selected="selSpawn == r.Id" OnClick="() => SelectSpawn(r.Id)">
              <span class="geo-type-icon" style="color:@(spTeam is null ? "var(--text-muted)" : GameColors.ChatHex(spTeam.Color))"><i data-lucide="@RegionNode.Icon(r.Type)"></i></span>
              <span class="list-label list-label--mono">@r.Id</span>
              <span class="list-tag">@(spTeam?.Name ?? "—")</span>
            </ListRow>
          }
        </div>
      </Section>

      <Section Title="Spawn Protection">
        <div class="panel-list geo-icons-flush">
          @if (!SpawnProtection.Any()) { <div class="list-empty">No protection regions.</div> }
          @foreach (var r in SpawnProtection)
          {
            <ListRow Compact Selected="selSpawn == r.Id" OnClick="() => SelectSpawn(r.Id)">
              <span class="geo-type-icon"><i data-lucide="@RegionNode.Icon(r.Type)"></i></span>
              <span class="list-label list-label--mono">@r.Id</span>
              <span class="list-tag">@(r.FirstEvent ?? "")</span>
            </ListRow>
          }
        </div>
      </Section>

      @if (draftRegions.Count > 0)
      {
        <Section Title="Draft">
          <div class="panel-list geo-icons-flush">
            @foreach (var r in draftRegions)
            {
              <ListRow Compact Selected="selSpawn == r.Id" OnClick="() => SelectSpawn(r.Id)">
                <span class="geo-type-icon"><i data-lucide="@RegionNode.Icon(r.Type)"></i></span>
                <span class="list-label list-label--mono">@r.Id</span>
                <span class="list-tag">unwired</span>
              </ListRow>
            }
          </div>
        </Section>
      }
  </Sidebar>

  <div class="sidebar-handle"></div>

  <EditorCanvas @ref="canvas" Slug="@Slug" Category="spawn" DrawCategory="spawn" DraftStep="teams" OnSelect="OnCanvasSelect" OnRegionCreated="Reload" OnGeometrySaved="OnGeometrySaved" />

  <div class="sidebar-handle"></div>

  <Inspector>
      <Section>
        @if (selTeam is not null && CurrentTeam is { } team)
        {
          <div class="section-header section-header--ruled"><h2 class="section-title">Team</h2></div>
          <Field Label="ID" Required>
            <input class="field-input" type="text" spellcheck="false" value="@team.Id" @onchange="e => RenameTeam(team, e.Value?.ToString())" />
          </Field>
          <Field Label="Display Name">
            <input class="field-input" type="text" value="@team.Name" @onchange="async e => { team.Name = e.Value?.ToString() ?? string.Empty; await SaveTeam(team); }" />
          </Field>
          <Field Label="Chat Color" Required>
            <div class="field-pick-row">
              <span class="field-swatch" style="background-color:@GameColors.ChatHex(team.Color)"></span>
              <select class="field-input" value="@team.Color" @onchange="async e => { team.Color = e.Value?.ToString() ?? string.Empty; await SaveTeam(team); }">
                @foreach (var c in GameColors.ChatColors) { <option value="@c.Value">@c.Label</option> }
              </select>
            </div>
          </Field>
          <Field Label="Dye Color">
            <div class="field-pick-row">
              <span class="field-swatch" style="background-color:@GameColors.DyeHex(team.DyeColor)"></span>
              <select class="field-input" value="@(team.DyeColor ?? "")" @onchange="async e => { team.DyeColor = e.Value?.ToString(); await SaveTeam(team); }">
                <option value="">None</option>
                @foreach (var c in GameColors.DyeColors) { <option value="@c.Value">@c.Label</option> }
              </select>
            </div>
          </Field>
          <div class="field-row">
            <Field Label="Max Players">
              <NumberField Value="team.MaxPlayers" ValueChanged="async v => { team.MaxPlayers = (int)v; await SaveTeam(team); }" Min="1" Max="500" />
            </Field>
            <Field Label="Min Players">
              <NumberField Value="team.MinPlayers" ValueChanged="async v => { team.MinPlayers = (int)v; await SaveTeam(team); }" Min="0" Max="500" />
            </Field>
          </div>
          <div class="panel-actions">
            <Button Variant="danger" OnClick="() => DeleteTeam(team)">Delete team</Button>
          </div>
        }
        else if (selSpawn is not null)
        {
          <RegionInspector Node="SpawnNode" Slug="@Slug" OnSetCoord="OnSetCoord" />
          <Section Title="Spawn Assignment">
            <Field Label="Team">
              <select class="field-input" value="@spawnTeam" @onchange="async e => { spawnTeam = e.Value?.ToString() ?? string.Empty; await SaveSpawn(); }">
                <option value="">— Unassigned —</option>
                <option value="__observer__">Observer</option>
                @foreach (var t in teams) { <option value="@t.Id">@(string.IsNullOrEmpty(t.Name) ? t.Id : t.Name)</option> }
              </select>
            </Field>
            <Field Label="Yaw (°)">
              <NumberField Value="spawnYaw" ValueChanged="async v => { spawnYaw = v; await SaveSpawn(); }" Min="-180" Max="180" />
            </Field>
            <Field Label="Kit">
              <input class="field-input" type="text" spellcheck="false" value="@spawnKit" @onchange="async e => { spawnKit = e.Value?.ToString() ?? string.Empty; await SaveSpawn(); }" />
            </Field>
            <div class="panel-actions">
              <Button Variant="danger" Fill OnClick="UnlinkSpawn">Remove Spawn Link</Button>
            </div>
          </Section>
        }
        else
        {
          <p class="panel-empty-msg">Select a team or spawn region to inspect.</p>
        }
      </Section>
  </Inspector>
</Workspace>

<Toast Message="@error" />
