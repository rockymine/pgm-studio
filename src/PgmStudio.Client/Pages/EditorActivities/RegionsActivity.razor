@namespace PgmStudio.Client.Pages.EditorActivities
@inject HttpClient Http

@* Regions activity (read-only registry audit): geo-tree sidebar + hybrid canvas + region inspector,
   with single-primary selection that also highlights descendants. Port of regions-activity.js. *@

<div class="workspace">
  <div class="workspace-sidebar">
    <div class="workspace-scroll">
      <section class="panel-section">
        <div class="section-header section-header--ruled"><h2 class="section-title">Regions</h2></div>
        @if (groups is null) { <div class="list-empty">Loading…</div> }
        else { <RegionTree Groups="groups" SelectedId="selectedId" SelectedSet="selectedSet" OnSelect="OnTreeSelect" /> }
      </section>
    </div>
  </div>

  <div class="sidebar-handle"></div>

  <EditorCanvas @ref="canvas" Slug="@Slug" OnSelect="OnCanvasSelect" />

  <div class="sidebar-handle"></div>

  <div class="workspace-inspector">
    <div class="workspace-scroll">
      <div class="panel-section">
        <RegionInspector Node="selectedNode" OnSelectChild="Select" />
      </div>
    </div>
  </div>
</div>
