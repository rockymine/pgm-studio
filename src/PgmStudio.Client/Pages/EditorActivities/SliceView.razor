@namespace PgmStudio.Client.Pages.EditorActivities
@inject IJSRuntime JS
@implements IAsyncDisposable

@* Mini side-view slice for the inspector: a localised vertical cross-section of the map at the
   selected region. Point/block → a draggable Y line sets the region's Y; rectangle → display only.
   X/Z buttons switch the look axis (mirrors the Build-Regions side-view). *@

@if (show)
{
  <div class="field">
    <div class="slice-head">
      <label class="field-label">@(editable ? "Side view — drag the line to set Y" : "Side view")</label>
      <div class="slice-axis">
        <button class="draw-tool-btn @(axis == "nz" ? "draw-tool-btn--active" : null)" title="Inspect from −Z" @onclick='() => SetAxis("nz")'>Z−</button>
        <button class="draw-tool-btn @(axis == "pz" ? "draw-tool-btn--active" : null)" title="Inspect from +Z" @onclick='() => SetAxis("pz")'>Z+</button>
        <button class="draw-tool-btn @(axis == "nx" ? "draw-tool-btn--active" : null)" title="Inspect from −X" @onclick='() => SetAxis("nx")'>X−</button>
        <button class="draw-tool-btn @(axis == "px" ? "draw-tool-btn--active" : null)" title="Inspect from +X" @onclick='() => SetAxis("px")'>X+</button>
      </div>
    </div>
    <div class="slice-view"><canvas @ref="canvasRef" class="slice-canvas"></canvas></div>
  </div>
}
