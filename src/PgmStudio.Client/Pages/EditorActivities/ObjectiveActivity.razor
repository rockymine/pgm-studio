@namespace PgmStudio.Client.Pages.EditorActivities
@inject HttpClient Http
@inject IJSRuntime JS

@* Objective activity — wools (list/add/inspector with location + monuments) + wool-region tree on a
   wool-filtered canvas. Port of objectives-activity.js + objectives-panel.js. Drawing is deferred. *@

<div class="workspace">
  <div class="workspace-sidebar">
    <div class="workspace-scroll">
      <section class="panel-section">
        <div class="section-header section-header--ruled">
          <h2 class="section-title">Wools</h2>
          <button class="action-btn" disabled="@(NextWoolColor() is null)" @onclick="AddWool">+ Add</button>
        </div>
        <div class="panel-list">
          @if (wools.Count == 0) { <div class="list-empty">No wools.</div> }
          @foreach (var w in wools)
          {
            <div class="list-row list-row--compact @(selWool == w.Id ? "list-row--selected" : null)" @onclick="() => SelectWool(w.Id)">
              <span class="list-swatch" style="background-color:@GameColors.DyeHex(w.Color)"></span>
              <span class="list-label">@DyeLabel(w.Color)</span>
            </div>
          }
        </div>
      </section>

      <section class="panel-section">
        <div class="section-header section-header--ruled"><h2 class="section-title">Wool Regions</h2></div>
        @if (groups is null) { <div class="list-empty">Loading…</div> }
        else { <RegionTree Groups="groups" SelectedId="selRegion" SelectedSet="selRegionSet" OnSelect="OnTreeSelect" /> }
      </section>
    </div>
  </div>

  <div class="sidebar-handle"></div>

  <EditorCanvas @ref="canvas" Slug="@Slug" Category="wool" DrawCategory="wool" OnSelect="OnCanvasSelect" OnRegionCreated="Reload" />

  <div class="sidebar-handle"></div>

  <div class="workspace-inspector">
    <div class="workspace-scroll">
      <div class="panel-section">
        @if (selWool is not null && CurrentWool is { } wool)
        {
          <div class="section-header section-header--ruled">
            <div class="section-heading">
              <span class="list-swatch" style="background-color:@GameColors.DyeHex(wool.Color)"></span>
              <h2 class="section-title">@DyeLabel(wool.Color) Wool</h2>
            </div>
          </div>
          <div class="field">
            <label class="field-label">Color</label>
            <select class="field-input" value="@wool.Color" @onchange="SaveWoolColor">
              @foreach (var c in AvailableColors(wool)) { <option value="@c.Value">@c.Label</option> }
            </select>
          </div>
          <div class="field">
            <label class="field-label">Owning Team</label>
            <div class="field-pick-row">
              <span class="field-swatch" style="background:@TeamColor(wool.Team)"></span>
              <select class="field-input" value="@(wool.Team ?? "")" @onchange="SaveWoolTeam">
                <option value="">— none —</option>
                @foreach (var t in teams) { <option value="@t.Id">@(string.IsNullOrEmpty(t.Name) ? t.Id : t.Name)</option> }
              </select>
            </div>
          </div>
          <div class="field">
            <label class="field-label">Block Position</label>
            <div class="ctrl-row">
              <div class="coord-field"><span class="coord-prefix">X</span><input class="coord-input" type="number" value="@wLocX" @onchange="e => wLocX = e.Value?.ToString()" @onblur="SaveWoolLocation" /></div>
              <div class="coord-field"><span class="coord-prefix">Y</span><input class="coord-input" type="number" value="@wLocY" @onchange="e => wLocY = e.Value?.ToString()" @onblur="SaveWoolLocation" /></div>
              <div class="coord-field"><span class="coord-prefix">Z</span><input class="coord-input" type="number" value="@wLocZ" @onchange="e => wLocZ = e.Value?.ToString()" @onblur="SaveWoolLocation" /></div>
            </div>
          </div>
          <div class="field">
            <label class="field-label">Wool Room Region</label>
            <input class="field-input" type="text" spellcheck="false" placeholder="region-id" value="@(wool.WoolRoomRegion ?? "")"
                   @onchange="SaveWoolRoom" />
          </div>
          <div class="section-footer section-footer--separated">
            <button class="action-btn action-btn--danger action-btn--fill" @onclick="() => DeleteWool(wool)">Delete Wool</button>
          </div>

          @* Monuments *@
          <section class="panel-section">
            <div class="section-header section-header--ruled">
              <h2 class="section-title">Monuments</h2>
              <button class="action-btn" disabled="@(NextMonumentTeam(wool) is null)" @onclick="() => AddMonument(wool)">+ Add</button>
            </div>
            @if (wool.Monuments.Count > 0)
            {
              <div class="filter-group-options filter-group-options--mt">
                @foreach (var m in wool.Monuments)
                {
                  var mt = teams.FirstOrDefault(t => t.Id == m.Team);
                  <button class="filter-chip @(m.Id == selMon ? "filter-chip--active" : null)"
                          style="@(mt is null ? null : $"color:{GameColors.ChatHex(mt.Color)}")" @onclick="() => SelectMonument(m.Id)">
                    @(mt?.Name ?? m.Team ?? "?")
                  </button>
                }
              </div>
            }
            @if (wool.Monuments.FirstOrDefault(m => m.Id == selMon) is { } mon)
            {
              <div class="section-body">
                <div class="field">
                  <label class="field-label">Team</label>
                  <div class="field-pick-row">
                    <span class="field-swatch" style="background:@TeamColor(mon.Team)"></span>
                    <select class="field-input" value="@(mon.Team ?? "")" @onchange="SaveMonTeam">
                      <option value="">— none —</option>
                      @foreach (var t in teams) { <option value="@t.Id">@(string.IsNullOrEmpty(t.Name) ? t.Id : t.Name)</option> }
                    </select>
                  </div>
                </div>
                <div class="field">
                  <label class="field-label">Block Position</label>
                  <div class="ctrl-row">
                    <div class="coord-field"><span class="coord-prefix">X</span><input class="coord-input" type="number" value="@mLocX" @onchange="e => mLocX = e.Value?.ToString()" @onblur="() => SaveMonumentLocation(wool, mon)" /></div>
                    <div class="coord-field"><span class="coord-prefix">Y</span><input class="coord-input" type="number" value="@mLocY" @onchange="e => mLocY = e.Value?.ToString()" @onblur="() => SaveMonumentLocation(wool, mon)" /></div>
                    <div class="coord-field"><span class="coord-prefix">Z</span><input class="coord-input" type="number" value="@mLocZ" @onchange="e => mLocZ = e.Value?.ToString()" @onblur="() => SaveMonumentLocation(wool, mon)" /></div>
                  </div>
                </div>
                <div class="field">
                  <label class="field-label">Monument Region</label>
                  <input class="field-input" type="text" spellcheck="false" placeholder="region-id (optional)" value="@(mon.MonumentRegion ?? "")"
                         @onchange="SaveMonRegion" />
                </div>
              </div>
              <div class="section-footer section-footer--separated">
                <button class="action-btn action-btn--danger action-btn--fill" @onclick="() => DeleteMonument(wool, mon)">Delete Monument</button>
              </div>
            }
          </section>
        }
        else if (selRegion is not null)
        {
          <RegionInspector Node="RegionNodeSel" OnSelectChild="Select" />
        }
        else
        {
          <p class="panel-empty-msg">Select a wool or region to inspect.</p>
        }
      </div>
    </div>
  </div>
</div>

@if (error is not null) { <div class="toast toast--error">@error</div> }
