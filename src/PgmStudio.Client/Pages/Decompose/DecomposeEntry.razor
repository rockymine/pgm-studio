@page "/decompose"
@layout EditorLayout
@inject HttpClient Http
@inject NavigationManager Nav

@* Dashboard entry for lane decomposition — jumps straight to the first two-team CTW map still to do
   (or back to the dashboard once the queue is drained). *@

<div class="editor-page">
  <div class="topbar"><span class="topbar-crumb">Decompose</span><div class="topbar-right"><ThemeToggle /></div></div>
  <div class="app-body">
    <div class="activity-viewport">
      <div class="workspace">
        <div class="workspace-scroll landing">
          <p class="landing-lead">@status</p>
        </div>
      </div>
    </div>
  </div>
</div>

@code {
    private string status = "Finding the next map to decompose…";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var q = await Http.GetFromJsonAsync<System.Text.Json.JsonElement>("api/decompose/queue");
            var todo = q.GetProperty("todo");
            if (todo.GetArrayLength() > 0)
                Nav.NavigateTo($"maps/{todo[0].GetProperty("slug").GetString()}/decompose");
            else
                status = "All two-team CTW maps are decomposed. 🎉";
        }
        catch { status = "Couldn't load the decomposition queue."; }
    }
}
