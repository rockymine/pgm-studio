@page "/maps/{Slug}/decompose"
@layout EditorLayout
@inject IJSRuntime JS
@inject HttpClient Http
@inject NavigationManager Nav
@implements IAsyncDisposable

@* Lane-decomposition surface — the human cuts a map's simplified island outline into lanes (lasso → pick
   two seam points → split), tags each piece's role, and confirms to the next map. Only one side of a
   symmetric map is shown (the rest is the mirror). Canvas = bridge/decompose-bridge.js, with the shared
   editor canvas chrome (toolbar · focus · zoom). The original outline is kept; cuts save to
   lane_decomposition_json. *@

<div class="editor-page">
  <div id="topbar" class="topbar">
    <a href="maps" class="topbar-breadcrumb-home" title="Back to dashboard">
      <i data-lucide="house"></i><span>Studio</span>
    </a>
    <span class="topbar-sep">›</span>
    <span class="topbar-crumb">@Slug.Replace('_', ' ')</span>
    <span class="topbar-sep">›</span>
    <span class="topbar-crumb topbar-crumb--dim">Decompose</span>
    <div class="topbar-right">
      <button class="action-btn" title="Previous map in the queue" @onclick="GoPrev" disabled="@(!CanPrev)"><i data-lucide="chevron-left"></i></button>
      <span class="topbar-crumb topbar-crumb--dim">@progressLabel</span>
      <button class="action-btn" title="Skip to the next map (without saving)" @onclick="GoNext" disabled="@(!CanNext)"><i data-lucide="chevron-right"></i></button>
      <button class="action-btn" title="Undo last cut" @onclick="Undo"><i data-lucide="undo-2"></i></button>
      @if (resetArmed)
      {
        <button class="action-btn action-btn--danger" title="Discard all cuts and start this map over" @onclick="Reset">Confirm reset</button>
      }
      else
      {
        <button class="action-btn" title="Discard this map's decomposition and re-cut from scratch" @onclick="() => resetArmed = true"><i data-lucide="rotate-ccw"></i></button>
      }
      <button class="action-btn action-btn--primary" @onclick="ConfirmNext" disabled="@saving"
              title="Save these lanes and move to the next map">Confirm &amp; Next</button>
      <ThemeToggle />
    </div>
  </div>

  <div id="main" class="app-body">
    <div class="activity-viewport">
      <div class="workspace">
        <div class="workspace-sidebar">
          <div class="workspace-scroll">
            <section class="panel-section">
              <div class="section-header section-header--ruled"><h2 class="section-title">How to cut</h2></div>
              <p class="field-help">Lasso a lane region, then click <strong>two</strong> seam points (existing
                corners or lasso-edge markers). The piece splits into the lane + the remainder; keep peeling.
                Only one team's island set is shown — the rest is its mirror.</p>
            </section>
            <section class="panel-section">
              <div class="section-header section-header--ruled"><h2 class="section-title">Pieces (@pieces.Count)</h2></div>
              @if (pieces.Count == 0) { <p class="field-help">Loading the island outline…</p> }
              @foreach (var p in pieces)
              {
                <div class="list-row list-row--compact @(selectedId == p.Id ? "list-row--selected" : null)"
                     @key="p.Id" @onclick="() => SelectPiece(p.Id)">
                  <span class="list-swatch" style="background:@RoleColor(p.Role)"></span>
                  <span class="list-label list-label--mono">@p.Id</span>
                  <span class="badge badge--dim">@p.Role</span>
                </div>
              }
            </section>
          </div>
        </div>
        <div class="sidebar-handle"></div>
        <div class="workspace-canvas">
          <div class="canvas-subbar">
            <div class="canvas-toolbar">
              <button class="draw-tool-btn @(tool == "lasso" ? "draw-tool-btn--active" : null)"
                      title="Lasso a lane, then click two seam points" @onclick='() => SetTool("lasso")'><i data-lucide="lasso"></i></button>
              <button class="draw-tool-btn @(tool == "select" ? "draw-tool-btn--active" : null)"
                      title="Select a piece to categorize it" @onclick='() => SetTool("select")'><i data-lucide="mouse-pointer-2"></i></button>
              <button class="draw-tool-btn @(tool == "pan" ? "draw-tool-btn--active" : null)"
                      title="Move / pan" @onclick='() => SetTool("pan")'><i data-lucide="hand"></i></button>
            </div>
            <div @ref="coordsRef" class="canvas-cursor"></div>
            <div class="canvas-subbar-right">
              <button class="filter-chip @(blocksOn ? "filter-chip--active" : null)"
                      title="Overlay the top-surface block colours" @onclick="ToggleBlocks">Blocks</button>
              <button class="filter-chip @(anchorsOn ? "filter-chip--active" : null)"
                      title="Mark the wool tips + spawn spurs (objective anchors)" @onclick="ToggleAnchors">Anchors</button>
              <button class="filter-chip @(buildOn ? "filter-chip--active" : null)"
                      title="Outline the declared buildable area" @onclick="ToggleBuild">Build</button>
              <select class="field-input canvas-island-select" title="Zoom to fit a piece" value="@focusSel" @onchange="OnFocusPiece">
                <option value="">Focus piece…</option>
                @foreach (var p in pieces)
                {
                  <option value="@p.Id">@p.Id (@p.Role)</option>
                }
              </select>
              <button class="filter-chip" title="Zoom out" @onclick="ZoomOut"><i data-lucide="minus"></i></button>
              <button class="filter-chip" title="Zoom in" @onclick="ZoomIn"><i data-lucide="plus"></i></button>
              <button class="filter-chip" title="Fit the island set" @onclick="Fit"><i data-lucide="scan"></i></button>
              <span @ref="zoomRef" class="canvas-zoom">—</span>
            </div>
          </div>
          <div @ref="wrapRef" class="svg-area">
            <svg @ref="svgRef" class="map-canvas-svg" xmlns="http://www.w3.org/2000/svg"></svg>
          </div>
        </div>
        <div class="sidebar-handle"></div>
        <div class="workspace-inspector">
          <div class="workspace-scroll">
            @if (Selected is { } sel)
            {
              <section class="panel-section">
                <div class="detail-header">
                  <span class="list-swatch" style="background:@RoleColor(sel.Role)"></span>
                  <span class="detail-label detail-label--mono">@sel.Id</span>
                  <span class="badge badge--dim">@sel.Vertices v@(sel.Holes > 0 ? $" · {sel.Holes} hole(s)" : "")</span>
                </div>
                <div class="section-body">
                  <div class="field">
                    <label class="field-label">Lane role</label>
                    <div class="filter-group-options filter-group-options--fill">
                      @foreach (var r in LaneRoles)
                      {
                        <button class="filter-chip @(sel.Role == r ? "filter-chip--active" : null)" @onclick="() => SetRole(sel.Id, r)">@r</button>
                      }
                    </div>
                  </div>
                  <div class="field">
                    <label class="field-label">Whole island</label>
                    <div class="filter-group-options filter-group-options--fill">
                      @foreach (var r in IslandRoles)
                      {
                        <button class="filter-chip @(sel.Role == r ? "filter-chip--active" : null)" @onclick="() => SetRole(sel.Id, r)">@r</button>
                      }
                    </div>
                  </div>
                  <p class="section-desc">Tag a cut lane (spawn / wool / frontline / hub) or a whole island
                    (stepping-stone / mid for a neutral mid, decorative to exclude it). Non-team islands are
                    pre-tagged from detection — just confirm.</p>
                </div>
              </section>
            }
            else
            {
              <section class="panel-section">
                <div class="section-header section-header--ruled"><h2 class="section-title">Categorize</h2></div>
                <p class="field-help">Pick the <strong>select</strong> tool and click a piece (or a row on the
                  left) to set its category from here.</p>
              </section>
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
