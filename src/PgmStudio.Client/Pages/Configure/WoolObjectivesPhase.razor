@namespace PgmStudio.Client.Pages.Configure
@using PgmStudio.Client.Models
@using PgmStudio.Client.Pages.EditorActivities
@using W = PgmStudio.Client.Pages.Configure.WoolAuthoring

@* Wools · objectives: the world scan names the objectives (signed monuments) and their owners (island of
   the source / complement of the capturing team); physical wool that no monument names is decorative and
   excluded by default. The author confirms/rejects, fixes an owner, or adds a missing wool. *@

<Workspace>

  <Sidebar>
      <Section Title="Objective wools">
        <Actions><span class="badge @(Included > 0 ? "badge--success" : "badge--dim")">@Included objective@(Included == 1 ? "" : "s")</span></Actions>
        <ChildContent>
        <p class="section-desc">Detected from the world — signed monuments name each objective, the island
          gives its owner. <strong>Toggle</strong> a row to include/exclude; physical wool no monument names
          is excluded as decorative. Select a wool to fix its owner.</p>
        @if (loading)
        {
          <div class="list-empty">Scanning the world…</div>
        }
        else
        {
          <div class="panel-list">
            @if (candidates.Count == 0) { <div class="list-empty">No wool found in the world — add one below.</div> }
            @foreach (var c in candidates)
            {
              <div class="list-row list-row--compact @(selectedColor == c.Color ? "list-row--selected" : null) @(c.Included ? null : "list-row--muted")"
                   @key="c.Color" @onclick="() => Select(c)">
                <span class="list-swatch" style="background:@W.Hex(c.Color)"></span>
                <span class="list-label list-label--mono">@c.Color</span>
                @if (c.Included)
                {
                  <span class="badge" style="background:@(string.IsNullOrEmpty(c.Owner) ? "transparent" : W.Hex(TeamColorOf(c.Owner)));color:#fff">@(string.IsNullOrEmpty(c.Owner) ? "no owner" : TeamName(c.Owner))</span>
                }
                else
                {
                  <span class="badge badge--dim" title="@c.ExcludeReason">excluded</span>
                }
              </div>
            }
          </div>
          <button class="action-btn action-btn--full action-btn--separated" @onclick="AddMissing"><i data-lucide="plus"></i> Add a wool</button>
        }
        </ChildContent>
      </Section>
  </Sidebar>

  <div class="sidebar-handle"></div>

  <EditorCanvas @ref="canvas" Slug="@Slug" Category="__wool_objectives__"
                OnSelect="OnCanvasSelect" OnReady="OnCanvasReady" />

  <div class="sidebar-handle"></div>

  <Inspector>
      @if (Selected is { } sel)
      {
        <Section @key="sel.Color">
          <div class="detail-header">
            <span class="geo-type-icon" style="color:@W.Hex(sel.Color)"><i data-lucide="@(sel.Signed ? "sparkles" : "square")"></i></span>
            <span class="detail-label detail-label--mono">@sel.Color</span>
            <span class="badge @(sel.Included ? "badge--success" : "badge--dim")">@(sel.Included ? "objective" : "excluded")</span>
          </div>
          <div class="section-body">
            <div class="field">
              <label class="field-label">Colour</label>
              <div class="field-pick-row">
                <span class="field-swatch" style="background:@W.Hex(sel.Color)"></span>
                <select class="field-input" @onchange="@(e => SetColor(sel, e.Value?.ToString() ?? sel.Color))">
                  @foreach (var d in GameColors.DyeColors)
                  {
                    <option value="@W.NormColor(d.Value)" selected="@(W.NormColor(d.Value) == sel.Color)">@d.Label</option>
                  }
                </select>
              </div>
            </div>
            <div class="field">
              <label class="field-label">Owning team <span class="text-muted text-sm">(defends it)</span></label>
              <div class="field-pick-row">
                <span class="field-swatch" style="background:@(string.IsNullOrEmpty(sel.Owner) ? "transparent" : W.Hex(TeamColorOf(sel.Owner)))"></span>
                <select class="field-input" @onchange="@(e => SetOwner(sel, e.Value?.ToString() ?? string.Empty))">
                  <option value="" selected="@string.IsNullOrEmpty(sel.Owner)">— pick —</option>
                  @foreach (var t in teams)
                  {
                    <option value="@t.Id" selected="@(t.Id == sel.Owner)">@t.Name</option>
                  }
                </select>
              </div>
            </div>

            @if (sel.Signed && !string.IsNullOrEmpty(sel.Evidence))
            {
              <div class="field">
                <label class="field-label">Evidence <span class="text-muted text-sm">· sign</span></label>
                <div class="field-value" style="white-space:pre-line">@sel.Evidence.Replace("\n", " ")</div>
                <div class="meter" style="margin-top:var(--space-1)"><div class="meter-fill" style="width:@((int)(sel.Confidence * 100))%"></div></div>
              </div>
            }

            <div class="field">
              <label class="field-label">Source</label>
              <div class="field-value">
                @if (sel.HasSource) { <text>@sel.Count wool block@(sel.Count == 1 ? "" : "s") · centre @Fmt(sel.X), @Fmt(sel.Y), @Fmt(sel.Z)</text> }
                else { <text>no physical wool — place it in the Spawn step</text> }
              </div>
            </div>
            <div class="field">
              <label class="field-label">Monuments <span class="text-muted text-sm">(captured by)</span></label>
              <div class="field-value">
                @if (sel.Monuments.Count == 0) { <text>none detected — place in the Monuments step</text> }
                else { @string.Join(", ", sel.Monuments.Select(m => string.IsNullOrEmpty(m.Team) ? "?" : TeamName(m.Team))) }
              </div>
            </div>

            <div class="ctrl-row" style="margin-top:var(--space-2)">
              @if (sel.Included)
              {
                <button class="action-btn action-btn--fill" @onclick="() => Toggle(sel)"><i data-lucide="x"></i> Exclude</button>
              }
              else
              {
                <button class="action-btn action-btn--primary action-btn--fill" @onclick="() => Toggle(sel)"><i data-lucide="check"></i> Include@(string.IsNullOrEmpty(sel.ExcludeReason) ? "" : " anyway")</button>
              }
              <button class="action-btn action-btn--fill" @onclick="() => Remove(sel)" title="Remove from the list"><i data-lucide="trash-2"></i></button>
            </div>
            @if (!sel.Included && !string.IsNullOrEmpty(sel.ExcludeReason))
            {
              <p class="section-desc">Excluded — @sel.ExcludeReason.</p>
            }
          </div>
        </Section>
      }
      else
      {
        <Section>
          <div class="detail-header">
            <span class="geo-type-icon detail-icon--muted"><i data-lucide="goal"></i></span>
            <span class="detail-label">Wool</span>
          </div>
          <p class="section-desc">Select a detected wool to confirm it, fix its owner, or exclude it as
            decoration. The included wools become the map's objectives.</p>
        </Section>
      }
  </Inspector>

</Workspace>

@code {
    private string TeamColorOf(string id) => TeamOf(id)?.Color ?? "";
    private static string Fmt(double v) => v.ToString("0.#");
}
