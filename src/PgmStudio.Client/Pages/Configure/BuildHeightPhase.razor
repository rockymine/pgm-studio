@namespace PgmStudio.Client.Pages.Configure
@using PgmStudio.Client.Pages.EditorActivities

@* Build · height step: the max-build-height cap, set with the same side-view as the Edit Build Regions
   step (shared BuildHeightSideview). Writes the build slice's maxHeight; the generator applies it. *@

<div class="workspace">

  <div class="workspace-sidebar">
    <div class="workspace-scroll">
      <section class="panel-section">
        <div class="section-header section-header--ruled"><h2 class="section-title">Maximum Build Height</h2></div>
        <p class="section-desc">The Y level above which no block placement is permitted. Drag the line on
          the side-view, or type a value. Leave blank for no vertical ceiling.</p>
        <div class="field">
          <label class="field-label">Blocks</label>
          <input class="field-input" type="number" min="0" max="255" step="1" placeholder="None"
                 value="@height" @onchange="OnHeightInput" />
        </div>
      </section>
    </div>
  </div>

  <div class="sidebar-handle"></div>

  <BuildHeightSideview Slug="@Slug" Height="@height" HeightChanged="OnSideviewHeight" />

</div>
