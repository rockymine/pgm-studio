@namespace PgmStudio.Client.Pages.Configure
@using PgmStudio.Client.Pages.EditorActivities

@* Build · buildable-layer step: draw the over-void bridges/platforms (areas) and optional no-build holes
   with the rectangle tool. Each is a dummy region on the reused canvas (selectable + resizable). Writes the
   build slice's areas/holes; the generator unions the areas, subtracts the holes, and wires void enforcement. *@

<div class="workspace">

  <div class="workspace-sidebar">
    <div class="workspace-scroll">
      <section class="panel-section">
        <SectionHeader Title="Buildable Layer" />
        <p class="section-desc">With the <strong>rectangle tool</strong>, drag the bridges and platforms over
          the void where players may build — the islands' terrain is already buildable. Add <strong>holes</strong>
          to carve no-build cutouts back out. The <strong>select tool</strong> picks a shape to resize it.</p>
        <div class="field">
          <label class="field-label">Drawing</label>
          <div class="ctrl-row">
            <button class="filter-chip @(drawMode == "area" ? "filter-chip--active" : null)" @onclick='() => drawMode = "area"'>Bridge</button>
            <button class="filter-chip @(drawMode == "hole" ? "filter-chip--active" : null)" @onclick='() => drawMode = "hole"'>Hole</button>
          </div>
        </div>
        <div class="panel-list">
          @if (boxes.Count == 0) { <div class="list-empty">Nothing drawn yet — pick a tool and drag a rectangle.</div> }
          @foreach (var b in boxes)
          {
            <div class="list-row list-row--compact @(selectedId == b.Id ? "list-row--selected" : null)"
                 @key="b.Id" @onclick="() => SelectBox(b.Id)">
              <span class="list-swatch" style="background:@(b.Hole ? HoleColor : AreaColor)"></span>
              <span class="geo-type-icon"><i data-lucide="rectangle-horizontal"></i></span>
              <span class="list-label list-label--mono">@Label(b)</span>
              <span class="badge badge--dim">@(b.Hole ? "hole" : "bridge")</span>
            </div>
          }
        </div>
        @if (MirrorActive && boxes.Count > 0)
        {
          <p class="section-desc">Faint copies on the canvas are the <strong>symmetry mirror</strong> — the
            generator recreates them, so they aren't listed or stored here.</p>
        }
        @if (boxes.Any(x => x.Hole) && !boxes.Any(x => !x.Hole))
        {
          <p class="section-desc">A hole only carves out a bridge — add a bridge for it to apply.</p>
        }
      </section>

      @if (overlayOn)
      {
      <section class="panel-section">
        <SectionHeader Title="Buildability" />
        <p class="section-desc"><strong>Buildable</strong> shades every column by whether players can build
          there:</p>
        <div class="panel-list">
          <div class="list-row list-row--compact"><span class="list-swatch" style="background:#4caf50"></span><span class="list-label">Buildable</span><span class="badge badge--dim">solid ground / bridge</span></div>
          <div class="list-row list-row--compact"><span class="list-swatch" style="background:#f57c00"></span><span class="list-label">Void-denied</span><span class="badge badge--dim">draw a bridge</span></div>
          <div class="list-row list-row--compact"><span class="list-swatch" style="background:#c62828"></span><span class="list-label">Never</span><span class="badge badge--dim">always blocked</span></div>
          <div class="list-row list-row--compact"><span class="list-swatch" style="background:#fbc02d"></span><span class="list-label">Restricted</span><span class="badge badge--dim">limited by a rule</span></div>
        </div>
        <p class="section-desc"><strong>Orange</strong> is open void where building is denied — draw a bridge
          across it to link your islands. <strong>Green</strong> already lets players build (terrain or a
          bridge you drew). It refreshes when you save the step.</p>
      </section>
      }
    </div>
  </div>

  <div class="sidebar-handle"></div>

  @* Reused edit canvas in rectangle-draw mode — draws report to the intent (no region is created); the
     bridges/holes render as dummy regions. Category is non-matching so the generated tree stays hidden. *@
  <EditorCanvas @ref="canvas" Slug="@Slug" RectDraw="true" Category="__build_authoring__" ShowBuildable="true"
                OnBuildableToggled="OnBuildableToggled"
                OnRectDrawn="OnRectDrawn" OnGeometrySaved="OnGeometrySaved" OnSelect="OnCanvasSelect" OnReady="OnCanvasReady" />

  <div class="sidebar-handle"></div>

  <div class="workspace-inspector">
    <div class="workspace-scroll">
      @if (Selected is { } sel)
      {
        <section class="panel-section" @key="sel.Id">
          <div class="detail-header">
            <span class="geo-type-icon detail-icon--muted"><i data-lucide="rectangle-horizontal"></i></span>
            <span class="detail-label detail-label--mono">@Label(sel)</span>
            <span class="badge badge--dim">@(sel.Hole ? "hole" : "bridge")</span>
          </div>
          <div class="section-body">
            <div class="field">
              <label class="field-label">Min</label>
              <div class="ctrl-row">
                <div class="coord-field"><span class="coord-prefix">X</span><input class="coord-input" value="@sel.MinX" readonly tabindex="-1" /></div>
                <div class="coord-field"><span class="coord-prefix">Z</span><input class="coord-input" value="@sel.MinZ" readonly tabindex="-1" /></div>
              </div>
            </div>
            <div class="field">
              <label class="field-label">Max</label>
              <div class="ctrl-row">
                <div class="coord-field"><span class="coord-prefix">X</span><input class="coord-input" value="@sel.MaxX" readonly tabindex="-1" /></div>
                <div class="coord-field"><span class="coord-prefix">Z</span><input class="coord-input" value="@sel.MaxZ" readonly tabindex="-1" /></div>
              </div>
            </div>
            <p class="section-desc">Select it on the canvas and drag the handles to resize.</p>
            <div class="section-footer section-footer--separated">
              <button class="action-btn action-btn--danger action-btn--fill" @onclick="() => Remove(sel.Id)">Remove @(sel.Hole ? "hole" : "bridge")</button>
            </div>
          </div>
        </section>
      }
      else
      {
        <section class="panel-section">
          <div class="detail-header">
            <span class="geo-type-icon detail-icon--muted"><i data-lucide="rectangle-horizontal"></i></span>
            <span class="detail-label">Buildable layer</span>
          </div>
          <p class="section-desc">Draw a bridge or hole, or select one to inspect and resize it.</p>
        </section>
      }
    </div>
  </div>

</div>
