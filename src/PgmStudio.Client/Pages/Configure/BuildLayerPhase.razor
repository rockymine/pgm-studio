@namespace PgmStudio.Client.Pages.Configure

@* Build · buildable-layer step: draw the over-void bridges/platforms (areas) and optional no-build holes
   with the rectangle tool. Each is a dummy region on the reused canvas (selectable + resizable). Writes the
   build slice's areas/holes; the generator unions the areas, subtracts the holes, and wires void enforcement. *@

<Workspace>

  <Sidebar>
      <Section Title="Buildable Layer">
        <p class="section-desc">With the <strong>rectangle tool</strong>, drag the bridges and platforms over
          the void where players may build — the islands' terrain is already buildable. Add <strong>holes</strong>
          to carve no-build cutouts back out. The <strong>select tool</strong> picks a shape to resize it.</p>
        <Field Label="Drawing">
          <div class="ctrl-row">
            <Chip Active='drawMode == "area"' OnClick='() => drawMode = "area"'>Bridge</Chip>
            <Chip Active='drawMode == "hole"' OnClick='() => drawMode = "hole"'>Hole</Chip>
          </div>
        </Field>
        <div class="panel-list">
          @if (boxes.Count == 0) { <div class="list-empty">Nothing drawn yet — pick a tool and drag a rectangle.</div> }
          @foreach (var b in boxes)
          {
            <ListRow Compact Selected="selectedId == b.Id"
                 @key="b.Id" OnClick="() => SelectBox(b.Id)">
              <span class="list-swatch" style="background:@(b.Hole ? HoleColor : AreaColor)"></span>
              <span class="geo-type-icon"><i data-lucide="rectangle-horizontal"></i></span>
              <span class="list-label list-label--mono">@Label(b)</span>
              <Badge Kind="dim">@(b.Hole ? "hole" : "bridge")</Badge>
            </ListRow>
          }
        </div>
        @if (MirrorActive && boxes.Count > 0)
        {
          <p class="section-desc">Faint copies on the canvas are the <strong>symmetry mirror</strong> — the
            generator recreates them, so they aren't listed or stored here.</p>
        }
        @if (boxes.Any(x => x.Hole) && !boxes.Any(x => !x.Hole))
        {
          <p class="section-desc">A hole only carves out a bridge — add a bridge for it to apply.</p>
        }
      </Section>

      @if (overlayOn)
      {
      <Section Title="Buildability">
        <p class="section-desc"><strong>Buildable</strong> shades every column by whether players can build
          there:</p>
        <div class="panel-list">
          <ListRow Compact><span class="list-swatch" style="background:#4caf50"></span><span class="list-label">Buildable</span><Badge Kind="dim">solid ground / bridge</Badge></ListRow>
          <ListRow Compact><span class="list-swatch" style="background:#f57c00"></span><span class="list-label">Void-denied</span><Badge Kind="dim">draw a bridge</Badge></ListRow>
          <ListRow Compact><span class="list-swatch" style="background:#c62828"></span><span class="list-label">Never</span><Badge Kind="dim">always blocked</Badge></ListRow>
          <ListRow Compact><span class="list-swatch" style="background:#fbc02d"></span><span class="list-label">Restricted</span><Badge Kind="dim">limited by a rule</Badge></ListRow>
        </div>
        <p class="section-desc"><strong>Orange</strong> is open void where building is denied — draw a bridge
          across it to link your islands. <strong>Green</strong> already lets players build (terrain or a
          bridge you drew). It refreshes when you save the step.</p>
      </Section>
      }
  </Sidebar>

  <div class="sidebar-handle"></div>

  @* Reused edit canvas in rectangle-draw mode — draws report to the intent (no region is created); the
     bridges/holes render as dummy regions. Category is non-matching so the generated tree stays hidden. *@
  <EditorCanvas @ref="canvas" Slug="@Slug" RectDraw="true" Category="__build_authoring__" ShowBuildable="true"
                OnBuildableToggled="OnBuildableToggled"
                OnRectDrawn="OnRectDrawn" OnGeometrySaved="OnGeometrySaved" OnSelect="OnCanvasSelect" OnReady="OnCanvasReady" />

  <div class="sidebar-handle"></div>

  <Inspector>
      @if (Selected is { } sel)
      {
        <Section @key="sel.Id">
          <DetailHeader Icon="rectangle-horizontal" IconMuted Mono Label="@Label(sel)">
            <Badge Kind="dim">@(sel.Hole ? "hole" : "bridge")</Badge>
          </DetailHeader>
          <div class="section-body">
            <Field Label="Min">
              <div class="ctrl-row">
                <CoordField Prefix="X" Value="@sel.MinX" ReadOnly tabindex="-1" />
                <CoordField Prefix="Z" Value="@sel.MinZ" ReadOnly tabindex="-1" />
              </div>
            </Field>
            <Field Label="Max">
              <div class="ctrl-row">
                <CoordField Prefix="X" Value="@sel.MaxX" ReadOnly tabindex="-1" />
                <CoordField Prefix="Z" Value="@sel.MaxZ" ReadOnly tabindex="-1" />
              </div>
            </Field>
            <p class="section-desc">Select it on the canvas and drag the handles to resize.</p>
            <div class="section-footer section-footer--separated">
              <Button Variant="danger" Fill OnClick="() => Remove(sel.Id)">Remove @(sel.Hole ? "hole" : "bridge")</Button>
            </div>
          </div>
        </Section>
      }
      else
      {
        <Section>
          <DetailHeader Icon="rectangle-horizontal" IconMuted Label="Buildable layer" />
          <p class="section-desc">Draw a bridge or hole, or select one to inspect and resize it.</p>
        </Section>
      }
  </Inspector>

</Workspace>
