@namespace PgmStudio.Client.Pages.Configure
@using PgmStudio.Client.Pages.EditorActivities

@* Teams · spawn step: the point tool drops team 0's spawn; the confirmed symmetry orbit-fills the rest
   (island-aware). The select tool picks a placed marker to inspect/adjust it. Canvas = reused EditorCanvas
   in point-pick mode (base layer only); markers show each team's spawn (placed = bright, orbit = faint).
   The reused side-view sets each spawn's Y on its terrain. *@

<div class="workspace">

  <div class="workspace-sidebar">
    <div class="workspace-scroll">
      <section class="panel-section">
        <div class="section-header section-header--ruled"><h2 class="section-title">Spawn Points</h2></div>
        <p class="section-desc">With the <strong>point tool</strong>, click the map to place a spawn — it
          takes the team of the island you click, and the confirmed symmetry orbits it onto the other teams
          (each reassigned by the island it lands on). The <strong>select tool</strong> picks a placed marker
          to adjust it. Place team 0's; the rest derive. Protection is the next step.</p>
        <div class="panel-list">
          @if (spawns.Count == 0) { <div class="list-empty">No spawns yet — use the point tool and click an island.</div> }
          @foreach (var s in spawns)
          {
            <div class="list-row list-row--compact @(selectedTeamId == s.Team ? "list-row--selected" : null)"
                 @key="s.Team" @onclick="() => SelectTeam(s.Team)">
              <span class="list-swatch" style="background:@Hex(s.Team)"></span>
              <span class="geo-type-icon"><i data-lucide="cylinder"></i></span>
              <span class="list-label list-label--mono">@s.Team-spawn</span>
              <span class="badge @(s.Authored ? "badge--success" : "badge--dim")">@(s.Authored ? "authored" : "orbit")</span>
            </div>
          }
        </div>
      </section>
    </div>
  </div>

  <div class="sidebar-handle"></div>

  @* Reused edit canvas — the point tool places a spawn; spawns render as point dummy regions (markers),
     picked by the normal select hit-test. Category is a non-matching sentinel so the generated tree stays
     hidden (only the island base + the spawn markers show). *@
  <EditorCanvas @ref="canvas" Slug="@Slug" PointPick="true" Category="__spawn_authoring__"
                OnPointPick="OnPointPick" OnSelect="OnCanvasSelect" OnReady="OnCanvasReady" />

  <div class="sidebar-handle"></div>

  <div class="workspace-inspector">
    <div class="workspace-scroll">
      @if (Selected is { } sel)
      {
        <section class="panel-section" @key="sel.Team">
          <div class="detail-header">
            <span class="geo-type-icon detail-icon--muted"><i data-lucide="cylinder"></i></span>
            <span class="detail-label detail-label--mono">@sel.Team-spawn</span>
            <span class="badge @(sel.Authored ? "badge--success" : "badge--dim")">@(sel.Authored ? "authored" : "orbit")</span>
          </div>
          <div class="section-body">
            <div class="field">
              <label class="field-label">Point</label>
              <div class="ctrl-row">
                <div class="coord-field"><span class="coord-prefix">X</span><input class="coord-input" value="@sel.X" @onchange="@(e => SetCoord(sel, "x", e))" /></div>
                <div class="coord-field"><span class="coord-prefix">Y</span><input class="coord-input" value="@sel.Y" @onchange="@(e => SetCoord(sel, "y", e))" /></div>
                <div class="coord-field"><span class="coord-prefix">Z</span><input class="coord-input" value="@sel.Z" @onchange="@(e => SetCoord(sel, "z", e))" /></div>
              </div>
            </div>
            <div class="field">
              <label class="field-label">Yaw</label>
              <div class="ctrl-row">
                <div class="coord-field"><span class="coord-prefix">°</span><input class="coord-input" value="@sel.Yaw" @onchange="@(e => SetCoord(sel, "yaw", e))" /></div>
              </div>
            </div>
            <SliceView Slug="@Slug" Node="@SpawnNode(sel)" OnYChanged="@(y => SetY(sel, y))" />
            <p class="section-desc">Owned by <strong>@TeamName(sel.Team)</strong>. Drag the side-view line to
              set the Y — shared across the orbit. Editing the authored spawn's X/Z re-derives the orbit.</p>
          </div>
        </section>
      }
      else
      {
        <section class="panel-section">
          <div class="detail-header">
            <span class="geo-type-icon detail-icon--muted"><i data-lucide="cylinder"></i></span>
            <span class="detail-label">Spawn point</span>
          </div>
          <p class="section-desc">Click an island on the canvas to place a spawn; orbit fills the rest.
            Select a spawn to fine-tune its coordinates.</p>
        </section>
      }
    </div>
  </div>

</div>
