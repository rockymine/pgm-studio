@namespace PgmStudio.Client.Pages.Configure
@using PgmStudio.Client.Pages.EditorActivities

@* Teams · spawn step: the point tool drops team 0's spawn; the confirmed symmetry orbit-fills the rest
   (island-aware). The select tool picks a placed marker to inspect/adjust it. Canvas = reused EditorCanvas
   in point-pick mode (base layer only); markers show each team's spawn (placed = bright, orbit = faint).
   The reused side-view sets each spawn's Y on its terrain. *@

<Workspace>

  <Sidebar>
      <Section Title="Spawn Points">
        <p class="section-desc">With the <strong>point tool</strong>, click the map to place a spawn — it
          takes the team of the island you click, and the confirmed symmetry orbits it onto the other teams
          (each reassigned by the island it lands on). The <strong>select tool</strong> picks a placed marker
          to adjust it. Place team 0's; the rest derive. Protection is the next step.</p>
        <div class="panel-list">
          @if (spawns.Count == 0) { <div class="list-empty">No spawns yet — use the point tool and click an island.</div> }
          @foreach (var s in spawns)
          {
            <ListRow Compact Selected="selectedTeamId == s.Team" @key="s.Team" OnClick="() => SelectTeam(s.Team)">
              <span class="list-swatch" style="background:@Hex(s.Team)"></span>
              <span class="geo-type-icon"><i data-lucide="@PointIcon"></i></span>
              <span class="list-label list-label--mono">@s.Team-spawn</span>
              <Badge Class="@(s.Authored ? "badge--success" : "badge--dim")">@(s.Authored ? "authored" : "orbit")</Badge>
            </ListRow>
          }
          @if (observer is not null)
          {
            <ListRow Compact Selected="selectedTeamId == ObserverId" @key="ObserverId" OnClick="() => SelectTeam(ObserverId)">
              <span class="list-swatch" style="background:@ObserverHex"></span>
              <span class="geo-type-icon"><i data-lucide="@PointIcon"></i></span>
              <span class="list-label list-label--mono">observer-spawn</span>
              <Badge Kind="dim">default</Badge>
            </ListRow>
          }
        </div>
      </Section>
  </Sidebar>

  <div class="sidebar-handle"></div>

  @* Reused edit canvas — the point tool places a spawn; spawns render as point dummy regions (markers),
     picked by the normal select hit-test. Category is a non-matching sentinel so the generated tree stays
     hidden (only the island base + the spawn markers show). *@
  <EditorCanvas @ref="canvas" Slug="@Slug" PointPick="true" Category="__spawn_authoring__"
                OnPointPick="OnPointPick" OnSelect="OnCanvasSelect" OnReady="OnCanvasReady" />

  <div class="sidebar-handle"></div>

  <Inspector>
      @if (Selected is { } sel)
      {
        <Section @key="sel.Team">
          <DetailHeader Icon="@PointIcon" IconMuted Mono Label='@(IsObserver(sel) ? "observer-spawn" : $"{sel.Team}-spawn")'>
            @if (IsObserver(sel))
            {
              <Badge Kind="dim">default</Badge>
            }
            else
            {
              <Badge Class="@(sel.Authored ? "badge--success" : "badge--dim")">@(sel.Authored ? "authored" : "orbit")</Badge>
            }
          </DetailHeader>
          <div class="section-body">
            <Field Label="Point">
              <div class="ctrl-row">
                <CoordField Prefix="X"><NumberField Value="sel.X" ValueChanged="@(v => SetCoord(sel, "x", v))" Step="0.5" CssClass="coord-input" /></CoordField>
                <CoordField Prefix="Y"><NumberField Value="sel.Y" ValueChanged="@(v => SetCoord(sel, "y", v))" Step="0.5" CssClass="coord-input" /></CoordField>
                <CoordField Prefix="Z"><NumberField Value="sel.Z" ValueChanged="@(v => SetCoord(sel, "z", v))" Step="0.5" CssClass="coord-input" /></CoordField>
              </div>
            </Field>
            <Field Label="Yaw">
              <div class="ctrl-row">
                <CoordField Prefix="°"><NumberField Value="sel.Yaw" ValueChanged="@(v => SetCoord(sel, "yaw", v))" Step="any" CssClass="coord-input" /></CoordField>
              </div>
            </Field>
            <SliceView Slug="@Slug" Node="@SpawnNode(sel)" OnYChanged="@(y => SetY(sel, y))" SeatOnFloor="true" />
            @if (IsObserver(sel))
            {
              <p class="section-desc">The <strong>observer</strong> (<code>&lt;default&gt;</code>) spawn — where
                players wait pre-game and spectate. Drag the side-view line to set its Y onto solid ground.
                The yaw auto-aims at a team spawn when you move it (edit it to override).</p>
            }
            else
            {
              <p class="section-desc">Owned by <strong>@TeamName(sel.Team)</strong>. Drag the side-view line to
                set the Y — shared across the orbit. Editing the authored spawn's X/Z re-derives the orbit.
                The yaw auto-aims at the map middle when you move it (edit it to override).</p>
            }
          </div>
        </Section>
      }
      else
      {
        <Section>
          <DetailHeader Icon="@PointIcon" IconMuted Label="Spawn point" />
          <p class="section-desc">Click an island on the canvas to place a spawn; orbit fills the rest.
            Select a spawn to fine-tune its coordinates.</p>
        </Section>
      }
  </Inspector>

</Workspace>
