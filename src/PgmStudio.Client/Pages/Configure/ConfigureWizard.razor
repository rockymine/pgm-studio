@page "/maps/{Slug}/configure"
@layout EditorLayout
@inject HttpClient Http
@inject IJSRuntime JS

@* New-map Configure wizard shell. Activity rail + flow bar + three-panel workspace, with a phase/step
   state machine and an intent-slice-gated rail. Built phase bodies render their own workspace; the rest
   are scaffold placeholders until their N-task lands. See new-map-authoring.md §12 + routing-and-ia.md. *@

<ConfigureLayout MapName="@mapName" Crumb="Configure" ActivePhaseId="@Phase.Id" Furthest="@furthest"
              PhaseIcon="@Phase.Icon" PhaseTitle="@Phase.Title"
              Steps="@Phase.Steps" CurrentStep="@step" SaveStatus="@SaveStatus"
              BackEnabled="@BackEnabled" NextEnabled="@NextEnabled" NextLabel="@NextLabel"
              OnJumpPhase="JumpPhase" OnStep="JumpStep" OnBack="Back" OnNext="Next">

  @* Phase bodies render inside this cascade: they patch their slice on Intent and call MarkDirty(), and
     the wizard persists it on the next phase-advance. *@
  <CascadingValue Value="this" IsFixed="true">
  @if (!ready)
  {
    @* Hold the phase bodies until the intent has loaded — they read it once on init, so mounting them
       mid-load would capture an empty intent (blank Map Info even when the map has a name/authors). *@
    <div class="workspace" @key="@("loading")">
      <div class="workspace-scroll"><p class="panel-empty-msg">Loading…</p></div>
    </div>
  }
  else if (Phase.Id == "info")
  {
    <InfoPhase @key="@Phase.Id" />
  }
  else if (Phase.Id == "world" && step == 0)
  {
    <WorldScanPhase @key="@("world-scan")" />
  }
  else if (Phase.Id == "world" && step == 1)
  {
    <WorldIslandsPhase @key="@("world-islands")" />
  }
  else if (Phase.Id == "world" && step == 2)
  {
    <WorldSymmetryPhase @key="@("world-symmetry")" />
  }
  else if (Phase.Id == "teams" && step == 0)
  {
    <TeamsPhase @key="@("teams-assign")" />
  }
  else if (Phase.Id == "teams" && step == 1)
  {
    <SpawnPhase @key="@("teams-spawn")" />
  }
  else if (Phase.Id == "teams" && step == 2)
  {
    <ProtectionPhase @key="@("teams-protect")" />
  }
  else if (Phase.Id == "build" && step == 0)
  {
    <BuildHeightPhase @key="@("build-height")" />
  }
  else if (Phase.Id == "build" && step == 1)
  {
    <BuildLayerPhase @key="@("build-layer")" />
  }
  @* Keyed on the step label, not its index: sketch-origin maps drop the Monuments step, which
     shifts Room's index down (ConfigureWizard.razor.cs LoadOriginAsync). *@
  else if (Phase.Id == "wools" && StepLabel == "Objectives")
  {
    <WoolObjectivesPhase @key="@("wools-objectives")" />
  }
  else if (Phase.Id == "wools" && StepLabel == "Spawn")
  {
    <WoolSpawnPhase @key="@("wools-spawn")" />
  }
  else if (Phase.Id == "wools" && StepLabel == "Monuments")
  {
    <WoolMonumentsPhase @key="@("wools-monuments")" />
  }
  else if (Phase.Id == "wools" && StepLabel == "Room")
  {
    <WoolRoomPhase @key="@("wools-room")" />
  }
  else if (Phase.Id == "review" && step == 0)
  {
    <ReviewPreflightPhase @key="@("review-preflight")" />
  }
  else if (Phase.Id == "review" && step == 1)
  {
    <ReviewTreePhase @key="@("review-tree")" />
  }
  else if (Phase.Id == "review" && step == 2)
  {
    <ReviewXmlPhase @key="@("review-xml")" />
  }
  else
  {
  <Workspace @key="@Phase.Id">
    <Sidebar>
        <Section Title="@Phase.Title">
          <Actions><Badge Kind="dim">@Phase.Task</Badge></Actions>
          <ChildContent>
          <p class="section-desc">
            @if (Phase.Steps.Length == 0)
            {
              <text>Single-step phase.</text>
            }
            else
            {
              <text>Step @(step + 1) of @Phase.Steps.Length — <strong>@StepLabel</strong>.</text>
            }
          </p>
          <p class="panel-empty-msg" style="text-align:left">
            Shell scaffold — the @Phase.Title panels are built by @Phase.Task.
          </p>
          </ChildContent>
        </Section>
    </Sidebar>

    <div class="sidebar-handle"></div>

    <div class="workspace-canvas">
      <div class="canvas-surface" style="display:flex;align-items:center;justify-content:center;">
        <p class="panel-empty-msg">@Phase.Title · @StepLabel — canvas scaffold (@Phase.Task)</p>
      </div>
    </div>

    <div class="sidebar-handle"></div>

    <Inspector>
        <Section>
          <DetailHeader Icon="@Phase.Icon" IconMuted Label="Inspector" />
          <p class="section-desc">Phase-specific inspector panels land with @Phase.Task.</p>
        </Section>
    </Inspector>
  </Workspace>
  }
  </CascadingValue>

</ConfigureLayout>
