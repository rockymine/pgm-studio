@namespace PgmStudio.Client.Pages.Configure
@using PgmStudio.Client.Models
@using PgmStudio.Client.Pages.EditorActivities
@using W = PgmStudio.Client.Pages.Configure.WoolAuthoring

@* Wools · spawn: confirm/adjust each wool's source point (where it dispenses), seeded by detection. The
   point tool moves it; an anchor-team wool re-derives its symmetric partners; the side-view sets the Y. *@

<div class="workspace">

  <div class="workspace-sidebar">
    <div class="workspace-scroll">
      <section class="panel-section">
        <div class="section-header section-header--ruled"><h2 class="section-title">Wool spawn</h2></div>
        <p class="section-desc">Where each wool dispenses. The seed comes from the detected source; nudge it
          with the <strong>point tool</strong> or the coordinates, and seat its Y on the side-view. Moving an
          authored wool re-derives its mirror.</p>
        <div class="panel-list">
          @if (wools.Count == 0) { <div class="list-empty">No wools — confirm objectives first.</div> }
          @foreach (var w in wools)
          {
            <div class="list-row list-row--compact @(selectedColor == w.Color ? "list-row--selected" : null)"
                 @key="w.Color" @onclick="() => SelectWool(w.Color)">
              <span class="geo-type-icon" style="color:@W.Hex(w.Color)"><i data-lucide="dot"></i></span>
              <span class="list-label list-label--mono">@w.Color</span>
              <span class="badge @(IsAuthored(w) ? "badge--success" : "badge--dim")">@(IsAuthored(w) ? "authored" : "orbit")</span>
            </div>
          }
        </div>
      </section>
    </div>
  </div>

  <div class="sidebar-handle"></div>

  <EditorCanvas @ref="canvas" Slug="@Slug" PointPick="true" Category="__wool_spawn__"
                OnPointPick="OnPointPick" OnSelect="OnCanvasSelect" OnReady="OnCanvasReady" />

  <div class="sidebar-handle"></div>

  <div class="workspace-inspector">
    <div class="workspace-scroll">
      @if (Selected is { } sel)
      {
        <section class="panel-section" @key="sel.Color">
          <div class="detail-header">
            <span class="geo-type-icon" style="color:@W.Hex(sel.Color)"><i data-lucide="dot"></i></span>
            <span class="detail-label detail-label--mono">@sel.Color wool</span>
            <span class="badge @(IsAuthored(sel) ? "badge--success" : "badge--dim")">@(IsAuthored(sel) ? "authored" : "orbit")</span>
          </div>
          <div class="section-body">
            <div class="field">
              <label class="field-label">Spawn location <span class="text-muted text-sm">(floored to a block)</span></label>
              <div class="ctrl-row">
                <div class="coord-field"><span class="coord-prefix">X</span><input class="coord-input" value="@sel.SpawnX" @onchange="@(e => SetCoord(sel, "x", e))" /></div>
                <div class="coord-field"><span class="coord-prefix">Y</span><input class="coord-input" value="@sel.SpawnY" @onchange="@(e => SetCoord(sel, "y", e))" /></div>
                <div class="coord-field"><span class="coord-prefix">Z</span><input class="coord-input" value="@sel.SpawnZ" @onchange="@(e => SetCoord(sel, "z", e))" /></div>
              </div>
            </div>
            <SliceView Slug="@Slug" Node="@SpawnNode(sel)" OnYChanged="@(y => SetY(sel, y))" />
            <p class="section-desc">Owned by <strong>@(string.IsNullOrEmpty(sel.Owner) ? "—" : TeamName(sel.Owner))</strong>.
              Drag the side-view line to set the Y. @(IsAuthored(sel) ? "Editing X/Z re-derives the mirror." : "")</p>
          </div>
        </section>
      }
      else
      {
        <section class="panel-section">
          <div class="detail-header">
            <span class="geo-type-icon detail-icon--muted"><i data-lucide="dot"></i></span>
            <span class="detail-label">Wool spawn</span>
          </div>
          <p class="section-desc">Select a wool to place its source point and set its Y.</p>
        </section>
      }
    </div>
  </div>

</div>
