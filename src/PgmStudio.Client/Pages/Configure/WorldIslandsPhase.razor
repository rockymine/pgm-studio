@namespace PgmStudio.Client.Pages.Configure
@using PgmStudio.Client.Pages.EditorActivities

@* World · Islands sub-step (N01): review detected islands, exclude the stray ones. Select from the list
   or by clicking the canvas; the selection's centre / block count / exclude toggle show in the inspector.
   The canvas is the reused EditorCanvas in island-select mode (island base layer + the Blocks overlay toggle). *@

<Workspace>

  <Sidebar>
      <Section Title="Islands">
        <Actions><Badge Kind="dim">@islands.Count detected</Badge></Actions>
        <ChildContent>
        <p class="section-desc">Exclude islands that aren't part of the playable layout (observer towers,
          decor). Removing one only re-runs <strong>symmetry detection</strong> — never the scan.</p>
        <div class="panel-list">
          @if (Included.Count == 0) { <div class="list-empty">No islands.</div> }
          @foreach (var isl in Included)
          {
            <ListRow Compact Selected="selectedId == isl.Id"
                 @key="isl.Id" OnClick="() => Select(isl.Id)">
              <span class="geo-type-icon"><i data-lucide="layers"></i></span>
              <span class="list-label">@Label(isl)</span>
              <span class="list-tag">@isl.BlockCount.ToString("N0")</span>
            </ListRow>
          }
        </div>
        </ChildContent>
      </Section>
      <Section Title="Excluded Islands">
        <div class="panel-list">
          @if (ExcludedList.Count == 0) { <div class="list-empty">No islands excluded.</div> }
          @foreach (var isl in ExcludedList)
          {
            <ListRow Compact Selected="selectedId == isl.Id"
                 @key="isl.Id" OnClick="() => Select(isl.Id)">
              <span class="geo-type-icon"><i data-lucide="layers"></i></span>
              <span class="list-label">@Label(isl)</span>
              <span class="list-tag">@isl.BlockCount.ToString("N0")</span>
            </ListRow>
          }
        </div>
      </Section>
  </Sidebar>

  <div class="sidebar-handle"></div>

  @* Reused edit canvas in island-select mode — base layer only, click an island to select it. *@
  <EditorCanvas @ref="canvas" Slug="@Slug" IslandSelect="true"
                OnIslandSelect="Select" OnReady="OnCanvasReady" />

  <div class="sidebar-handle"></div>

  <Inspector>
      @if (Selected is { } sel)
      {
        <Section @key="sel.Id">
          <div class="detail-header">
            <span class="geo-type-icon detail-icon--muted"><i data-lucide="layers"></i></span>
            <span class="detail-label">@Label(sel)</span>
            <Badge Class="@(IsExcluded(sel) ? "badge--dim" : "badge--success")">@(IsExcluded(sel) ? "excluded" : "included")</Badge>
          </div>
          <div class="section-body">
            <Field Label="Centre">
              <div class="ctrl-row">
                <div class="coord-field"><span class="coord-prefix">X</span><input class="coord-input" value="@sel.CentreX.ToString("0.#")" disabled /></div>
                <div class="coord-field"><span class="coord-prefix">Z</span><input class="coord-input" value="@sel.CentreZ.ToString("0.#")" disabled /></div>
              </div>
            </Field>
            <Field Label="Blocks">
              <div class="field-pick-row">
                <span class="field-value">@sel.BlockCount.ToString("N0")</span>
              </div>
            </Field>
            @if (IsExcluded(sel))
            {
              <Button Fill OnClick="() => ToggleExclude(sel)">Include island</Button>
            }
            else
            {
              <Button Variant="danger" Fill OnClick="() => ToggleExclude(sel)">Exclude island</Button>
            }
          </div>
        </Section>
      }
      else
      {
        <Section>
          <div class="detail-header">
            <span class="geo-type-icon detail-icon--muted"><i data-lucide="layers"></i></span>
            <span class="detail-label">Islands</span>
          </div>
          <p class="section-desc">Select an island — in the list or on the canvas — to see its details and
            exclude it.</p>
        </Section>
      }
  </Inspector>

</Workspace>
