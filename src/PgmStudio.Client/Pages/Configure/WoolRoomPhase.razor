@namespace PgmStudio.Client.Pages.Configure
@using PgmStudio.Client.Pages.EditorActivities
@using W = PgmStudio.Client.Pages.Configure.WoolAuthoring

@* Wools · room: draw the rectangle(s) each wool lives in — a room is a union of rectangles, listed flat
   (one row per rectangle, authored or orbit) and edited one at a time. The right panel shows coordinates. *@

<Workspace>

  <Sidebar>
      <section class="panel-section">
        @{ var rows = Rows(); }
        <div class="section-header section-header--ruled"><h2 class="section-title">Wool rooms</h2></div>
        <p class="section-desc">With the <strong>rectangle tool</strong>, drag the room around a wool's source —
          draw several for a multi-part room. The symmetry fills the partner wools. Click a rectangle to select
          it, then drag the handles on the canvas to resize.</p>
        <div class="panel-list">
          @if (wools.Count == 0) { <div class="list-empty">No wools — confirm objectives first.</div> }
          else if (rows.Count == 0) { <div class="list-empty">Nothing drawn yet — drag a rectangle over a wool's source.</div> }
          @foreach (var row in rows)
          {
            <div class="list-row list-row--compact @(selectedRegionId == row.RegionId ? "list-row--selected" : null)"
                 @key="row.RegionId" @onclick="() => SelectRow(row.RegionId)">
              <span class="list-swatch" style="background:@W.Hex(row.Color)"></span>
              <span class="geo-type-icon"><i data-lucide="rectangle-horizontal"></i></span>
              <span class="list-label list-label--mono">@row.Name</span>
              <span class="badge @(row.Authored ? "badge--success" : "badge--dim")">@(row.Authored ? "authored" : "orbit")</span>
            </div>
          }
        </div>
      </section>
  </Sidebar>

  <div class="sidebar-handle"></div>

  <EditorCanvas @ref="canvas" Slug="@Slug" RectDraw="true" Category="__wool_room__"
                OnRectDrawn="OnRectDrawn" OnGeometrySaved="OnGeometrySaved" OnSelect="OnCanvasSelect" OnReady="OnCanvasReady" />

  <div class="sidebar-handle"></div>

  <Inspector>
      @if (Selected is { } sel)
      {
        <div class="panel-stack" @key="sel.RegionId">
          <section class="panel-section">
            <div class="detail-header">
              <span class="geo-type-icon" style="color:@W.Hex(sel.Color)"><i data-lucide="rectangle-horizontal"></i></span>
              <span class="detail-label detail-label--mono">@sel.Name</span>
              <span class="badge @(sel.Authored ? "badge--success" : "badge--dim")">@(sel.Authored ? "authored" : "orbit")</span>
            </div>
            <div class="section-body">
              <div class="field">
                <label class="field-label">Min</label>
                <div class="ctrl-row">
                  <div class="coord-field"><span class="coord-prefix">X</span><input class="coord-input" value="@sel.MinX" readonly tabindex="-1" /></div>
                  <div class="coord-field"><span class="coord-prefix">Z</span><input class="coord-input" value="@sel.MinZ" readonly tabindex="-1" /></div>
                </div>
              </div>
              <div class="field">
                <label class="field-label">Max</label>
                <div class="ctrl-row">
                  <div class="coord-field"><span class="coord-prefix">X</span><input class="coord-input" value="@sel.MaxX" readonly tabindex="-1" /></div>
                  <div class="coord-field"><span class="coord-prefix">Z</span><input class="coord-input" value="@sel.MaxZ" readonly tabindex="-1" /></div>
                </div>
              </div>
              @if (sel.Authored)
              {
                <p class="section-desc">Owned by <strong>@TeamName(OwnerSlug(sel.Color))</strong>. Drag the handles
                  on the canvas to resize. Draw another rectangle over the @sel.Color source to add to its room.</p>
                <div class="section-footer section-footer--separated">
                  <button class="action-btn action-btn--danger action-btn--fill" @onclick="() => Remove(sel.RegionId)">Remove rectangle</button>
                </div>
              }
              else
              {
                <p class="section-desc">Derived from the authored <strong>@sel.Color</strong> room by symmetry —
                  edit the authored partner to change it.</p>
              }
            </div>
          </section>

          @if (sel.Authored)
          {
            <section class="panel-section">
              <div class="section-header section-header--ruled">
                <h2 class="section-title">Auto-wiring</h2>
                <span class="badge badge--dim">derived</span>
              </div>
              <div class="panel-list">
                <div class="list-row list-row--compact list-row--muted"><span class="geo-type-icon"><i data-lucide="link"></i></span><span class="list-label list-label--mono">enter = not-@TeamSlug(OwnerSlug(sel.Color))</span><span class="list-tag">room defense</span></div>
                <div class="list-row list-row--compact list-row--muted"><span class="geo-type-icon"><i data-lucide="link"></i></span><span class="list-label list-label--mono">block = not-@TeamSlug(OwnerSlug(sel.Color))</span><span class="list-tag">build/break</span></div>
                @if (WoolOf(sel.Color) is { } sw)
                {
                  <div class="list-row list-row--compact list-row--muted"><span class="geo-type-icon"><i data-lucide="link"></i></span><span class="list-label list-label--mono">capture ×@sw.Monuments.Count</span><span class="list-tag">monuments</span></div>
                }
              </div>
              <p class="section-desc">The generator wires defense + build/break on the whole room and capture on
                the monuments — derived at save.</p>
            </section>
          }
        </div>
      }
      else
      {
        <section class="panel-section">
          <div class="detail-header">
            <span class="geo-type-icon detail-icon--muted"><i data-lucide="rectangle-horizontal"></i></span>
            <span class="detail-label">Wool room</span>
          </div>
          <p class="section-desc">Draw a rectangle over a wool's source, or select one to inspect and resize it.</p>
        </section>
      }
  </Inspector>

</Workspace>
