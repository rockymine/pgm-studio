@namespace PgmStudio.Client.Pages.Configure

@* Map Info phase body (N00): the map's identity slice — name + authors/contributors → intent meta.
   Version / mode / objective are auto-derived by the generator and shown locked. Author handling mirrors
   the Overview editor: a username resolves on blur to its head + canonical name, an unknown one is
   flagged and kept out of the intent. Edits patch the wizard's working Intent and mark it dirty. *@

<div class="workspace">
  <div class="workspace-scroll" style="max-width: 720px; margin: 0 auto;">

    <section class="panel-section">
      <div class="section-header section-header--ruled">
        <h2 class="section-title">Identity</h2>
      </div>
      <div class="section-body">
        <div class="field">
          <label class="field-label">Map name <span class="field-required">*</span></label>
          <input class="field-input" type="text" placeholder="My CTW Map" value="@name" @oninput="OnName" />
        </div>
        <div class="field-row">
          <div class="field">
            <label class="field-label">Version</label>
            <input class="field-input" type="text" value="@Version" disabled title="Auto-derived" />
          </div>
          <div class="field field--compact">
            <label class="field-label">Mode</label>
            <input class="field-input" type="text" value="@Mode" disabled title="Auto-derived" />
          </div>
        </div>
        <div class="field">
          <label class="field-label">Objective</label>
          <textarea class="field-input field-input--textarea" rows="2" disabled
                    title="Auto-derived from gamemode">@Objective</textarea>
        </div>
        <p class="section-desc">Version, mode, and objective are auto-derived — the generator sets them, so
          they aren't edited here.</p>
      </div>
    </section>

    <section class="panel-section">
      <div class="section-header section-header--ruled">
        <h2 class="section-title">Authors <span class="field-required">*</span></h2>
        <button class="action-btn" @onclick="AddAuthor">+ Add</button>
      </div>
      <div class="author-list">
        @foreach (var p in authors) { @PersonRow(p) }
      </div>
      <p class="section-desc">At least one verified author is required. Usernames are checked against
        Mojang when you leave the field.</p>
    </section>

    <section class="panel-section">
      <div class="section-header section-header--ruled">
        <h2 class="section-title">Contributors</h2>
        <button class="action-btn" @onclick="AddContributor">+ Add</button>
      </div>
      @if (contributors.Count == 0)
      {
        <p class="section-desc">Optional — people who helped but aren't lead authors.</p>
      }
      else
      {
        <div class="author-list">
          @foreach (var p in contributors) { @PersonRow(p) }
        </div>
      }
    </section>

  </div>
</div>

@code {
  // One author/contributor row: avatar head (mc-heads, via the resolved uuid) · username field · remove.
  // Markup template, so it lives here rather than the code-behind. Mirrors the Overview editor's row.
  private RenderFragment PersonRow(Person p) => __builder =>
  {
    <div class="author-row">
      <img class="author-avatar" width="16" height="16" alt=""
           src="@(string.IsNullOrEmpty(p.Uuid) ? AvatarEmpty : $"https://mc-heads.net/avatar/{p.Uuid}/16")" />
      <input class="field-input author-name @(p.Error ? "field-input--error" : null)" type="text"
             placeholder="Minecraft username" spellcheck="false"
             title="@(p.Error ? "No Minecraft account with this username" : p.Uuid)"
             value="@p.Name" @oninput="e => OnInput(p, e)" @onblur="() => ResolveName(p)" />
      <button class="btn-remove" title="Remove" @onclick="() => Remove(p)"><i data-lucide="x"></i></button>
    </div>;
  };
}
