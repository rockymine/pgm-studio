@namespace PgmStudio.Client.Pages.Edit
@inject HttpClient Http
@inject IJSRuntime JS

@* Objective phase — wools (list/add/inspector with location + monuments) + wool-region tree on a
   wool-filtered canvas. Port of objectives-activity.js + objectives-panel.js. Drawing is deferred. *@

<div class="phase-body">
<FlowBar Class="flow-bar--flush" PhaseIcon="goal" PhaseTitle="Objective"
         BackEnabled="@(!IsFirstPhase)" NextLabel="@(IsLastPhase ? "Done" : "Next")"
         OnBack="OnPrevPhase" OnNext="OnNextPhase" />
<Workspace>
  <Sidebar>
      <Section Title="Wools">
        <Actions>
          <Button Disabled="@(NextWoolColor() is null)" OnClick="AddWool">+ Add</Button>
        </Actions>
        <ChildContent>
          <div class="panel-list">
            @if (wools.Count == 0) { <div class="list-empty">No wools.</div> }
            @foreach (var w in wools)
            {
              <ListRow Compact Selected="selWool == w.Id" OnClick="() => SelectWool(w.Id)">
                <span class="list-swatch" style="background-color:@GameColors.DyeHex(w.Color)"></span>
                <span class="list-label">@DyeLabel(w.Color)</span>
              </ListRow>
            }
          </div>
        </ChildContent>
      </Section>

      <Section Title="Wool Regions">
        @if (groups is null) { <div class="list-empty">Loading…</div> }
        else { <RegionTree Groups="groups" SelectedId="selRegion" SelectedSet="selRegionSet" OnSelect="OnTreeSelect" /> }
      </Section>
  </Sidebar>

  <div class="sidebar-handle"></div>

  <EditorCanvas @ref="canvas" Slug="@Slug" Category="wool" DrawCategory="wool" DraftStep="objective" OnSelect="OnCanvasSelect" OnRegionCreated="Reload" OnGeometrySaved="OnGeometrySaved" />

  <div class="sidebar-handle"></div>

  <Inspector>
      <Section>
        @if (selWool is not null && CurrentWool is { } wool)
        {
          <div class="section-header section-header--ruled">
            <div class="section-heading">
              <span class="list-swatch" style="background-color:@GameColors.DyeHex(wool.Color)"></span>
              <h2 class="section-title">@DyeLabel(wool.Color) Wool</h2>
            </div>
          </div>
          <Field Label="Color">
            <select class="field-input" value="@wool.Color" @onchange="SaveWoolColor">
              @foreach (var c in AvailableColors(wool)) { <option value="@c.Value">@c.Label</option> }
            </select>
          </Field>
          <Field Label="Owning Team">
            <div class="field-pick-row">
              <span class="field-swatch" style="background:@TeamColor(wool.Team)"></span>
              <select class="field-input" value="@(wool.Team ?? "")" @onchange="SaveWoolTeam">
                <option value="">— none —</option>
                @foreach (var t in teams) { <option value="@t.Id">@(string.IsNullOrEmpty(t.Name) ? t.Id : t.Name)</option> }
              </select>
            </div>
          </Field>
          <Field Label="Block Position">
            <div class="ctrl-row">
              <CoordField Prefix="X" Type="number" Value="@wLocX" OnChange="e => wLocX = e.Value?.ToString()" OnBlur="SaveWoolLocation" />
              <CoordField Prefix="Y" Type="number" Value="@wLocY" OnChange="e => wLocY = e.Value?.ToString()" OnBlur="SaveWoolLocation" />
              <CoordField Prefix="Z" Type="number" Value="@wLocZ" OnChange="e => wLocZ = e.Value?.ToString()" OnBlur="SaveWoolLocation" />
            </div>
          </Field>
          <Field Label="Wool Room Region">
            <input class="field-input" type="text" spellcheck="false" placeholder="region-id" value="@(wool.WoolRoomRegion ?? "")"
                   @onchange="SaveWoolRoom" />
          </Field>
          <div class="section-footer section-footer--separated">
            <Button Variant="danger" Fill OnClick="() => DeleteWool(wool)">Delete Wool</Button>
          </div>

          @* Monuments *@
          <Section Title="Monuments">
            <Actions>
              <Button Disabled="@(NextMonumentTeam(wool) is null)" OnClick="() => AddMonument(wool)">+ Add</Button>
            </Actions>
            <ChildContent>
              @if (wool.Monuments.Count > 0)
              {
                <div class="filter-group-options filter-group-options--mt">
                  @foreach (var m in wool.Monuments)
                  {
                    var mt = teams.FirstOrDefault(t => t.Id == m.Team);
                    <Chip Active="m.Id == selMon"
                            style="@(mt is null ? null : $"color:{GameColors.ChatHex(mt.Color)}")" OnClick="() => SelectMonument(m.Id)">
                      @(mt?.Name ?? m.Team ?? "?")
                    </Chip>
                  }
                </div>
              }
              @if (wool.Monuments.FirstOrDefault(m => m.Id == selMon) is { } mon)
              {
                <div class="section-body">
                  <Field Label="Team">
                    <div class="field-pick-row">
                      <span class="field-swatch" style="background:@TeamColor(mon.Team)"></span>
                      <select class="field-input" value="@(mon.Team ?? "")" @onchange="SaveMonTeam">
                        <option value="">— none —</option>
                        @foreach (var t in teams) { <option value="@t.Id">@(string.IsNullOrEmpty(t.Name) ? t.Id : t.Name)</option> }
                      </select>
                    </div>
                  </Field>
                  <Field Label="Block Position">
                    <div class="ctrl-row">
                      <CoordField Prefix="X" Type="number" Value="@mLocX" OnChange="e => mLocX = e.Value?.ToString()" OnBlur="() => SaveMonumentLocation(wool, mon)" />
                      <CoordField Prefix="Y" Type="number" Value="@mLocY" OnChange="e => mLocY = e.Value?.ToString()" OnBlur="() => SaveMonumentLocation(wool, mon)" />
                      <CoordField Prefix="Z" Type="number" Value="@mLocZ" OnChange="e => mLocZ = e.Value?.ToString()" OnBlur="() => SaveMonumentLocation(wool, mon)" />
                    </div>
                  </Field>
                  <Field Label="Monument Region">
                    <input class="field-input" type="text" spellcheck="false" placeholder="region-id (optional)" value="@(mon.MonumentRegion ?? "")"
                           @onchange="SaveMonRegion" />
                  </Field>
                </div>
                <div class="section-footer section-footer--separated">
                  <Button Variant="danger" Fill OnClick="() => DeleteMonument(wool, mon)">Delete Monument</Button>
                </div>
              }
            </ChildContent>
          </Section>
        }
        else if (selRegion is not null)
        {
          <RegionInspector Node="RegionNodeSel" Slug="@Slug" OnSelectChild="Select" OnSetY="SetRegionY" OnSetCoord="OnSetCoord" />
        }
        else
        {
          <p class="panel-empty-msg">Select a wool or region to inspect.</p>
        }
      </Section>
  </Inspector>
</Workspace>
</div>

<Toast Message="@error" />
