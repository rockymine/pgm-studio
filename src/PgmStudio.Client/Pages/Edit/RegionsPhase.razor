@namespace PgmStudio.Client.Pages.Edit
@inject HttpClient Http
@inject IJSRuntime JS
@implements IAsyncDisposable

@* Regions phase: geo-tree sidebar + hybrid canvas + region inspector. R1a authoring interaction:
   Ctrl/⌘-click multi-selects; Ctrl+G groups ≥2 into a union, or ungroups a single compound. *@

<div class="phase-body">
<FlowBar Class="flow-bar--flush" PhaseIcon="layout-dashboard" PhaseTitle="Regions"
         BackEnabled="@(!IsFirstPhase)" NextLabel="@(IsLastPhase ? "Done" : "Next")"
         OnBack="OnPrevPhase" OnNext="OnNextPhase" />
<Workspace>
  <Sidebar>
      <Section Title="Regions">
        @if (groups is null) { <div class="list-empty">Loading…</div> }
        else { <RegionTree Groups="groups" SelectedId="primaryId" SelectedSet="selection" OnSelect="OnTreeSelect" OnSelectCtrl="OnTreeSelectCtrl" /> }
      </Section>
  </Sidebar>

  <div class="sidebar-handle"></div>

  <EditorCanvas @ref="canvas" Slug="@Slug" OnSelect="OnCanvasSelect" OnGeometrySaved="OnGeometrySaved" />

  <div class="sidebar-handle"></div>

  <Inspector>
      <Section>
        <RegionInspector Node="primaryNode" Slug="@Slug" OnSelectChild="SelectOne" OnSetCoord="OnSetCoord" />
      </Section>
  </Inspector>
</Workspace>
</div>

<Toast Message="@error" />
