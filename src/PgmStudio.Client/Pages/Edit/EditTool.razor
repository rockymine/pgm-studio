@page "/maps/{Slug}/edit"
@layout StudioLayout
@inject HttpClient Http
@inject IJSRuntime JS

@* Editor shell — topbar + nav rail + activity viewport. Port of studio/templates/editor.html
   + the phase state machine in static/main.js. *@

<StudioShell>
  <Bar>
    <Topbar HomeHref="/maps" HomeLabel="Maps" HomeTitle="Back to dashboard">
      <Crumbs>
        <Crumb>@(mapName ?? Slug.Replace('_', ' '))</Crumb>
        <Crumb Dim>@(string.IsNullOrEmpty(mapVersion) ? "" : $"v{mapVersion}")</Crumb>
      </Crumbs>
      <Right>
        <div id="topbar-error" role="alert" class="@(error is null ? null : "is-visible")">
          <span class="topbar-error-text">@error</span>
          <button class="topbar-error-dismiss" @onclick="() => error = null"><i data-lucide="x"></i></button>
        </div>
        <Button Disabled>Export XML</Button>
      </Right>
    </Topbar>
  </Bar>
  <Rail>
    <NavRail>
      @foreach (var a in Phases)
      {
        <NavButton Icon="@a.Icon" Title="@a.Title" Active="active == a.Id"
                   Disabled="!loaded" Status="@StatusOf(a.Id)" OnClick="() => Switch(a.Id)" />
      }
      <NavButton Icon="gavel" Title="Filters" Disabled="true" />
      <NavButton Icon="archive" Title="Export" Disabled="true" />
    </NavRail>
  </Rail>
  <ChildContent>
      @if (!loaded)
      {
        <div class="workspace workspace--placeholder">
          <p class="panel-empty-msg">@(error ?? "Loading map…")</p>
        </div>
      }
      else
      {
        @switch (active)
        {
          case "setup":
            <SetupPhase Slug="@Slug" IsFirstPhase="@IsFirstPhase"
                                OnPrevPhase="@(() => GoAdjacent(-1))" OnNextPhase="@(() => GoAdjacent(1))" />
            break;
          case "overview":
            <IdentityPhase Slug="@Slug" OnStatus="OnOverviewStatus" IsFirstPhase="@IsFirstPhase" IsLastPhase="@IsLastPhase"
                               OnPrevPhase="@(() => GoAdjacent(-1))" OnNextPhase="@(() => GoAdjacent(1))" />
            break;
          case "teams":
            <TeamsPhase Slug="@Slug" IsFirstPhase="@IsFirstPhase" IsLastPhase="@IsLastPhase"
                            OnPrevPhase="@(() => GoAdjacent(-1))" OnNextPhase="@(() => GoAdjacent(1))" />
            break;
          case "build-regions":
            <BuildRegionsPhase Slug="@Slug" IsFirstPhase="@IsFirstPhase"
                                   OnPrevPhase="@(() => GoAdjacent(-1))" OnNextPhase="@(() => GoAdjacent(1))" />
            break;
          case "objective":
            <ObjectivePhase Slug="@Slug" IsFirstPhase="@IsFirstPhase" IsLastPhase="@IsLastPhase"
                                OnPrevPhase="@(() => GoAdjacent(-1))" OnNextPhase="@(() => GoAdjacent(1))" />
            break;
          case "regions":
            <RegionsPhase Slug="@Slug" IsFirstPhase="@IsFirstPhase" IsLastPhase="@IsLastPhase"
                              OnPrevPhase="@(() => GoAdjacent(-1))" OnNextPhase="@(() => GoAdjacent(1))" />
            break;
          default:
            <div class="workspace workspace--placeholder">
              <p class="panel-empty-msg">@(TitleOf(active)) — not yet ported.</p>
            </div>
            break;
        }
      }
  </ChildContent>
</StudioShell>
