@namespace PgmStudio.Client.Pages.AuthoringParts

@* Shared real-geometry canvas for the /authoring concept page. Renders thunder's ACTUAL terrain
   islands — 17 polygons from the island detector's `simplified_polygon` exterior (RDP-decimated),
   projected to a 256×256 viewBox (sx = x+128, sy = z+128; thunder world bbox -119..120). The
   per-island team is its nearest team spawn (4 each + 1 contested centre). `Mode` tints the polygons
   to match the activity; `ChildContent` adds overlays (spawn dots, wool rooms, connectivity lines …)
   inside the same svg. Static UI mock — not interactive. *@

<svg viewBox="0 0 256 256" preserveAspectRatio="xMidYMid meet" style="width:100%;height:100%;display:block">
  @if (Axes)
  {
    <line x1="128" y1="0" x2="128" y2="256" stroke="var(--canvas-axis)" stroke-width="0.5" opacity="0.4" />
    <line x1="0" y1="128" x2="256" y2="128" stroke="var(--canvas-axis)" stroke-width="0.5" opacity="0.4" />
  }
  @foreach (var isl in Islands)
  {
    var s = Style(isl.Team);
    <polygon points="@isl.Points" fill="@s.Fill" stroke="@s.Stroke" stroke-width="0.7" />
  }
  @ChildContent
</svg>

@code {
    // neutral (gray shapes) | teams (tint by assignment) | build (green build layer) |
    // buildable (validation green footprint) | surface (traversability walkable green)
    [Parameter] public string Mode { get; set; } = "neutral";
    [Parameter] public bool Axes { get; set; } = true;
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private record Isl(string Team, string Points);

    private static string Hex(string t) => t switch
    {
        "blue" => "#5555FF", "green" => "#55FF55", "red" => "#FF5555", "yellow" => "#FFFF55", _ => ""
    };

    private (string Fill, string Stroke) Style(string team) => Mode switch
    {
        "teams" when team != "center" => ($"color-mix(in oklch, {Hex(team)} 24%, transparent)", Hex(team)),
        "buildable" => ("color-mix(in oklch, var(--canvas-add-fill) 60%, transparent)", "var(--canvas-add-stroke)"),
        "surface"   => ("color-mix(in oklch, var(--color-success) 55%, transparent)", "var(--color-success)"),
        "build"     => ("color-mix(in oklch, var(--canvas-add-fill) 22%, transparent)", "var(--canvas-add-stroke)"),
        _           => ("color-mix(in oklch, var(--canvas-island) 55%, transparent)", "var(--canvas-island-stroke)")
    };

