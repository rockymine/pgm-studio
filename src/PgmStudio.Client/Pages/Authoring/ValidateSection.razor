@namespace PgmStudio.Client.Pages.AuthoringParts

@* Buildability & Traversability — visual checks over thunder's REAL terrain (shared IslandMap), with
   the colour scheme of the reference previews (tools/buildability_preview.py, traversability_preview.py):
   buildability = green buildable / red never / orange void-denied; traversability = green walkable
   surface, blue ● spawn, white ■ wool, red ring = isolated. *@

<section class="ds-section" id="validate">
  <div class="ds-section-heading">
    <div>
      <p class="ds-kicker">Validation</p>
      <h2>Buildability &amp; Traversability</h2>
    </div>
    <p>Two automated checks over the real island geometry — re-run after every Build change; the gate
       routes failures back to Build. Mirrors the reference preview renderers.</p>
  </div>

  <p class="ds-theming-note">
    <strong>Buildability</strong> classifies every column — <em>buildable</em> (the island terrain plus the
    over-void build region), and <em>void-denied</em> across the rest of the map bounding box (no y=0 block to
    build on). <strong>Traversability</strong>
    floods the walkable surface ∪ bridgeable buildable and checks that every spawn reaches every wool. A
    point in a different connected component is the disconnection the check warns about (red ring); it
    blocks export (HTTP&nbsp;409) and routes back to Build.
  </p>

  <div class="ds-example-grid">

    @* ── Buildability ──────────────────────────────────────────────────── *@
    <article class="ds-example">
      <div class="ds-example-label">Buildability — after Build (all bridges present)</div>
      <div class="canvas-surface canvas-surface--svg" style="min-height:320px;border-radius:var(--radius-sm);overflow:hidden">
        <IslandMap Mode="buildable">
          <Backdrop>
            @* void-denied = the whole map bounding box — columns with no y=0 block aren't buildable *@
            <rect x="9" y="9" width="239" height="239" fill="#f59e0b" fill-opacity="0.14" />
          </Backdrop>
          <ChildContent>
            @* buildable REGION = the build rects / bridges (a distinct green over the terrain green) *@
            <g fill="color-mix(in oklch, var(--color-success) 38%, transparent)" stroke="var(--color-success)" stroke-width="0.6">
              <rect x="112" y="112" width="33" height="33" rx="1"/>
              <rect x="40" y="107" width="72" height="42" rx="1"/>
              <rect x="15" y="144" width="57" height="29" rx="1"/>
              <rect x="145" y="108" width="72" height="42" rx="1"/>
              <rect x="185" y="84" width="57" height="29" rx="1"/>
              <rect x="107" y="145" width="42" height="72" rx="1"/>
              <rect x="144" y="185" width="29" height="57" rx="1"/>
              <rect x="108" y="40" width="42" height="72" rx="1"/>
              <rect x="84" y="15" width="29" height="57" rx="1"/>
            </g>
          </ChildContent>
        </IslandMap>
      </div>
      <div class="panel-list" style="padding:var(--space-2) 0 0">
        <div class="list-row list-row--compact list-row--muted"><span class="list-swatch" style="background:var(--canvas-add-fill);border-color:var(--canvas-add-stroke)"></span><span class="list-label">Buildable · terrain</span><span class="list-tag">island surface (void filter)</span></div>
        <div class="list-row list-row--compact list-row--muted"><span class="list-swatch" style="background:var(--color-success);border-color:var(--color-success)"></span><span class="list-label">Buildable · region</span><span class="list-tag">build rects / bridges</span></div>
        <div class="list-row list-row--compact list-row--muted"><span class="list-swatch" style="background:#f59e0b;border-color:#b45309"></span><span class="list-label">Void-denied</span><span class="list-tag">map bbox · no y=0 block</span></div>
      </div>
      <div class="step-row" style="margin-top:var(--space-2)">
        <span class="step-dot step-dot--done"></span>
        <span class="step-label">Buildability</span>
        <span class="step-detail">terrain + build region buildable · the rest of the bbox is void-denied</span>
      </div>
    </article>

    @* ── Traversability ────────────────────────────────────────────────── *@
    <article class="ds-example">
      <div class="ds-example-label">Traversability — connected (left) vs Yellow isolated (right)</div>
      <div class="ds-example-grid" style="gap:var(--space-3)">

        <div>
          <div class="canvas-surface canvas-surface--svg" style="min-height:240px;border-radius:var(--radius-sm);overflow:hidden">
            <IslandMap Mode="surface">
              @* spawn ● blue, wool ■ white — per the reference renderer *@
              <circle cx="34.5" cy="112.5" r="2.6" fill="#1565c0" stroke="white" stroke-width="0.7" />
              <circle cx="222.5" cy="144.5" r="2.6" fill="#1565c0" stroke="white" stroke-width="0.7" />
              <circle cx="112.5" cy="222.5" r="2.6" fill="#1565c0" stroke="white" stroke-width="0.7" />
              <circle cx="144.5" cy="34.5" r="2.6" fill="#1565c0" stroke="white" stroke-width="0.7" />
              <rect x="13" y="134.5" width="5" height="5" fill="white" stroke="black" stroke-width="0.5" />
              <rect x="239" y="118" width="5" height="5" fill="white" stroke="black" stroke-width="0.5" />
              <rect x="134" y="239" width="5" height="5" fill="white" stroke="black" stroke-width="0.5" />
              <rect x="118" y="13" width="5" height="5" fill="white" stroke="black" stroke-width="0.5" />
            </IslandMap>
          </div>
          <div class="step-row" style="margin-top:var(--space-2)">
            <span class="step-dot step-dot--done"></span>
            <span class="step-label">Connected</span>
            <span class="step-detail">1 component · all reachable</span>
          </div>
        </div>

        <div>
          <div class="canvas-surface canvas-surface--svg" style="min-height:240px;border-radius:var(--radius-sm);overflow:hidden">
            <IslandMap Mode="surface">
              @* blue/green/red connected; yellow spawn + wool isolated (red rings) *@
              <circle cx="34.5" cy="112.5" r="2.6" fill="#1565c0" stroke="white" stroke-width="0.7" />
              <circle cx="222.5" cy="144.5" r="2.6" fill="#1565c0" stroke="white" stroke-width="0.7" />
              <circle cx="112.5" cy="222.5" r="2.6" fill="#1565c0" stroke="white" stroke-width="0.7" />
              <circle cx="144.5" cy="34.5" r="2.6" fill="#1565c0" stroke="white" stroke-width="0.7" />
              <rect x="13" y="134.5" width="5" height="5" fill="white" stroke="black" stroke-width="0.5" />
              <rect x="239" y="118" width="5" height="5" fill="white" stroke="black" stroke-width="0.5" />
              <rect x="134" y="239" width="5" height="5" fill="white" stroke="black" stroke-width="0.5" />
              <rect x="118" y="13" width="5" height="5" fill="white" stroke="black" stroke-width="0.5" />
              <circle cx="144.5" cy="34.5" r="6" fill="none" stroke="var(--color-error)" stroke-width="1.4" />
              <circle cx="120.5" cy="15.5" r="6" fill="none" stroke="var(--color-error)" stroke-width="1.4" />
            </IslandMap>
          </div>
          <div class="step-row" style="margin-top:var(--space-2)">
            <span class="step-dot step-dot--error"></span>
            <span class="step-label">Isolated</span>
            <span class="step-detail">2 components · Yellow unreachable</span>
          </div>
        </div>

      </div>

      <div class="panel-list" style="padding:var(--space-3) 0 0">
        <div class="list-row list-row--compact list-row--muted"><span class="list-swatch" style="background:var(--color-success);border-color:var(--color-success)"></span><span class="list-label">Walkable surface</span><span class="list-tag">stand on it</span></div>
        <div class="list-row list-row--compact list-row--muted"><span class="list-swatch" style="background:#1565c0;border-color:#1565c0"></span><span class="list-label">Spawn</span><span class="list-tag">●</span></div>
        <div class="list-row list-row--compact list-row--muted"><span class="list-swatch" style="background:#ffffff;border-color:#000"></span><span class="list-label">Wool</span><span class="list-tag">■ · red ring = isolated</span></div>
      </div>

      <div class="panel-warning" style="margin-top:var(--space-3)">
        <strong>Export blocked.</strong> Yellow spawn (16,&minus;93) and yellow-wool (&minus;7,&minus;112) land in a
        second component — the gap between <code>yellow-main-and-spawn</code> and the centre has no bridge.
        Return to <strong>Build → Buildable layer</strong> and draw the missing rectangle; traversability re-runs on return.
      </div>
    </article>

  </div>
</section>
