@namespace PgmStudio.Client.Pages.AuthoringParts

<section class="ds-section" id="xml">
  <div class="ds-section-heading">
    <div>
      <p class="ds-kicker">05 · Review &amp; Export</p>
      <h2>XML preview &amp; export</h2>
    </div>
    <p>The <strong>final sub-step</strong> of Review &amp; Export: the generated PGM document, segmented into
       containers (pick one on the left to jump to its block — the real serialized output, not a template
       or a diff). Here the flow bar's <strong>Next becomes Export</strong> — enabled only when the
       Pre-flight gate is open (HTTP&nbsp;409 otherwise).</p>
  </div>

  <article class="ds-example">
    <div class="ds-example-label">Review &amp; Export · sub-step 3 — XML (Next = Export)</div>
    <div class="flow-bar">
      <div class="flow-bar-phase"><i data-lucide="badge-check"></i><span>Review &amp; Export</span></div>
      <div class="flow-steps">
        <button class="flow-step flow-step--done"><i data-lucide="check"></i>Pre-flight</button>
        <button class="flow-step flow-step--done"><i data-lucide="check"></i>Region tree</button>
        <button class="flow-step flow-step--active">XML</button>
      </div>
      <div class="flow-bar-actions">
        <button class="action-btn">Back</button>
        <button class="action-btn action-btn--primary"><i data-lucide="download"></i> Export</button>
      </div>
    </div>
    <div class="ds-workspace-frame" style="height:480px">
      <div class="workspace">
        <div class="workspace-sidebar" style="width:184px">
          <div class="workspace-scroll">
            <section class="panel-section">
              <div class="section-header section-header--ruled"><h2 class="section-title">Containers</h2></div>
              <div class="panel-list">
                <div class="list-row list-row--compact"><span class="geo-type-icon"><i data-lucide="users"></i></span><span class="list-label">Teams</span><span class="list-tag">4</span></div>
                <div class="list-row list-row--compact"><span class="geo-type-icon"><i data-lucide="dot"></i></span><span class="list-label">Spawns</span><span class="list-tag">4</span></div>
                <div class="list-row list-row--compact"><span class="geo-type-icon"><i data-lucide="square"></i></span><span class="list-label">Wools</span><span class="list-tag">4</span></div>
                <div class="list-row list-row--compact list-row--selected"><span class="geo-type-icon"><i data-lucide="shapes"></i></span><span class="list-label">Regions</span><span class="list-tag">49</span></div>
                <div class="list-row list-row--compact"><span class="geo-type-icon"><i data-lucide="filter"></i></span><span class="list-label">Filters</span><span class="list-tag">35</span></div>
                <div class="list-row list-row--compact"><span class="geo-type-icon"><i data-lucide="zap"></i></span><span class="list-label">Apply rules</span><span class="list-tag">16</span></div>
              </div>
            </section>
          </div>
        </div>
        <div class="sidebar-handle"></div>
        <div class="workspace-canvas" style="background:var(--bg-base)">
          <div class="workspace-scroll">
            <pre class="detail-xml-pre">&lt;regions&gt;
  &lt;!-- Spawn cylinders (synthetic ids — generated by orbit-fill) --&gt;
  &lt;cylinder id="__spawn_blue__anon_0"   base="-93.5,7,-15.5" radius="1" height="0"/&gt;
  &lt;cylinder id="__spawn_green__anon_0"  base="94.5,7,16.5"   radius="1" height="0"/&gt;
  &lt;cylinder id="__spawn_red__anon_0"    base="-15.5,7,94.5"  radius="1" height="0"/&gt;
  &lt;cylinder id="__spawn_yellow__anon_0" base="16.5,7,-93.5"  radius="1" height="0"/&gt;

  &lt;!-- Spawn + monument protection rectangles --&gt;
  &lt;rectangle id="blue-spawn-protect"      min="-99,-21" max="-81,-9"/&gt;
  &lt;rectangle id="green-spawn-protect"     min="82,10"   max="100,22"/&gt;
  &lt;rectangle id="red-spawn-protect"       min="-21,82"  max="-9,100"/&gt;
  &lt;rectangle id="yellow-spawn-protect"    min="10,-99"  max="22,-81"/&gt;
  &lt;rectangle id="blue-monument-protect"   min="-73,-20" max="-70,-13"/&gt;
  &lt;!-- …green / red / yellow monument-protect… --&gt;
  &lt;union id="spawns-and-monuments"&gt;
    &lt;region id="blue-spawn-protect"/&gt;   &lt;region id="green-spawn-protect"/&gt;
    &lt;region id="red-spawn-protect"/&gt;    &lt;region id="yellow-spawn-protect"/&gt;
    &lt;region id="blue-monument-protect"/&gt; …
  &lt;/union&gt;

  &lt;!-- Wool room rectangles + union --&gt;
  &lt;rectangle id="blue-wool"   min="-119,2"   max="-105,19"/&gt;
  &lt;rectangle id="green-wool"  min="106,-18"  max="120,-1"/&gt;
  &lt;rectangle id="red-wool"    min="2,106"    max="19,120"/&gt;
  &lt;rectangle id="yellow-wool" min="-18,-119" max="-1,-105"/&gt;
  &lt;union id="wools"&gt;
    &lt;region id="blue-wool"/&gt;  &lt;region id="green-wool"/&gt;
    &lt;region id="red-wool"/&gt;   &lt;region id="yellow-wool"/&gt;
  &lt;/union&gt;

  &lt;!-- Build areas wrapped in the void-deny negative --&gt;
  &lt;rectangle id="center-island"       min="-16,-16" max="17,17"/&gt;
  &lt;rectangle id="blue-main-and-spawn" min="-88,-21" max="-16,21"/&gt;
  &lt;rectangle id="blue-two-islands"    min="-113,16" max="-56,45"/&gt;
  &lt;!-- …green / red / yellow main-and-spawn + two-islands… --&gt;
  &lt;negative id="deny-blocks"&gt;
    &lt;union id="deny-blocks__anon_0"&gt;
      &lt;region id="center-island"/&gt;
      &lt;region id="blue-main-and-spawn"/&gt; … &lt;region id="yellow-two-islands"/&gt;
    &lt;/union&gt;
  &lt;/negative&gt;

  &lt;!-- Wool capture points (12 × point — 3 per wool, one per opposing team) --&gt;
  &lt;point id="wool-capture-points__anon_0"&gt;-18,8,73&lt;/point&gt;
  &lt;point id="wool-capture-points__anon_3"&gt;-73,8,-18&lt;/point&gt;
  &lt;!-- …10 more… --&gt;
  &lt;union id="wool-capture-points"&gt; … &lt;/union&gt;
&lt;/regions&gt;</pre>
          </div>
        </div>
      </div>
    </div>
  </article>

  <div class="ds-example-grid" style="margin-top:var(--space-5)">
    <article class="ds-example">
      <div class="ds-example-label">Teams (4)</div>
      <pre class="detail-xml-pre">&lt;teams&gt;
  &lt;team id="blue"   color="blue"     max="12"&gt;Blue&lt;/team&gt;
  &lt;team id="green"  color="green"    max="12"&gt;Green&lt;/team&gt;
  &lt;team id="red"    color="dark red" max="12"&gt;Red&lt;/team&gt;
  &lt;team id="yellow" color="yellow"   max="12"&gt;Yellow&lt;/team&gt;
&lt;/teams&gt;</pre>
    </article>

    <article class="ds-example">
      <div class="ds-example-label">Spawns (4 + observer)</div>
      <pre class="detail-xml-pre">&lt;spawns&gt;
  &lt;spawn team="blue"   kit="spawn-kit" yaw="0" region="__spawn_blue__anon_0"/&gt;
  &lt;spawn team="green"  kit="spawn-kit" yaw="0" region="__spawn_green__anon_0"/&gt;
  &lt;spawn team="red"    kit="spawn-kit" yaw="0" region="__spawn_red__anon_0"/&gt;
  &lt;spawn team="yellow" kit="spawn-kit" yaw="0" region="__spawn_yellow__anon_0"/&gt;
  &lt;default yaw="0" region="__observer_spawn__anon_0"/&gt;
&lt;/spawns&gt;</pre>
    </article>

    <article class="ds-example">
      <div class="ds-example-label">Wools (4 colours · 3 monuments each)</div>
      <pre class="detail-xml-pre">&lt;wools&gt;
  &lt;wool color="blue" location="-112.5,10,8.5"&gt;
    &lt;monument&gt;&lt;block&gt;72,18,18&lt;/block&gt;&lt;/monument&gt;  &lt;!-- green --&gt;
    &lt;monument&gt;&lt;block&gt;-18,8,73&lt;/block&gt;&lt;/monument&gt;  &lt;!-- red --&gt;
    &lt;monument&gt;&lt;block&gt;18,8,-71&lt;/block&gt;&lt;/monument&gt;  &lt;!-- yellow --&gt;
  &lt;/wool&gt;
  &lt;!-- green / red / yellow wools follow (orbit-filled) --&gt;
&lt;/wools&gt;</pre>
    </article>

    <article class="ds-example">
      <div class="ds-example-label">Apply rules (16)</div>
      <pre class="detail-xml-pre">&lt;apply enter="only-blue"  region="blue-spawn-protect"
       message="You may not enter the enemy's spawn!"/&gt;
&lt;apply block="never"      region="spawns-and-monuments"
       message="You may not block/break spawns or monuments!"/&gt;
&lt;apply enter="not-blue"   region="blue-wool"
       message="You may not enter your own wool room!"/&gt;
&lt;apply block="blue-wool-edit" use="not-blue" region="blue-wool"
       message="You may not modify the wool room!"/&gt;
&lt;apply block="no-void"    region="deny-blocks"
       message="You may not edit the void!"/&gt;</pre>
    </article>
  </div>
</section>
