@page "/maps"
@layout StudioLayout
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>PGM Studio — @StageTitle</PageTitle>

@* Staged map collection — one overview, scoped by ?stage=sketch|configure|edit (default edit). The
   activity rail switches stage; each stage lists its maps with the matching resume target and a
   stage-appropriate "start" action. Reached from the landing cards. *@

<StudioShell>
  <Bar>
    <Topbar HomeHref="/" HomeLabel="Studio" HomeTitle="Studio home">
      <Crumbs><Crumb Dim>@StageTitle</Crumb></Crumbs>
    </Topbar>
  </Bar>
  <Rail>
    <NavRail LogoHref="/" LogoTitle="Studio home">
      <NavButton Icon="pencil-ruler" Title="Sketches" Href="maps?stage=sketch" Active="CurrentStage == MapStage.Sketch" />
      <NavButton Icon="settings-2" Title="Configuring" Href="maps?stage=configure" Active="CurrentStage == MapStage.Configure" />
      <NavButton Icon="map" Title="Maps" Href="maps" Active="CurrentStage == MapStage.Edit" />
    </NavRail>
  </Rail>
  <Footer>
    <AppFooter>
      <AppFooterLink Href="design" Icon="palette">Design</AppFooterLink>
      <a class="app-footer-link" href="https://github.com/rockymine/pgm-studio" target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 012-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"></path>
        </svg><span>GitHub</span>
      </a>
    </AppFooter>
  </Footer>
  <ChildContent>
      <Workspace>
        <ContentColumn MaxWidth="960">

          @if (Just is not null && JustMap is not null)
          {
            <div class="callout">
              <span class="callout-icon"><i data-lucide="check-circle-2"></i></span>
              <p><strong>@JustMap.Name</strong> is rasterized and saved — ready to configure into a
                playable <code>map.xml</code> whenever you are.</p>
              <Button Variant="primary" Href="@($"maps/{Just}/configure")" style="margin-left:auto;">
                <i data-lucide="settings-2"></i><span>Continue to Configure</span>
              </Button>
            </div>
          }

          <Section Title="@StageTitle">
            <Actions>
              <Badge Kind="dim">@(maps?.Count ?? 0)</Badge>
              @if (CurrentStage == MapStage.Sketch)
              {
                <Button Variant="primary" OnClick="NewSketch" Icon="plus" Class="action-btn--push-end" Disabled="@creatingSketch">New sketch</Button>
              }
              else if (CurrentStage == MapStage.Configure)
              {
                <Button Variant="primary" Href="maps/new" Icon="import" Class="action-btn--push-end">Import a world</Button>
              }
            </Actions>
            <Description>@StageBlurb</Description>
            <ChildContent>

            <input class="field-input" placeholder="Search…" @bind="filter" @bind:event="oninput" style="margin-top: var(--space-3);" />

            <div class="panel-list" style="margin-top: var(--space-3);">
              @if (maps is null) { <div class="list-empty">Loading…</div> }
              else if (!Filtered.Any()) { <div class="list-empty">@EmptyMessage</div> }
              else
              {
                @foreach (var m in Filtered)
                {
                  <ListRow Href="@($"maps/{m.Slug}/{RowMode}")" Selected="m.Slug == Just" @key="m.Slug">
                    <span class="list-label list-label--mono">@m.Slug</span>
                    <span class="list-label">@m.Name</span>
                    @if (CurrentStage == MapStage.Edit)
                    {
                      @* one tag per gamemode: a map can be more than one, and a map with no objective
                         module we read carries none rather than a blank tag *@
                      @foreach (var g in m.Gamemodes) { <span class="list-tag">@g.ToUpperInvariant()</span> }
                      @if (!string.IsNullOrEmpty(m.Version)) { <span class="list-tag">@($"v{m.Version}")</span> }
                    }
                    <span class="list-go"><i data-lucide="arrow-right"></i></span>
                  </ListRow>
                }
              }
            </div>
            </ChildContent>
          </Section>
        </ContentColumn>
      </Workspace>
  </ChildContent>
</StudioShell>
