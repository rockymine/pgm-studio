@page "/generator"
@layout EditorLayout
@implements IAsyncDisposable

@* Generator browse (G117): compose boards interactively, sieve them, and pin the keepers. Cards are
   server-rendered SVGs of the full fanned board; pin/open re-compose from the reproducible descriptor. *@

<div class="editor-page">
  <div id="topbar" class="topbar">
    <a href="/" class="topbar-breadcrumb-home" title="Studio home">
      <i data-lucide="house"></i><span>Studio</span>
    </a>
    <span class="topbar-sep">›</span>
    <span class="topbar-crumb topbar-crumb--dim">Generator</span>
    <div class="topbar-right">
      <Button Href="/plan-editor" Icon="layout-grid" Title="Open the plan editor">Plan editor</Button>
      <ThemeToggle />
    </div>
  </div>

  <div class="gen-body">
    <aside class="gen-filters">
      <Section Title="Filters">

        <Field Label="Players / team">
          <LabelEnd><strong>@players</strong></LabelEnd>
          <ChildContent>
            <input type="range" class="field-range" min="6" max="30" step="2" value="@players" @oninput="OnPlayers" />
          </ChildContent>
        </Field>

        <Field Label="Symmetry">
          <div class="filter-group-options">
            @foreach (var s in Symmetries)
            {
              <Chip Active="symmetry == s.Id" Disabled="!s.Supported"
                    Title="@(s.Supported ? s.Label : "the composer can't produce this yet")"
                    OnClick="() => PickSymmetry(s.Id)">@s.Label</Chip>
            }
          </div>
        </Field>

        <Field Label="Max score">
          <LabelEnd><strong>@(maxScore >= ScoreCap ? "any" : maxScore.ToString("0.0"))</strong></LabelEnd>
          <ChildContent>
            <input type="range" class="field-range" min="0" max="8" step="0.5" value="@maxScore" @oninput="OnMaxScore" />
          </ChildContent>
        </Field>

        <Field Label="Wool count">
          <div class="gen-wool">
            <input type="number" min="0" max="6" value="@woolMin" @oninput="OnWoolMin" title="min (0 = any)" />
            <span>–</span>
            <input type="number" min="0" max="6" value="@woolMax" @oninput="OnWoolMax" title="max (0 = any)" />
          </div>
        </Field>

        <Button Variant="primary" Full OnClick="Reload">Apply</Button>
        <p class="section-desc">Players / score / wool count apply on the button. Structure filters below apply on click.</p>

        <Field Label="Wool families">
          <LabelEnd><span class="text-xs text-muted">all present</span></LabelEnd>
          <ChildContent>
            <div class="filter-group-options">
              @foreach (var w in WoolChips)
              {
                <Chip Active="woolFilter.Contains(w.Token)" Disabled="!w.InMix"
                      Title="@(w.InMix ? w.Label : "not in the production mix")"
                      OnClick="() => ToggleWool(w.Token)">@w.Label</Chip>
              }
            </div>
          </ChildContent>
        </Field>

        <Field Label="Hub form">
          <LabelEnd><span class="text-xs text-muted">any of</span></LabelEnd>
          <ChildContent>
            <div class="filter-group-options">
              @foreach (var h in HubChips)
              {
                <Chip Active="hubFilter.Contains(h.Token)" OnClick="() => ToggleHub(h.Token)">@h.Label</Chip>
              }
            </div>
          </ChildContent>
        </Field>

        <Field Label="Frontline">
          <LabelEnd><span class="text-xs text-muted">any of</span></LabelEnd>
          <ChildContent>
            <div class="filter-group-options">
              @foreach (var f in FrontChips)
              {
                <Chip Active="frontFilter.Contains(f.Token)" OnClick="() => ToggleFront(f.Token)">@f.Label</Chip>
              }
            </div>
          </ChildContent>
        </Field>

      </Section>
    </aside>

    <main class="gen-main">
      @if (pinned.Count > 0)
      {
        <div class="gen-tray">
          <span class="gen-tray-label"><i data-lucide="pin"></i> Held · @pinned.Count</span>
          <div class="gen-tray-items">
            @foreach (var p in pinned)
            {
              <div class="gen-tray-chip">
                <a class="gen-tray-fig" href="@($"/plan-editor?plan={p.Id}")" title="Open in plan editor">
                  @if (traySvg.TryGetValue(p.Id, out var s)) { @((MarkupString)s) }
                </a>
                <span class="gen-tray-name" title="@p.Name">@p.Name</span>
                <button class="gen-tray-x" @onclick="() => Unpin(p.Id)" title="Unpin"><i data-lucide="x"></i></button>
              </div>
            }
          </div>
        </div>
      }

      @if (StructuralActive)
      {
        <p class="gen-scanned">scanned @totalScanned · matched @cards.Count@(totalScanned > 0 && cards.Count * 12 < totalScanned ? " — rare mix; a candidate to promote to a held target" : "")</p>
      }

      <div class="gen-grid">
        @foreach (var card in cards)
        {
          <div class="gen-card @(IsPinned(card) ? "gen-card--pinned" : null)">
            <div class="gen-card-badges" title="Structure — filter from the sidebar">
              @foreach (var w in card.Structure.Wools.Distinct())
              {
                <span class="gen-badge gen-badge--wool">@w</span>
              }
              <span class="gen-badge gen-badge--hub">@card.Structure.Hub</span>
              <span class="gen-badge gen-badge--front">@card.Structure.Frontline</span>
            </div>
            <button class="gen-card-fig" @onclick="() => OpenDetail(card)" title="Open details">
              @((MarkupString)card.Svg)
            </button>
            <div class="gen-card-foot">
              <span class="gen-card-score" title="Evaluator score — lower is better">@card.Score.ToString("0.0")</span>
              <span class="gen-card-meta">@card.WoolCount wool · #@card.Descriptor.Seed</span>
              <button class="gen-pin @(IsPinned(card) ? "gen-pin--on" : null)" @onclick="() => TogglePin(card)"
                      title="@(IsPinned(card) ? "Unpin" : "Pin to hold tray")"><i data-lucide="pin"></i></button>
            </div>
          </div>
        }
      </div>

      @if (feedError is not null) { <p class="gen-status">@feedError</p> }
      else if (loading) { <p class="gen-status">Composing…</p> }
      else if (cards.Count == 0) { <p class="gen-status">No boards match these filters.</p> }
      else if (exhausted) { <p class="gen-status">End of the run for these filters.</p> }

      <div @ref="sentinelRef" class="gen-sentinel"></div>
      @if (!exhausted && !loading && cards.Count > 0)
      {
        <Button Full Class="gen-more" OnClick="LoadMore">Load more</Button>
      }
    </main>
  </div>

  @if (detail is { } d)
  {
    <SideDrawer Open="true" Title="Board detail" Icon="layout-grid" OnClose="CloseDetail">
      <Body>
        <div class="gen-detail-fig">@((MarkupString)d.Svg)</div>
        <div class="gen-detail-meta">
          Score <strong>@d.Score.ToString("0.00")</strong> · @d.WoolCount wool ·
          @d.Descriptor.Players players · @d.Descriptor.Symmetry · seed @d.Descriptor.Seed
        </div>
        <div class="gen-detail-meta">
          <strong>@string.Join(", ", d.Structure.Wools)</strong> wools · hub <strong>@d.Structure.Hub</strong> · frontline <strong>@d.Structure.Frontline</strong>
        </div>
        @if (d.HardTerms.Count > 0)
        {
          <div class="plan-compile-errors"><p class="section-desc">hard terms fired: @string.Join(", ", d.HardTerms)</p></div>
        }
        @if (d.TopSoft.Count > 0)
        {
          <div class="plan-lint-list">
            @foreach (var t in d.TopSoft)
            {
              <div class="plan-lint-row plan-lint-row--static">
                <span class="plan-lint-chip">@t.TermId</span>
                <span class="plan-lint-msg">@t.Contribution.ToString("0.00")</span>
              </div>
            }
          </div>
        }
        <pre class="gen-descriptor">@DescriptorJson(d)</pre>
      </Body>
      <Footer>
        <Button Full Icon="clipboard" OnClick="() => CopyDescriptor(d)">Copy descriptor</Button>
        <Button Full OnClick="() => TogglePin(d)">@(IsPinned(d) ? "Unpin" : "Pin to hold tray")</Button>
        <Button Variant="primary" Full Icon="external-link" OnClick="() => OpenInEditor(d)">Open in plan editor</Button>
      </Footer>
    </SideDrawer>
  }
</div>
