@page "/maps/{Slug}/sketch"
@layout StudioLayout
@inject IJSRuntime JS
@inject HttpClient Http
@inject NavigationManager Nav
@implements IAsyncDisposable

@* Sketch tool — Layout step. Blazor renders the topbar + toolbar + svg shell; the reused SketchCanvas
   JS (via bridge/sketch-bridge.js) owns drawing, the live island computation, and the mirror preview.
   Persistence (load/save) is wired in S2d; this step is the draw + live-islands experience. *@

<StudioShell>
  <Bar>
    <Topbar HomeHref="maps?stage=sketch" HomeLabel="Sketches" HomeTitle="Back to sketches">
      <Crumbs>
        <Crumb>@Slug.Replace('_', ' ')</Crumb>
        <Crumb Dim>Sketch</Crumb>
      </Crumbs>
      <Right>
        @if (finishError is not null) { <span class="topbar-crumb topbar-crumb--dim">@finishError</span> }
        <span class="topbar-crumb topbar-crumb--dim">@islandLabel</span>
      </Right>
    </Topbar>
  </Bar>
  <Rail>
    <NavRail LogoHref="/" LogoTitle="Studio home">
      <NavButton Icon="book-open-text" Title="Info" Active="@InfoActive" OnClick="GoInfo" />
      <NavButton Icon="pencil-ruler" Title="Draw" Active="@DrawActive" OnClick="GoDraw" />
    </NavRail>
  </Rail>
  <ChildContent>
      @if (InfoActive)
      {
        <SketchInfoPhase Slug="@Slug" OnNext="GoDraw"
                         Mode="@mode" CenterX="@centerX" CenterZ="@centerZ"
                         OnModeChange="OnModeChange" OnCenterX="OnCenterX" OnCenterZ="OnCenterZ" />
      }
      @* Draw stays mounted (hidden, not removed) so the canvas bridge + zoom/draw state survive a trip
         to Info; [hidden] is display:none, and SetPhase re-measures the canvas on return. *@
      <div class="phase-body" hidden="@(!DrawActive)">
      <FlowBar Class="flow-bar--flush" PhaseIcon="pencil-ruler" PhaseTitle="Draw"
               BackEnabled="true" NextLabel="Finish" NextEnabled="@(!finishing)"
               OnBack="GoInfo" OnNext="Finish" />
      <Workspace>
        <Sidebar>
            <SketchLayers Layers="layerRows" ActiveId="@activeLayerId" OnSelect="SelectLayer" OnAdd="AddLayer"
                          OnDelete="DeleteLayer" OnRename="RenameLayer" OnSetBaseY="SetLayerBaseY" />
            <SketchLibrary Items="libraryItems" OnArm="ArmPlace" />
            <SketchPanel Islands="islands" Shapes="shapes" SelectedShapeId="selectedShapeId" SelectedIslandId="selectedIslandId"
                         OnSelectShape="SelectShape" OnSelectIsland="SelectIsland" />
        </Sidebar>
        <div class="sidebar-handle"></div>
        <div class="workspace-canvas">
          <div class="canvas-subbar">
            <div class="canvas-toolbar">
              <button class="draw-tool-btn @(tool == "move" ? "draw-tool-btn--active" : null)" title="Move / pan"
                      @onclick='() => SetTool("move")'><i data-lucide="hand"></i></button>
              <button class="draw-tool-btn @(tool == "select" ? "draw-tool-btn--active" : null)" title="Select / edit"
                      @onclick='() => SetTool("select")'><i data-lucide="mouse-pointer-2"></i></button>
              <button class="draw-tool-btn @(tool == "rectangle" ? "draw-tool-btn--active" : null)" title="Rectangle"
                      @onclick='() => SetTool("rectangle")'><i data-lucide="rectangle-horizontal"></i></button>
              <button class="draw-tool-btn @(tool == "circle" ? "draw-tool-btn--active" : null)" title="Circle"
                      @onclick='() => SetTool("circle")'><i data-lucide="circle"></i></button>
              <button class="draw-tool-btn @(tool == "polygon" ? "draw-tool-btn--active" : null)" title="Polygon (click vertices, double-click to close)"
                      @onclick='() => SetTool("polygon")'><i data-lucide="pentagon"></i></button>
              <button class="draw-tool-btn @(tool == "lasso" ? "draw-tool-btn--active" : null)" title="Lasso (hold and trace)"
                      @onclick='() => SetTool("lasso")'><i data-lucide="lasso"></i></button>
              <button class="draw-tool-btn @(tool == "measure" ? "draw-tool-btn--active" : null)" title="Measure (drag across a void gap to read its length in blocks)"
                      @onclick='() => SetTool("measure")'><i data-lucide="ruler"></i></button>
              <button class="draw-tool-btn @(tool == "split" ? "draw-tool-btn--active" : null)" title="Split (click two points to slice a shape in two along the line)"
                      @onclick='() => SetTool("split")'><i data-lucide="scissors"></i></button>
              <button class="draw-tool-btn @(op == "add" ? "draw-tool-btn--op-add" : null)" title="Add — shapes build land"
                      @onclick='() => SetOperation("add")'><i data-lucide="plus"></i><span class="draw-tool-label">Add</span></button>
              <button class="draw-tool-btn @(op == "subtract" ? "draw-tool-btn--op-sub" : null)" title="Subtract — shapes carve land away"
                      @onclick='() => SetOperation("subtract")'><i data-lucide="minus"></i><span class="draw-tool-label">Sub</span></button>
            </div>
            <div @ref="coordsRef" class="canvas-cursor"></div>
            <div @ref="dimRef" class="canvas-dim"></div>
            <div class="canvas-subbar-right">
              <Chip Active="mirrorOn" Title="Show the mirrored copies"
                    OnClick="ToggleMirror">Mirror</Chip>
              <Chip Active="shapesOn" Title="Show the draw primitives over the islands"
                    OnClick="ToggleShapes">Shapes</Chip>
              <Chip Active="chunksOn" Title="Show the 16-block chunk grid"
                    OnClick="ToggleChunks">Chunks</Chip>
              <Chip Active="snapOn" Title="Snap shapes to other shapes' edges while dragging (Alt bypasses)"
                    OnClick="ToggleSnap">Snap</Chip>
              <Chip Title="Fit the working bounds" OnClick="OnFit"><i data-lucide="scan"></i></Chip>
              <Chip Active="threeD" Disabled="@isoUnavailable"
                    Title="@(isoUnavailable ? "3-D preview needs WebGL, which isn't available in this browser" : "Isometric height preview (read-only)")"
                    OnClick="Toggle3D">3D</Chip>
              @if (isoUnavailable)
              {
                <span class="canvas-zoom" title="The 3-D height preview needs WebGL, which this browser can't provide.">no WebGL</span>
              }
              @if (threeD)
              {
                <Chip Title="Rotate the preview 90°" OnClick="RotateIso"><i data-lucide="rotate-cw"></i></Chip>
              }
              <span @ref="zoomRef" class="canvas-zoom">—</span>
            </div>
          </div>
          <div @ref="wrapRef" class="svg-area">
            <svg @ref="svgRef" class="map-canvas-svg" xmlns="http://www.w3.org/2000/svg"></svg>
          </div>
        </div>
        <div class="sidebar-handle"></div>
        <SketchInspector Shape="SelectedShape" Island="SelectedIsland" Shapes="shapes"
                         OnToggleOp="ToggleOp" OnToggleOverride="ToggleOverride" OnDeleteShape="DeleteShape"
                         OnPromoteShape="PromoteShape" OnSetHeight="SetHeight" OnToggleMirrors="ToggleMirrors" OnRenameIsland="RenameIsland"
                         OnRotate="Rotate"
                         SelectedVertexIdx="selectedVertexIdx" SelectedVertexHeight="selectedVertexHeight" OnSetVertexHeight="SetVertexHeight" />
      </Workspace>
      </div>
  </ChildContent>
</StudioShell>
