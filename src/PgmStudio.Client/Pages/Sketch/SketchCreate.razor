@page "/maps/new-sketch"
@layout EditorLayout
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav

@* New-sketch landing — the full-screen creation entry for the Sketch stage (the Configure stage has the
   matching /maps/new). Name the map and set its footprint + symmetry; Continue creates the draft and
   opens the editor at /maps/{slug}/sketch. *@

<StudioShell>
  <Bar>
    <Topbar HomeHref="/" HomeLabel="Studio" HomeTitle="Studio home">
      <Crumbs>
        <Crumb Href="maps?stage=sketch">Sketches</Crumb>
        <Crumb Dim>New sketch</Crumb>
      </Crumbs>
    </Topbar>
  </Bar>
  <Rail>
    <ActivityRail LogoHref="/" LogoTitle="Studio home">
      <ActivityButton Icon="pencil-ruler" Title="Sketches" Href="maps?stage=sketch" Active="true" />
      <ActivityButton Icon="settings-2" Title="Configuring" Href="maps?stage=configure" />
      <ActivityButton Icon="map" Title="Maps" Href="maps" />
    </ActivityRail>
  </Rail>
  <ChildContent>
      <div class="workspace">
        <div class="workspace-scroll" style="max-width: 760px; margin: 0 auto;">

          <section class="panel-section">
            <div class="section-header section-header--ruled"><h2 class="section-title">Identity</h2></div>
            <div class="section-body">
              <div class="field">
                <label class="field-label">Map name</label>
                <input class="field-input" @bind="sketchName" @bind:event="oninput" placeholder="My CTW Map"
                       @onkeydown="@(e => { if (e.Key == "Enter") _ = Submit(); })" />
              </div>
            </div>
          </section>

          <div class="cfg-step-panel">
              <section class="panel-section">
                <div class="section-header section-header--ruled"><h2 class="section-title">Footprint</h2></div>
                <div class="section-body">
                  <div class="choice-row">
                    <button class="choice-tile @(preset == "landscape" ? "choice-tile--active" : null)"
                            title="2-team landscape — 120×80" @onclick='() => SetPreset("landscape")'>
                      <svg class="choice-thumb" viewBox="0 0 24 24"><rect class="choice-fill" x="3" y="6" width="18" height="12" /></svg>
                      <span class="choice-name">Landscape</span>
                    </button>
                    <button class="choice-tile @(preset == "portrait" ? "choice-tile--active" : null)"
                            title="2-team portrait — 80×120" @onclick='() => SetPreset("portrait")'>
                      <svg class="choice-thumb" viewBox="0 0 24 24"><rect class="choice-fill" x="6" y="3" width="12" height="18" /></svg>
                      <span class="choice-name">Portrait</span>
                    </button>
                    <button class="choice-tile @(preset == "square" ? "choice-tile--active" : null)"
                            title="Square — 4-team / D2 — 120×120" @onclick='() => SetPreset("square")'>
                      <svg class="choice-thumb" viewBox="0 0 24 24"><rect class="choice-fill" x="4" y="4" width="16" height="16" /></svg>
                      <span class="choice-name">Square</span>
                    </button>
                    <button class="choice-tile @(preset == "custom" ? "choice-tile--active" : null)"
                            title="Custom — set the width and depth below" @onclick='() => SetPreset("custom")'>
                      <svg class="choice-thumb" viewBox="0 0 24 24"><rect class="choice-outline" x="4" y="6" width="16" height="12" /></svg>
                      <span class="choice-name">Custom</span>
                    </button>
                  </div>
                  <div class="field">
                    <label class="field-label">Size (blocks)</label>
                    <div class="ctrl-row">
                      <div class="coord-field"><span class="coord-prefix">W</span><NumberField Value="width" ValueChanged="OnWidth" Min="16" Step="8" CssClass="coord-input" /></div>
                      <div class="coord-field"><span class="coord-prefix">D</span><NumberField Value="depth" ValueChanged="OnDepth" Min="16" Step="8" CssClass="coord-input" /></div>
                    </div>
                  </div>
                </div>
              </section>

              <section class="panel-section">
                <div class="section-header section-header--ruled"><h2 class="section-title">Symmetry</h2></div>
                <div class="section-body">
                  <div class="choice-row">
                    <button class="choice-tile @(mode == "mirror_x" ? "choice-tile--active" : null)"
                            title="Mirror X — reflect left ↔ right across a vertical axis" @onclick='() => SetMode("mirror_x")'>
                      <svg class="choice-thumb" viewBox="0 0 24 24">
                        <line class="choice-axis" x1="12" y1="3" x2="12" y2="21" />
                        <polygon class="choice-fill" points="3,8 9,12 3,16" />
                        <polygon class="choice-fill" points="21,8 15,12 21,16" />
                      </svg>
                      <span class="choice-name">Mirror X</span>
                    </button>
                    <button class="choice-tile @(mode == "mirror_z" ? "choice-tile--active" : null)"
                            title="Mirror Z — reflect top ↔ bottom across a horizontal axis" @onclick='() => SetMode("mirror_z")'>
                      <svg class="choice-thumb" viewBox="0 0 24 24">
                        <line class="choice-axis" x1="3" y1="12" x2="21" y2="12" />
                        <polygon class="choice-fill" points="8,3 12,9 16,3" />
                        <polygon class="choice-fill" points="8,21 12,15 16,21" />
                      </svg>
                      <span class="choice-name">Mirror Z</span>
                    </button>
                    <button class="choice-tile @(mode == "rot_180" ? "choice-tile--active" : null)"
                            title="Rotate 180° — 2-fold point symmetry" @onclick='() => SetMode("rot_180")'>
                      <svg class="choice-thumb" viewBox="0 0 24 24">
                        <polygon class="choice-fill" points="4,4 11,4 4,11" />
                        <polygon class="choice-fill" points="20,20 13,20 20,13" />
                        <circle class="choice-dot" cx="12" cy="12" r="1.4" />
                      </svg>
                      <span class="choice-name">Rotate 180°</span>
                    </button>
                    <button class="choice-tile @(mode == "rot_90" ? "choice-tile--active" : null)"
                            title="Rotate 90° — 4-fold symmetry (4 teams / D2)" @onclick='() => SetMode("rot_90")'>
                      <svg class="choice-thumb" viewBox="0 0 24 24">
                        <polygon class="choice-fill" points="4,4 10,4 4,10" />
                        <polygon class="choice-fill" points="20,4 20,10 14,4" />
                        <polygon class="choice-fill" points="20,20 14,20 20,14" />
                        <polygon class="choice-fill" points="4,20 4,14 10,20" />
                        <circle class="choice-dot" cx="12" cy="12" r="1.4" />
                      </svg>
                      <span class="choice-name">Rotate 90°</span>
                    </button>
                  </div>
                  <div class="field">
                    <label class="field-label">Centre</label>
                    <div class="ctrl-row">
                      <div class="coord-field"><span class="coord-prefix">X</span><NumberField Value="centerX" ValueChanged="@(v => centerX = v)" CssClass="coord-input" /></div>
                      <div class="coord-field"><span class="coord-prefix">Z</span><NumberField Value="centerZ" ValueChanged="@(v => centerZ = v)" CssClass="coord-input" /></div>
                    </div>
                  </div>
                </div>
              </section>
          </div>

          <div class="section-footer">
            <button class="action-btn action-btn--primary" @onclick="Submit" disabled="@busy">Continue</button>
            @if (createError is not null) { <span class="field-error">@createError</span> }
          </div>

        </div>
      </div>
  </ChildContent>
</StudioShell>
