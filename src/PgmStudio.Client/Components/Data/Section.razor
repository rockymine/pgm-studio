@namespace PgmStudio.Client.Components

@* The canonical panel section — a .panel-section stack of an optional header (SectionHeader built
   from Title/Variant + the Actions right slot, or a full Header override), an optional Description
   paragraph, the body (ChildContent), and an optional Footer (.section-footer). panel-section is a
   flex column with gap, so header/desc/body/footer space themselves. *@

<section class="@Cls">
    @if (Header is not null)
    {
        @Header
    }
    else if (!string.IsNullOrEmpty(Title) || Actions is not null)
    {
        <SectionHeader Variant="@Variant" Title="@Title">@Actions</SectionHeader>
    }
    @if (Description is not null) { <p class="section-desc">@Description</p> }
    @ChildContent
    @if (Footer is not null) { <div class="@FooterCls">@Footer</div> }
</section>

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Variant { get; set; } = "ruled";   // header context: ruled | list | plain
    [Parameter] public RenderFragment? Description { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }      // header right slot
    [Parameter] public RenderFragment? Header { get; set; }       // overrides Title/Actions entirely
    [Parameter] public RenderFragment? Footer { get; set; }
    [Parameter] public string? FooterClass { get; set; }          // e.g. section-footer--end / --separated
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private string Cls => string.Join(' ', new[] { "panel-section", Class }.Where(c => !string.IsNullOrEmpty(c)));
    private string FooterCls => string.Join(' ', new[] { "section-footer", FooterClass }.Where(c => !string.IsNullOrEmpty(c)));
}
