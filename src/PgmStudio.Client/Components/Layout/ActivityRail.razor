@namespace PgmStudio.Client.Components

@* The left activity rail — the pgm/STUDIO logo box (a link when LogoHref is set, else static) above
   the activity buttons (ChildContent — compose with <ActivityButton>). *@

<nav class="activity-rail">
    @if (LogoHref is not null)
    {
        <a class="activity-logo" href="@LogoHref" title="@LogoTitle">
            <div class="activity-logo-box">
                <span class="activity-logo-pgm">pgm</span>
                <span class="activity-logo-sub">STUDIO</span>
            </div>
        </a>
    }
    else
    {
        <div class="activity-logo">
            <div class="activity-logo-box">
                <span class="activity-logo-pgm">pgm</span>
                <span class="activity-logo-sub">STUDIO</span>
            </div>
        </div>
    }
    @ChildContent
</nav>

@code {
    [Parameter] public string? LogoHref { get; set; }
    [Parameter] public string? LogoTitle { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
