@namespace PgmStudio.Client.Components

@* The full-screen studio shell — the .editor-page wrapper around a Bar (a Topbar), the body, and an
   optional Footer. The default body is .app-body with an optional Rail (a NavRail) beside the
   .activity-viewport that wraps ChildContent. Two escapes: Viewport=false drops the viewport wrapper
   (ChildContent sits directly in .app-body); Bare=true drops .app-body entirely for pages that own
   their own body layout (the generator's gen-body, the /design ds-layout). *@

<div class="editor-page">
    @Bar
    @if (Bare)
    {
        @ChildContent
    }
    else
    {
        <div class="app-body">
            @Rail
            @if (Viewport)
            {
                <div class="activity-viewport">@ChildContent</div>
            }
            else
            {
                @ChildContent
            }
        </div>
    }
    @Footer
</div>

@code {
    [Parameter] public RenderFragment? Bar { get; set; }
    [Parameter] public RenderFragment? Rail { get; set; }
    [Parameter] public RenderFragment? Footer { get; set; }
    [Parameter] public bool Bare { get; set; }
    [Parameter] public bool Viewport { get; set; } = true;
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
