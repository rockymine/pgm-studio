@namespace PgmStudio.Client.Components

@* One activity-rail button — a single Lucide glyph, Active when it is the current activity. Renders an
   <a> when Href is set (navigation), else a <button> (state switch) that can be Disabled and carry a
   status dot (Status = green | yellow | red → data-status). *@

@if (Href is not null)
{
    <a class="@Cls" href="@Href" title="@Title" data-status="@Status"><i data-lucide="@Icon"></i></a>
}
else
{
    <button class="@Cls" title="@Title" disabled="@Disabled" data-status="@Status" @onclick="OnClick"><i data-lucide="@Icon"></i></button>
}

@code {
    [Parameter] public string? Icon { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Href { get; set; }
    [Parameter] public bool Active { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Status { get; set; }   // green | yellow | red → data-status
    [Parameter] public EventCallback OnClick { get; set; }

    private string Cls => Active ? "activity-btn active" : "activity-btn";
}
