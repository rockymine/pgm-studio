@namespace PgmStudio.Client.Components

@* A clean wizard step strip — a phase's icon + name, its steps (if any), and Back/Next. Its own
   strip above the workspace, never inside the canvas sub-bar (which keeps its own draw toolbar). Replaces
   numbered-circle step bars (.cfg-step-bar). *@

<div class="@Cls">
  @* @key the lucide-bearing regions by their content so Blazor RECREATES them on navigation instead of
     patching DOM that studio.icons (lucide.createIcons) has replaced with <svg> — patching the mutated
     nodes corrupts the reconciler (removeChild/non-text-child errors). *@
  <div class="flow-bar-phase" @key="@PhaseTitle"><i data-lucide="@PhaseIcon"></i><span>@PhaseTitle</span></div>
  @if (Steps.Count > 0)
  {
    <div class="flow-steps" @key="@($"{PhaseTitle}:{CurrentStep}")">
      @for (var j = 0; j < Steps.Count; j++)
      {
        var idx = j;
        var cls = idx < CurrentStep ? "flow-step flow-step--done"
                : idx == CurrentStep ? "flow-step flow-step--active"
                : "flow-step";
        @* Label only — status icons (the check) deferred to ND4 (save model), where step status gets meaning. *@
        <button class="@cls" disabled="@(idx > MaxStep)" @onclick="() => OnStep.InvokeAsync(idx)">@Steps[idx]</button>
      }
    </div>
  }
  <div class="flow-bar-actions">
    <Button Disabled="@(!BackEnabled)" OnClick="OnBack">Back</Button>
    <Button Variant="primary" Disabled="@(!NextEnabled)" OnClick="OnNext">@NextLabel</Button>
  </div>
</div>

@code {
    [Parameter] public string? Class { get; set; }
    [Parameter] public string PhaseIcon { get; set; } = "";
    [Parameter] public string PhaseTitle { get; set; } = "";
    [Parameter] public IReadOnlyList<string> Steps { get; set; } = Array.Empty<string>();
    [Parameter] public int CurrentStep { get; set; }
    /// <summary>Highest step the user may jump to via the flow bar — later steps are locked/dimmed.
    /// Default unlimited (every step is freely navigable).</summary>
    [Parameter] public int MaxStep { get; set; } = int.MaxValue;

    [Parameter] public bool BackEnabled { get; set; }
    [Parameter] public bool NextEnabled { get; set; } = true;
    [Parameter] public string NextLabel { get; set; } = "Next";

    [Parameter] public EventCallback<int> OnStep { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }
    [Parameter] public EventCallback OnNext { get; set; }

    private string Cls => string.Join(' ', new[] { "flow-bar", Class }.Where(c => !string.IsNullOrEmpty(c)));
}
