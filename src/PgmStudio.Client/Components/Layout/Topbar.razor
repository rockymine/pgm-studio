@namespace PgmStudio.Client.Components

@* The app top bar — an optional breadcrumb-home link (icon + label), a Crumbs slot for the page's
   trail (compose with <Crumb>), and a right cluster (Right slot) that ends with the theme toggle
   unless ShowTheme is off. Renders no .topbar-right at all when there is nothing to put there. *@

<div class="topbar">
    @if (HomeHref is not null)
    {
        <a class="topbar-breadcrumb-home" href="@HomeHref" title="@HomeTitle">
            @if (HomeIcon is not null) { <i data-lucide="@HomeIcon"></i> }
            <span>@HomeLabel</span>
        </a>
    }
    @Crumbs
    @if (Right is not null || ShowTheme)
    {
        <div class="topbar-right">
            @Right
            @if (ShowTheme) { <ThemeToggle /> }
        </div>
    }
</div>

@code {
    [Parameter] public string? HomeHref { get; set; }
    [Parameter] public string? HomeLabel { get; set; }
    [Parameter] public string? HomeIcon { get; set; } = "house";
    [Parameter] public string? HomeTitle { get; set; }
    [Parameter] public RenderFragment? Crumbs { get; set; }
    [Parameter] public RenderFragment? Right { get; set; }
    [Parameter] public bool ShowTheme { get; set; } = true;
}
