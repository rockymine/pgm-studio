@namespace PgmStudio.Client.Features.Edit
@inject HttpClient Http
@inject IJSRuntime JS

@* Identity phase — map identity + authors/contributors, editing the map's raw stored metadata
   directly (Version/Objective are freely editable and persist via the explicit Save below) — unlike
   Configure's Identity, which authors an intent slice that's regenerated wholesale. *@

<div class="phase-body">
<FlowBar Class="flow-bar--flush" PhaseIcon="book-open-text" PhaseTitle="Identity"
         BackEnabled="@(!IsFirstPhase)" NextLabel="@(IsLastPhase ? "Done" : "Next")"
         OnBack="OnPrevPhase" OnNext="OnNextPhase" />
<Workspace>
  <ContentColumn MaxWidth="720">
      <Section Title="Map Identity">
        <Field Label="Map Name" Required For="ov-name">
          <input id="ov-name" class="field-input" type="text" placeholder="My CTW Map"
                 value="@name" @oninput="e => { name = e.Value?.ToString() ?? string.Empty; Dirty(); }" />
        </Field>
        <div class="field-row">
          <Field Label="Version" Required For="ov-version">
            <input id="ov-version" class="field-input" type="text" placeholder="1.0.0"
                   value="@version" @oninput="e => { version = e.Value?.ToString() ?? string.Empty; Dirty(); }" />
          </Field>
          <Field Label="Gamemode" For="ov-gamemode">
            @* Derived from the map's objective modules, so it is shown rather than asked for: typing a
               gamemode could not change what the map is. Empty when the map carries no objective yet. *@
            <input id="ov-gamemode" class="field-input" type="text" disabled
                   title="Derived from the map's objectives" placeholder="—" value="@GamemodeLabel" />
          </Field>
        </div>
        <Field Label="Objective" For="ov-objective">
          <textarea id="ov-objective" class="field-input field-input--textarea" rows="2"
                    placeholder="Capture all enemy wools!"
                    value="@objective" @oninput="e => { objective = e.Value?.ToString() ?? string.Empty; Dirty(); }"></textarea>
        </Field>
      </Section>

      <AuthorsEditor Authors="authors" Contributors="contributors" OnChanged="Dirty" />

      <Section>
        <div class="panel-actions">
          <Button Variant="primary" Disabled="@(!dirty)" OnClick="Save">Save changes</Button>
          <span class="panel-save-status">@saveStatus</span>
        </div>
      </Section>
  </ContentColumn>
</Workspace>
</div>
