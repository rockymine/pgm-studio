@namespace PgmStudio.Client.Features.Configure
@using W = PgmStudio.Client.Features.Configure.WoolAuthoring

@* Wools · monuments: every wool is captured by all teams except its owner (N−1). The scan pre-fills the
   signed pedestals; box a cluster to detect more (routed by colour) or drop a manual one, and confirm the
   capturing team per row. *@

<Workspace>

  <Sidebar>
      <Section Title="Wool monuments">
        <p class="section-desc">Pick a wool to see its capture monuments. <strong>Box</strong> a cluster on
          the canvas to detect (each hit routes to its colour); an empty box drops a manual monument for the
          selected wool. Each wool needs <strong>@Expected</strong> (one per enemy team).</p>
        <Button Full Class="action-btn--separated" Disabled="@detecting" OnClick="DetectMapWide">
          <i data-lucide="scan-search"></i> @(detecting ? "Detecting…" : "Detect monuments (whole map)")
        </Button>
        <div class="panel-list" style="margin-top:var(--space-3)">
          @if (wools.Count == 0) { <div class="list-empty">No wools — confirm objectives first.</div> }
          @foreach (var w in wools)
          {
            var have = Capturers(w).Count(t => MonumentFor(w, t.Id) is not null);
            <ListRow Compact Selected="selectedColor == w.Color" @key="w.Color" OnClick="() => SelectWool(w.Color)">
              <span class="geo-type-icon" style="color:@W.Hex(w.Color)"><i data-lucide="@PointIcon"></i></span>
              <span class="list-label list-label--mono">@w.Color</span>
              <Badge Class="@(have >= Expected ? "badge--success" : "badge--warning")">@have / @Expected</Badge>
            </ListRow>
          }
        </div>
      </Section>
  </Sidebar>

  <div class="sidebar-handle"></div>

  <EditorCanvas @ref="canvas" Slug="@Slug" RectDraw="true" Category="__wool_monuments__"
                OnRectDrawn="OnBoxDrawn" OnSelect="OnCanvasSelect" OnReady="OnCanvasReady" />

  <div class="sidebar-handle"></div>

  <Inspector>
      @if (Selected is { } sel)
      {
        <Section @key="sel.Color">
          <DetailHeader Icon="@PointIcon" IconStyle='@($"color:{W.Hex(sel.Color)}")' Mono Label='@($"{sel.Color} monuments")'>
            <Badge Kind="neutral">@sel.Color wool</Badge>
          </DetailHeader>
          <div class="section-body">
            <p class="section-desc">Captured by every team except <strong>@(string.IsNullOrEmpty(sel.Owner) ? "—" : TeamName(sel.Owner))</strong> (its owner).</p>
            @foreach (var cap in Capturers(sel))
            {
              var m = MonumentFor(sel, cap.Id);
              <Field @key="cap.Id">
                <LabelHint>
                  <span class="list-swatch list-swatch--sm" style="background:@W.Hex(TeamColorOf(cap.Id))"></span>
                  @cap.Name captures
                </LabelHint>
                <ChildContent>
                @if (m is not null)
                {
                  <div class="ctrl-row">
                    <CoordField Prefix="X" Value="@m.X" ReadOnly />
                    <CoordField Prefix="Y" Value="@m.Y" ReadOnly />
                    <CoordField Prefix="Z" Value="@m.Z" ReadOnly />
                    <Button Title="Remove" OnClick="() => DeleteMonument(sel, m)"><i data-lucide="trash-2"></i></Button>
                  </div>
                }
                else
                {
                  <div class="field-value text-muted">Not placed — box its pedestal on the canvas.</div>
                }
                </ChildContent>
              </Field>
            }
            @{ var stray = sel.Monuments.Where(m => Capturers(sel).All(t => t.Id != m.Team)).ToList(); }
            @if (stray.Count > 0)
            {
              <Field>
                <LabelHint><span class="text-warning">Unassigned capturer</span></LabelHint>
                <ChildContent>
                @foreach (var m in stray)
                {
                  <div class="ctrl-row" @key="m">
                    <select class="field-input" @onchange="@(e => SetMonumentTeam(sel, m, e.Value?.ToString() ?? string.Empty))">
                      <option value="" selected>— team —</option>
                      @foreach (var t in Capturers(sel))
                      {
                        <option value="@t.Id">@t.Name</option>
                      }
                    </select>
                    <Button Title="Remove" OnClick="() => DeleteMonument(sel, m)"><i data-lucide="trash-2"></i></Button>
                  </div>
                }
                </ChildContent>
              </Field>
            }
          </div>
        </Section>
      }
      else
      {
        <Section>
          <DetailHeader Icon="@PointIcon" IconMuted Label="Monuments" />
          <p class="section-desc">Select a wool to see its capture monuments.</p>
        </Section>
      }
  </Inspector>

</Workspace>
