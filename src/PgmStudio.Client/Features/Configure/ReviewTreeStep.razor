@namespace PgmStudio.Client.Features.Configure

@* Review & Export · Region tree step (N07): read-only inspect/debug view of the full generated tree.
   Reuses the editor's RegionTree component (collapse · type icons · synthetic-id styling). Writes nothing. *@

<Workspace>
  <ContentColumn MaxWidth="760">
    <Section Title="Regions">
      <Actions>
        <Badge Kind="dim">read-only@(RegionCount > 0 ? $" · {RegionCount} regions" : "")</Badge>
      </Actions>
      <ChildContent>
        <p class="section-desc">For intent maps the shaping steps drop the tree — structure is a generated
          artifact — so it lives here as the inspect &amp; debug view of what the generator produced. The
          unions, the negative wrappers, and the synthetic <code>__anon_N</code> ids are structural glue, not
          authored decisions. To change a region, return to the step that emits it (Teams · Build · Wools); the
          tree regenerates on save.</p>

        @if (loading)
        {
          <p class="panel-empty-msg">Loading…</p>
        }
        else if (error is not null)
        {
          <div class="panel-warning"><strong>Couldn't load the region tree.</strong> @error</div>
        }
        else
        {
          <RegionTree Groups="groups" />
        }
      </ChildContent>
    </Section>
  </ContentColumn>
</Workspace>
