@namespace PgmStudio.Client.Features.Sketch

@* Sketch Layout tree — islands (collapsible parents) with their contributing shapes as indented
   children. Same geo-tree format as the region tree (geo-indent pipes + collapse chevrons). Selection
   only; per-item actions live in SketchInspector. Rendered inside the editor's workspace-sidebar. *@

<Section Title="Islands">
  <div class="region-tree">
    @if (!Islands.Any() && !Shapes.Any())
    {
      <div class="panel-empty-msg">Draw shapes to form islands.</div>
    }
    else
    {
      @foreach (var isl in Islands)
      {
        <div class="geo-row @(isl.Id == SelectedIslandId ? "geo-row--selected" : null)"
             @onclick="() => OnSelectIsland.InvokeAsync(isl.Id)">
          <span class="geo-indent">
            @if (isl.ShapeIds.Count > 0)
            {
              @* @key on the collapsed state forces Blazor to recreate the button (and a fresh
                 <i data-lucide>) when it flips — lucide replaced the old <i> with an <svg>, so an
                 in-place attribute swap wouldn't change the rendered icon. *@
              <button class="collapse-btn" @key="@(collapsed.Contains(isl.Id))" @onclick="() => Toggle(isl.Id)" @onclick:stopPropagation="true">
                <i data-lucide="@(collapsed.Contains(isl.Id) ? "chevron-right" : "chevron-down")"></i>
              </button>
            }
          </span>
          <span class="geo-type-icon" style="@(isl.Mirrors ? null : "color:var(--text-muted)")"><i data-lucide="layers"></i></span>
          <span class="geo-label" title="@isl.Name">@isl.Name</span>
          <span class="list-tag">@isl.ShapeIds.Count shape@(isl.ShapeIds.Count == 1 ? "" : "s")</span>
        </div>
        @if (!collapsed.Contains(isl.Id))
        {
          @foreach (var sid in isl.ShapeIds)
          {
            var s = ShapeById(sid);
            @if (s is not null)
            {
              <div class="geo-row @(s.Id == SelectedShapeId ? "geo-row--selected" : null)"
                   @onclick="() => OnSelectShape.InvokeAsync(s.Id)">
                <span class="geo-indent"><span class="indent-pipe"></span></span>
                <span class="geo-type-icon" style="@(s.Operation == "subtract" ? "color:var(--canvas-sub-fill)" : null)"><i data-lucide="@TypeIcon(s.Type)"></i></span>
                <span class="geo-label">@s.Type</span>
                <span class="list-tag">@s.Dim</span>
                @if (s.Override)
                {
                  <span class="geo-type-icon geo-type-icon--warning geo-type-icon--flush" title="Override"><i data-lucide="shield"></i></span>
                }
              </div>
            }
          }
        }
      }
      @foreach (var s in Unassigned())
      {
        <div class="geo-row @(s.Id == SelectedShapeId ? "geo-row--selected" : null)"
             @onclick="() => OnSelectShape.InvokeAsync(s.Id)">
          <span class="geo-indent"></span>
          <span class="geo-type-icon" style="@(s.Operation == "subtract" ? "color:var(--canvas-sub-fill)" : null)"><i data-lucide="@TypeIcon(s.Type)"></i></span>
          <span class="geo-label">@s.Type</span>
          <span class="list-tag">@s.Dim</span>
          @if (s.Override)
          {
            <span class="geo-type-icon geo-type-icon--warning geo-type-icon--flush" title="Override"><i data-lucide="shield"></i></span>
          }
        </div>
      }
    }
  </div>
</Section>
