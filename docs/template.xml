<map proto="1.4.0">
<name>CTW Template Advanced</name>
<version>1.0.0</version>
<objective>Capture both wools!</objective>
<gamemode>ctw</gamemode>
<created>0001-01-01</created> <!-- yyyy-mm-dd -->
<phase>development</phase>
<include id="gapple-kill-reward"/>
<include id="iron-bulkcrafting"/>
<authors>
    <author uuid="e2d2c2c6-cea9-4510-9ab2-a091b5605b30"/> <!-- Ruediger_LP -->
    <author uuid="fe3608b7-d105-4029-8800-34b3147065b6"/> <!-- rockymine -->
    <author uuid="f1ff7ecc-2e79-4320-85de-adb392eb2822"/> <!-- DerStiv -->
    <author uuid="ec5ec930-5cf3-4f8a-ad9f-09056aeed71b"/> <!-- Tundren -->
    <author uuid="b2539be1-8f98-4375-b653-9d91cd04c30e"/> <!-- Mewzzy -->
    <author uuid="d5a64b26-15ea-46c4-8319-f9c83e82a1fa"/> <!-- Eliminate -->
    <author uuid="cc01304f-907b-4c80-b9c2-8f61872969d1"/> <!-- Just_ -->
    <author uuid="eecceb3e-07e2-43cf-9686-3965d087ac12"/> <!-- xaeros -->
    <author uuid="93015a6b-c2a3-4023-bba7-4ee6634bb5c8"/> <!-- Shuliett -->
    <author uuid="1bac62d3-1553-41b6-a70b-613396071c5d"/> <!-- ItsMeKiing -->
    <author uuid="74271a2f-47c0-4bd7-9a9f-4dc7eaedabe0"/> <!-- killtrixy -->
    <author uuid="6863869b-4b8c-4445-b778-a8e016775ae4"/> <!-- Cazadorian -->
    <author uuid="2ca8072f-74be-4798-85b8-bbce03aa91af"/> <!-- Tywnis -->
    <author uuid="5198dc37-537f-4ea5-8ee8-1e0952d4a36b"/> <!-- _3Each -->
    <author uuid="e4cfa2d5-6b11-4e15-a893-9d92f18385f3"/> <!-- mariogoat -->
    <author uuid="63ddf58a-ba2c-4d39-8481-6358bb46c63a"/> <!-- samschaap -->
    <author uuid="4ed45d5d-bdc3-4f1a-9201-014e06019618"/> <!-- Trionaf -->
    <author uuid="74efe633-e238-465f-b167-d772b1c42107"/> <!-- Fbpr27 -->
    <author uuid="924c4e61-57b6-4931-afdb-6525b2ed34c0"/> <!-- OAF6 -->
</authors>
<contributors>
    <contributor uuid="e2d2c2c6-cea9-4510-9ab2-a091b5605b30" contribution="xml"/> <!-- Ruediger_LP -->
</contributors>
<teams>
    <team id="blue-team" color="blue" dye-color="blue" max="32">Blue</team>
    <team id="red-team" color="red" dye-color="red" max="32">Red</team>
</teams>
<kits>
    <kit id="spawn-kit">
        <clear/>
        <item slot="0" material="iron sword" unbreakable="true"/>
        <item slot="1" material="bow" unbreakable="true">
            <enchantment>arrow infinite</enchantment>
        </item>
        <item slot="2" material="iron pickaxe" unbreakable="true">
            <enchantment level="2">dig speed</enchantment>
        </item>
        <item slot="3" material="iron axe" unbreakable="true">
            <enchantment level="2">dig speed</enchantment>
        </item>
        <item slot="4" material="wood" amount="64"/>
        <item slot="5" material="stained clay" amount="48" team-color="true"/>
        <item slot="6" material="vine" amount="24"/>
        <item slot="8" material="golden apple"/>
        <item slot="28" material="arrow"/>
        <item slot="29" material="shears" unbreakable="true"/>
        <item slot="30" material="iron spade" unbreakable="true">
            <enchantment level="2">dig speed</enchantment>
        </item>
        <helmet material="iron helmet" unbreakable="true"/>
        <chestplate material="chainmail chestplate" unbreakable="true"/>
        <leggings material="leather leggings" team-color="true" unbreakable="true"/>
        <boots material="leather boots" team-color="true" unbreakable="true"/>
        <effect duration="oo" amplifier="100">damage resistance</effect>
    </kit>
    <kit id="reset-resistance-kit" force="true">
        <effect duration="0" amplifier="0">damage resistance</effect>
    </kit>
</kits>
<spawns>
    <spawn team="blue-team" kit="spawn-kit" yaw="0" region="blue-spawn-point"/>
    <spawn team="red-team" kit="spawn-kit" yaw="0" region="red-spawn-point"/>
    <default yaw="0" region="obs-spawn-point"/>
</spawns>
<wools craftable="false">
    <wool team="blue-team" color="green" monument="blue-team-green-wool" location="asdf"/>
    <wool team="blue-team" color="lime" monument="blue-team-lime-wool" location="yxcv"/>
    <wool team="red-team" color="yellow" monument="red-team-yellow-wool" location="qwer"/>
    <wool team="red-team" color="orange" monument="red-team-orange-wool" location="tzui"/>
</wools>
<filters>
    <any id="block-break-void-filter">
        <all>
            <any>
                <material>leaves</material>
                <material>log</material>
            </any>
            <void/>
        </all>
        <not id="block-place-void-filter">
            <void/>
        </not>
    </any>
    <all id="reds-woolrooms-filter">
        <team id="only-blue">blue-team</team>
        <filter id="woolrooms-filter"/>
    </all>
    <all id="blues-woolrooms-filter">
        <team id="only-red">red-team</team>
        <filter id="woolrooms-filter"/>
    </all>
    <any id="woolrooms-filter">
        <material>web</material>
        <material>wood:0</material>
        <material>stained clay:14</material>
        <material>stained clay:11</material>
        <material>vine</material>
        <all>
            <cause>player</cause>
            <any>
                <material>stationary water</material>
                <material>water</material>
            </any>
        </all>
    </any>
    <all id="only-iron-cause-world">
        <material id="only-iron">iron block</material>
        <cause>world</cause>
    </all>
    <material id="only-air">air</material>
    <deny id="deny-physics">
        <any>
            <material>redstone wire</material>
            <material>flower pot</material>
        </any>
    </deny>
</filters>
<regions>
    <cylinder id="blue-spawn-point" base="0,20,0" radius="1" height="0"/>
    <cylinder id="red-spawn-point" base="0,20,0" radius="1" height="0"/>
    <cylinder id="obs-spawn-point" base="0,20,0" radius="1" height="0"/>
    <point id="green-wool-spawn">asdf</point>
    <point id="lime-wool-spawn">yxcv</point>
    <point id="yellow-wool-spawn">qwer</point>
    <point id="orange-wool-spawn">tzui</point>
    <negative id="not-spawns">
        <union id="spawns">
            <complement>
                <union>
                    <rectangle id="blue-spawn" min="0,0" max="0,0"/>
                    <rectangle id="red-spawn" min="0,0" max="0,0"/>
                </union>
                <block id="blue-team-green-wool">0,0,0</block>
                <block id="blue-team-lime-wool">0,0,0</block>
                <block id="red-team-yellow-wool">0,0,0</block>
                <block id="red-team-orange-wool">0,0,0</block>
            </complement>
        </union>
    </negative>
    <union id="woolrooms">
        <union id="blues-woolrooms"> <!-- blue defends / red attacks -->
            <rectangle id="yellow-woolroom" min="0,0" max="0,0"/>
            <rectangle id="orange-woolroom" min="0,0" max="0,0"/>
        </union>
        <union id="reds-woolrooms"> <!-- red defends / blue attacks -->
            <rectangle id="green-woolroom" min="0,0" max="0,0"/>
            <rectangle id="lime-woolroom" min="0,0" max="0,0"/>
        </union>
    </union>
    <negative id="not-build-region">
        <union id="build-region">
            <rectangle min="0,0" max="0,0"/>
            <rectangle min="0,0" max="0,0"/>
            <rectangle min="0,0" max="0,0"/>
        </union>
    </negative>
    <!-- applicators -->
    <apply enter="only-blue" region="blue-spawn" message="You may not enter the enemy's spawn!"/>
    <apply enter="only-red" region="red-spawn" message="You may not enter the enemy's spawn!"/>
    <apply enter="only-red" region="blues-woolrooms" message="You may not enter your own wool room!"/>
    <apply enter="only-blue" region="reds-woolrooms" message="You may not enter your own wool room!"/>
    <apply block-place="only-iron-cause-world" block-break="only-iron" region="spawns" message="You may not edit spawn!"/>
    <apply block="blues-woolrooms-filter" region="blues-woolrooms" message="You may not edit the wool room!"/>
    <apply block="reds-woolrooms-filter" region="reds-woolrooms" message="You may not edit the wool room!"/>
    <apply block-place="block-place-void-filter" block-break="block-break-void-filter" region="not-build-region" message="You may not edit the void!"/>
    <apply kit="reset-resistance-kit" region="not-spawns"/>
    <apply block-physics="deny-physics" region="woolrooms"/>
</regions>
<spawners>
    <spawner spawn-region="green-wool-spawn" player-region="green-woolroom" delay="1.5s">
        <item material="wool" amount="1" damage="13"/>
    </spawner>
    <spawner spawn-region="lime-wool-spawn" player-region="lime-woolroom" delay="1.5s">
        <item material="wool" amount="1" damage="5"/>
    </spawner>
    <spawner spawn-region="yellow-wool-spawn" player-region="yellow-woolroom" delay="1.5s">
        <item material="wool" amount="1" damage="4"/>
    </spawner>
    <spawner spawn-region="orange-wool-spawn" player-region="orange-woolroom" delay="1.5s">
        <item material="wool" amount="1" damage="1"/>
    </spawner>
</spawners>
<toolrepair>
    <tool>iron sword</tool>
    <tool>bow</tool>
    <tool>iron pickaxe</tool>
    <tool>iron axe</tool>
    <tool>arrow</tool>
    <tool>shears</tool>
    <tool>iron spade</tool>
</toolrepair>
<itemkeep>
    <item>iron sword</item>
    <item>bow</item>
    <item>iron pickaxe</item>
    <item>iron axe</item>
    <item>arrow</item>
    <item>shears</item>
    <item>iron spade</item>
    <item>wood</item>
    <item>stained clay</item>
    <item>vine</item>
    <item>golden apple</item>
</itemkeep>
<itemremove>
    <item>iron helmet</item>
    <item>chainmail chestplate</item>
    <item>leather leggings</item>
    <item>leather boots</item>
    <item>stone</item>
</itemremove>
<block-drops>
    <rule>
        <filter>
            <any>
                <material>wood</material>
                <material>stained clay:11</material>
                <material>stained clay:14</material>
            </any>
        </filter>
        <drops>
            <item chance="0" material="wood"/>
        </drops>
    </rule>
</block-drops>
<item-mods>
    <rule>
        <match>
            <material>iron sword</material>
            <material>iron pickaxe</material>
            <material>iron axe</material>
            <material>iron spade</material>
            <material>shears</material>
            <material>bow</material>
            <material>diamond chestplate</material>
        </match>
        <modify unbreakable="true"/>
    </rule>
</item-mods>
<renewables>
    <renewable rate="1" region="spawns" renew-filter="only-iron" replace-filter="only-air" avoid-players="2"/>
</renewables>
<hunger>
    <depletion>off</depletion>
</hunger>
<maxbuildheight>100</maxbuildheight>
<kill-rewards>
    <kill-reward>
        <item material="wood" amount="48"/>
    </kill-reward>
</kill-rewards>
</map>
